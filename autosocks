# ============================================================
# 函数：_install_dbip
# 功能：检测并安装DB-IP国家IP归属地数据库
# 依赖：无
# 返回：0成功，1失败
# 错误码：
#   0 - 成功
#   1 - 下载失败
#   2 - 解压失败
# ============================================================
_install_dbip() {
    local db_dir="/var/lib/GeoIP"
    local db_file="$db_dir/GeoIP.dat"
    local db_url="https://download.db-ip.com/free/dbip-country-lite-$(date +%Y-%m).gz"

    # 1. 检查是否已安装
    if [ -f "$db_file" ]; then
        log "INFO" "geo" "DB-IP数据库已存在，跳过安装"
        return 0
    fi

    # 2. 创建目录
    mkdir -p "$db_dir" 2>/dev/null || true

    # 3. 下载数据库（3次重试）
    local downloaded=false
    for i in 1 2 3; do
        echo "📥 正在下载DB-IP数据库... (尝试 $i/3)"
        if wget -q -O "$db_file.gz" "$db_url" 2>/dev/null; then
            downloaded=true
            break
        fi
        echo "⚠️ 下载失败，2秒后重试..."
        sleep 2
    done

    if [ "$downloaded" = "false" ]; then
        print_error "DB-IP数据库下载失败" "E902"
        return 1
    fi

    # 4. 解压
    echo "📦 正在解压..."
    gunzip -f "$db_file.gz"

    # 5. 验证
    if [ -f "$db_file" ] && [ -s "$db_file" ]; then
        print_success "DB-IP数据库安装成功"
        log "INFO" "geo" "DB-IP数据库安装完成"
        return 0
    else
        print_error "DB-IP数据库文件无效" "E903"
        rm -f "$db_file"
        return 1
    fi
}

# ============================================================
# 函数：_check_dbip_works
# 功能：检查DB-IP数据库是否可用
# 返回：0可用，1不可用
# ============================================================
_check_dbip_works() {
    if ! command -v geoiplookup &>/dev/null; then
        return 1
    fi

    if [ ! -f "/var/lib/GeoIP/GeoIP.dat" ]; then
        return 1
    fi

    # 测试查询
    local result
    result=$(geoiplookup 8.8.8.8 2>/dev/null)
    if [ -n "$result" ]; then
        return 0
    fi

    return 1
}

# ============================================================
# 函数：geo_on
# 功能：开启GeoIP分流功能
# ============================================================
geo_on() {
    echo "🚀 正在开启分流功能..."
    echo ""

    # 检查root权限
    if [ "$(id -u)" -ne 0 ]; then
        print_error "需要管理员权限运行" "E904"
        echo ""
        echo "  请使用 sudo 运行："
        echo "  sudo autosocks geo on"
        return 3
    fi

    # 安装DB-IP
    echo "📥 正在安装DB-IP数据库..."
    if ! _install_dbip; then
        print_warning "DB-IP安装失败，分流功能可能不完整"
    fi
    echo ""

    # 下载国内IP列表 (E9-S02)
    echo "📥 正在下载国内IP列表..."
    if ! _download_china_ip; then
        print_warning "国内IP列表下载失败，将使用缓存"
    fi
    echo ""

    # 检查geoiplookup
    if ! command -v geoiplookup &>/dev/null; then
        print_warning "geoiplookup命令不可用，将安装..."
        echo "  安装：apt-get install geoip-bin"
    fi

    echo "✅ GeoIP分流功能已就绪"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  分流功能    ✅ 已开启"
    echo "  下一步     请运行 autosocks geo status 查看状态"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    log "INFO" "geo" "分流功能已开启"
    return 0

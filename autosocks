# --------------------
# 权限检查（E3-S01）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_root
# 功能：检查当前用户是否有 root 权限
# 参数：无
# 返回：
#   0 - 有 root 权限
#   1 - 无 root 权限
# 示例：
#   check_root
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_root() {
    if [ "$EUID" -eq 0 ]; then
        return 0
    else
        print_error "权限不足" "E001"
        echo ""
        echo "试试这个："
        echo "• 在命令前面加 sudo"
        echo "• 例如：sudo autosocks start"
        echo ""
        return 1
    fi
}

# --------------------
# SSH检查（E3-S02）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_ssh
# 功能：检查系统是否安装了 SSH 客户端
# 参数：无
# 返回：
#   0 - SSH 已安装
#   1 - SSH 未安装
# 示例：
#   check_ssh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_ssh() {
    if command -v ssh &>/dev/null; then
        return 0
    else
        print_error "SSH 未安装" "E007"
        echo ""
        echo "试试这个："
        # 检测操作系统类型，给出对应的安装命令
        if [ -f /etc/debian_version ]; then
            echo "• Ubuntu/Debian: sudo apt-get install openssh-client"
        elif [ -f /etc/redhat-release ]; then
            echo "• CentOS/RHEL: sudo yum install openssh-clients"
        else
            echo "• Ubuntu/Debian: sudo apt-get install openssh-client"
            echo "• CentOS/RHEL: sudo yum install openssh-clients"
        fi
        echo ""
        return 1
    fi
}

# --------------------
# systemd检查（E3-S03）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_systemd
# 功能：检查系统是否支持 systemd 服务管理
# 参数：无
# 返回：
#   0 - systemd 可用
#   1 - systemd 不可用
# 示例：
#   check_systemd
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_systemd() {
    # 方法1：检查 systemd 进程
    if pidof systemd >/dev/null 2>&1; then
        local version
        version=$(systemctl --version 2>/dev/null | head -1)
        log INFO "check" "systemd 可用：$version"
        return 0
    fi

    # 方法2：检查 systemctl 命令
    if command -v systemctl >/dev/null 2>&1; then
        local version
        version=$(systemctl --version 2>/dev/null | head -1)
        log INFO "check" "systemd 可用：$version"
        return 0
    fi

    # systemd 不可用
    print_error "systemd 不可用" "E008"
    echo ""
    echo "您的系统不支持 systemd，无法使用以下功能："
    echo "• 开机自启"
    echo "• 断线自动重连"
    echo ""
    echo "AutoSOCKS 可以在没有 systemd 的系统上运行，"
    echo "但需要手动启动，且不会自动重连。"
    echo ""
    return 1
}

# --------------------
# 端口检查（E3-S04）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_port
# 功能：检查指定端口是否被占用
# 参数：$1 - 端口号（1-65535）
# 返回：
#   0 - 端口可用
#   1 - 端口被占用或参数错误
# 示例：
#   check_port 1080
#   check_port 8080
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_port() {
    local port="$1"

    # AC-01: 验证端口号格式
    if [ -z "$port" ]; then
        print_error "缺少端口号参数" "E012"
        echo ""
        echo "正确用法：check_port 1080"
        return 1
    fi

    if ! echo "$port" | grep -qE '^[0-9]+$'; then
        print_error "端口号格式错误（应为数字）" "E012"
        echo ""
        echo "正确格式：端口号（1-65535）"
        echo "示例：check_port 1080"
        return 1
    fi

    # 验证端口范围
    if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        print_error "端口号超出范围（应为 1-65535）" "E012"
        echo ""
        echo "有效端口范围：1 - 65535"
        echo "常用端口：1080, 8080, 1081"
        return 1
    fi

    log DEBUG "check" "检查端口 $port 是否被占用..."

    # AC-06: 优先使用 ss 命令检查端口
    if command -v ss >/dev/null 2>&1; then
        if ss -tln 2>/dev/null | grep -qE ":${port}[[:space:]]"; then
            # AC-04: 输出错误码 E002
            print_error "端口 $port 被占用" "E002"
            echo ""
            # AC-05: 提示解决方案
            echo "试试这些："
            echo "• 换个端口：autosocks install --port $((port + 1))"
            echo "• 查看谁在用：sudo ss -tlnp | grep :${port}"
            echo ""
            log WARN "check" "端口 $port 已被占用（使用 ss 检测）"
            return 1
        fi
        log INFO "check" "端口 $port 可用（使用 ss 检测）"
        return 0
    fi

    # AC-07: 备用方案，使用 netstat 命令
    if command -v netstat >/dev/null 2>&1; then
        if netstat -tln 2>/dev/null | grep -qE ":${port}[[:space:]]"; then
            # AC-04: 输出错误码 E002
            print_error "端口 $port 被占用" "E002"
            echo ""
            # AC-05: 提示解决方案
            echo "试试这些："
            echo "• 换个端口：autosocks install --port $((port + 1))"
            echo "• 查看谁在用：sudo netstat -tlnp | grep :${port}"
            echo ""
            log WARN "check" "端口 $port 已被占用（使用 netstat 检测）"
            return 1
        fi
        log INFO "check" "端口 $port 可用（使用 netstat 检测）"
        return 0
    fi

    # ss 和 netstat 都不可用，警告但继续
    log WARN "check" "无法检测端口占用（ss 和 netstat 都不可用），跳过检查"
    print_warning "无法检测端口占用（缺少 ss 和 netstat 命令）"
    echo "  建议安装："
    echo "  • Ubuntu/Debian: sudo apt-get install iproute2"
    echo "  • CentOS/RHEL: sudo yum install iproute"
    echo ""
    return 0
}

# --------------------
# 网络检查（E3-S05）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_network
# 功能：检查网络是否通畅
# 参数：$1 - 超时时间（秒），默认5秒
# 返回：
#   0 - 网络通畅
#   1 - 网络不通
# 示例：
#   check_network           # 使用默认5秒超时
#   check_network 10        # 使用10秒超时
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# check_network - 检查网络连接
# 参数：$1 - 超时时间（秒），默认5秒（可选）
# 返回：0=通畅，1=不通
# 注意：调用时不传参数使用默认值，这是设计意图
# shellcheck disable=SC2120
check_network() {
    local timeout="${1:-5}"

    log INFO "check" "检查网络连接（超时：${timeout}秒）..."

    # 使用 ping 测试网络（ping Google DNS）
    if ping -c 1 -W "$timeout" 8.8.8.8 >/dev/null 2>&1; then
        log INFO "check" "网络连接正常"
        return 0
    else
        print_error "网络不通" "E003"
        echo ""
        echo "可能原因："
        echo "1. 网络没连上"
        echo "2. 防火墙阻止了 ping"
        echo "3. DNS 解析失败"
        echo ""
        echo "试试这些："
        echo "• 检查网络：ping 8.8.8.8"
        echo "• 检查网线：确认网线插好"
        echo "• 检查WiFi：确认已连接到无线网络"
        echo ""
        log WARN "check" "网络连接失败"
        return 1
    fi
}

# --------------------
# 服务器连接检查（E3-S06）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_server
# 功能：检查服务器连接和认证
# 参数：
#   $1 - server  服务器地址（格式：user@ip 或 user@hostname）
#   $2 - port    SSH端口（默认22）
# 返回：
#   0 - 连接成功且认证通过
#   1 - 连接或认证失败
# 错误码：
#   E003 - 网络不通（无法连接到服务器IP）
#   E004 - 认证失败（SSH响应但认证失败）
#   E011 - SSH服务未响应（端口通但SSH不响应）
#   E012 - 格式错误（服务器地址格式不正确）
# 示例：
#   check_server root@192.168.1.100
#   check_server root@192.168.1.100 2222
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_server() {
    local server="$1"
    local port="${2:-22}"

    # AC-01: 校验服务器地址格式
    if [ -z "$server" ]; then
        print_error "缺少服务器地址参数" "E012"
        echo ""
        echo "正确格式：user@ip地址"
        echo "示例：root@192.168.1.100"
        return 1
    fi

    # 验证服务器地址格式（支持IP和域名）
    # 格式：user@ip 或 user@hostname.domain
    if ! echo "$server" | grep -qE '^[a-zA-Z_][a-zA-Z0-9_-]*@[a-zA-Z0-9.-]+$'; then
        print_error "服务器地址格式错误" "E012"
        echo ""
        echo "正确格式：user@ip地址"
        echo "示例：root@192.168.1.100"
        echo "      admin@server.example.com"
        return 1
    fi

    # AC-02: 解析服务器地址
    local server_user
    local server_host
    server_user="${server%@*}"
    server_host="${server#*@}"

    log INFO "check" "测试服务器连接：${server_user}@${server_host}:${port}"

    # AC-04: 步骤1 - 测试端口连通性
    log DEBUG "check" "测试端口连通性..."
    if ! nc -z -w 5 "$server_host" "$port" 2>/dev/null; then
        print_error "无法连接到服务器" "E003"
        echo ""
        echo "服务器：${server_host}:${port}"
        echo ""
        echo "可能原因："
        echo "1. 服务器地址写错了"
        echo "2. 服务器没开机"
        echo "3. 防火墙阻止了连接"
        echo "4. 网络不通"
        echo ""
        echo "试试这些："
        echo "• 检查地址：确认 IP 地址正确"
        echo "• 测试网络：ping ${server_host}"
        echo "• 检查端口：telnet ${server_host} ${port}"
        echo ""
        log WARN "check" "端口连通性测试失败: ${server_host}:${port}"
        return 1
    fi

    log DEBUG "check" "端口 ${port} 可达"

    # AC-05: 步骤2 - 测试SSH服务响应
    # 通过检测 SSH banner 来确认是 SSH 服务
    log DEBUG "check" "测试SSH服务响应..."
    local ssh_banner
    ssh_banner=$(timeout 5 bash -c "echo '' | nc -w 3 ${server_host} ${port} 2>/dev/null" | head -1)

    if [ -z "$ssh_banner" ] || ! echo "$ssh_banner" | grep -qi "SSH"; then
        print_error "服务器SSH服务未响应" "E011"
        echo ""
        echo "服务器：${server_host}:${port}"
        echo ""
        echo "可能原因："
        echo "1. 服务器SSH服务没启动"
        echo "2. SSH端口配置错误（默认22，你可能用了其他端口）"
        echo "3. 防火墙拦截了SSH协议"
        echo ""
        echo "试试这些："
        echo "• 确认SSH端口：是否使用了非标准端口？"
        echo "• 手动测试：ssh -p ${port} ${server_user}@${server_host}"
        echo "• 系管理员检查：systemctl status sshd"
        echo ""
        log WARN "check" "SSH服务未响应: ${server_host}:${port}"
        return 1
    fi

    log DEBUG "check" "SSH服务响应正常: ${ssh_banner}"

    # AC-07 & AC-08: 步骤3 - 测试SSH认证（仅密钥模式）
    if [ "$AUTH_TYPE" = "key" ]; then
        log INFO "check" "测试SSH认证（密钥模式）..."

        # 使用 BatchMode 测试密钥认证（不提示输入密码）
        if ! ssh -o BatchMode=yes \
                  -o ConnectTimeout=5 \
                  -o StrictHostKeyChecking=accept-new \
                  -p "$port" \
                  "${server_user}@${server_host}" \
                  exit 2>/dev/null; then
            # AC-06: 认证失败 - 先检测远程服务器是否启用了公钥认证
            log INFO "check" "SSH认证失败，检测远程服务器公钥认证状态..."

            local pubkey_result
            check_pubkey_auth "${server_user}@${server_host}" "$port"
            pubkey_result=$?

            if [ $pubkey_result -eq 1 ]; then
                # E014: 远程服务器未启用公钥认证
                print_error "远程服务器未启用公钥认证" "E014"
                echo ""
                echo "服务器：${server_user}@${server_host}:${port}"
                echo ""
                echo "问题：远程服务器的 SSH 没有开启公钥登录功能"
                echo ""
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                read -r -p "是否尝试自动启用公钥认证？[y/N]: " enable_choice
                echo ""

                if [ "$enable_choice" = "y" ] || [ "$enable_choice" = "Y" ]; then
                    enable_pubkey_auth "${server_user}@${server_host}" "$port"
                    local enable_result=$?
                    if [ $enable_result -eq 0 ]; then
                        # 启用成功，提示上传公钥后重试
                        echo ""
                        print_info "配置完成后，请重新运行安装命令："
                        echo "  autosocks install --server ${server_user}@${server_host}"
                        echo ""
                        return 1
                    elif [ $enable_result -eq 2 ]; then
                        # 用户选择手动处理
                        return 1
                    else
                        # 启用失败
                        return 1
                    fi
                else
                    _show_manual_pubkey_instructions "${server_user}@${server_host}" "$port"
                fi
                log WARN "check" "远程服务器未启用公钥认证"
                return 1
            fi

            # 公钥认证已启用，但认证仍然失败 - 其他原因
            print_error "认证失败" "E004"
            echo ""
            echo "服务器：${server_user}@${server_host}:${port}"
            echo ""
            echo "可能原因："
            echo "1. 用户名写错了"
            echo "2. 密钥文件不对"
            echo "3. 服务器上没有配置你的公钥"
            echo "4. 密钥文件权限不正确"
            echo ""
            echo "试试这些："
            echo "• 检查用户名：确认服务器上有这个用户"
            echo "• 检查密钥：ls -la ~/.ssh/id_rsa"
            echo "• 修复权限：chmod 600 ~/.ssh/id_rsa"
            echo "• 手动测试：ssh -p ${port} ${server_user}@${server_host}"
            echo "• 上传公钥：ssh-copy-id -p ${port} ${server_user}@${server_host}"
            echo ""
            log WARN "check" "SSH认证失败（密钥模式）"
            return 1
        fi

        log INFO "check" "SSH认证测试通过"
    else
        # AC-08: 密码模式跳过认证测试
        log INFO "check" "密码模式：跳过SSH认证测试（密码模式下无法自动验证）"
        print_warning "密码模式无法自动验证认证，请确保密码正确"
    fi

    # 所有检查通过
    log INFO "check" "服务器连接测试成功: ${server_user}@${server_host}:${port}"
    return 0
}

# --------------------
# 密钥权限检查（E3-S07）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_key_perm
# 功能：检查并修复 SSH 密钥文件权限
# 参数：$1 - 密钥文件路径（默认：~/.ssh/id_rsa）
# 返回：
#   0 - 成功或已修复
#   1 - 文件不存在或无法修复
# 示例：
#   check_key_perm                    # 检查默认密钥
#   check_key_perm /path/to/key       # 检查指定密钥
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_key_perm() {
    local key_file="${1:-$HOME/.ssh/id_rsa}"

    log DEBUG "check" "检查密钥文件权限：$key_file"

    # AC-07: 检查文件是否存在
    if [ ! -f "$key_file" ]; then
        print_error "密钥文件不存在：$key_file" "E010"
        echo ""
        echo "你的密钥文件：$key_file"
        echo ""
        echo "如果你还没有密钥，需要先生成："
        echo "• 运行：ssh-keygen -t rsa"
        echo ""
        log WARN "check" "密钥文件不存在: $key_file"
        return 1
    fi

    # AC-03: 获取当前权限（兼容 Linux 和 macOS）
    local current_perms
    if stat -c %a /dev/null 2>/dev/null; then
        # Linux 方式
        current_perms=$(stat -c %a "$key_file" 2>/dev/null)
    else
        # macOS/BSD 方式
        current_perms=$(stat -f %Lp "$key_file" 2>/dev/null)
    fi

    # 如果无法获取权限，报错
    if [ -z "$current_perms" ]; then
        print_error "无法获取密钥文件权限" "E010"
        echo ""
        echo "你的密钥文件：$key_file"
        echo ""
        log ERROR "check" "无法获取密钥权限: $key_file"
        return 1
    fi

    # AC-04: 检查权限是否正确（应为 600）
    if [ "$current_perms" = "600" ]; then
        log INFO "check" "密钥权限正确：$key_file (600)"
        return 0
    fi

    # AC-05, AC-06: 权限不正确，自动修复
    log WARN "check" "密钥权限不正确（当前：$current_perms），正在自动修复..."
    print_warning "密钥权限不正确，正在自动修复..."

    if chmod 600 "$key_file" 2>/dev/null; then
        print_success "密钥权限已自动修复为 600"
        log INFO "check" "密钥权限已修复：$key_file (600)"
        return 0
    else
        # 修复失败
        print_error "无法自动修复密钥权限" "E010"
        echo ""
        echo "你的密钥文件：$key_file"
        echo "当前权限：$current_perms"
        echo "正确权限：600"
        echo ""
        echo "请手动修复："
        echo "• 运行：chmod 600 $key_file"
        echo ""
        log ERROR "check" "无法修复密钥权限: $key_file"
        return 1
    fi
}

# --------------------
# 远程公钥认证检测与启用（E9-S01, E9-S02）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_pubkey_auth
# 功能：检测远程服务器是否启用了 SSH 公钥认证
# 参数：
#   $1 - server  服务器地址（格式：user@ip）
#   $2 - port    SSH端口（默认22）
# 返回：
#   0 - 远程服务器已启用公钥认证
#   1 - 远程服务器未启用公钥认证
#   2 - 无法检测（网络问题等）
# 说明：
#   通过 SSH 调试信息判断服务器支持的认证方式
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_pubkey_auth() {
    local server="$1"
    local port="${2:-22}"

    # 解析服务器地址
    local server_user="${server%@*}"
    local server_host="${server#*@}"

    log INFO "check" "检测远程服务器公钥认证状态：${server_user}@${server_host}:${port}"

    # 使用 SSH 调试模式获取服务器支持的认证方式
    # -o PreferredAuthentications=none 让连接在认证前就失败，返回认证方式列表
    # -o BatchMode=yes 不提示密码
    local auth_info
    auth_info=$(ssh -v -o PreferredAuthentications=none \
                     -o ConnectTimeout=5 \
                     -o StrictHostKeyChecking=accept-new \
                     -o BatchMode=yes \
                     -p "$port" \
                     "${server_user}@${server_host}" 2>&1 || true)

    # 检查是否支持 publickey 认证
    if echo "$auth_info" | grep -q "Authentications that can continue.*publickey"; then
        log INFO "check" "远程服务器已启用公钥认证"
        return 0
    fi

    # 检查是否有 keyboard-interactive 或 password（说明不支持或禁用了 publickey）
    if echo "$auth_info" | grep -q "Authentications that can continue"; then
        local auth_methods
        auth_methods=$(echo "$auth_info" | grep "Authentications that can continue" | tail -1 | sed 's/.*: //')

        if ! echo "$auth_methods" | grep -q "publickey"; then
            log WARN "check" "远程服务器未启用公钥认证，支持的认证方式：$auth_methods"
            return 1
        fi
    fi

    # 无法确定
    log WARN "check" "无法检测远程服务器公钥认证状态"
    return 2
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：enable_pubkey_auth
# 功能：启用远程服务器的 SSH 公钥认证
# 参数：
#   $1 - server  服务器地址（格式：user@ip）
#   $2 - port    SSH端口（默认22）
#   $3 - password 远程服务器密码（可选，如果提供则自动执行）
# 返回：
#   0 - 启用成功
#   1 - 启用失败或用户取消
# 说明：
#   需要 sshpass 工具和远程服务器密码
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
enable_pubkey_auth() {
    local server="$1"
    local port="${2:-22}"
    local password="${3:-}"

    # 解析服务器地址
    local server_user="${server%@*}"
    local server_host="${server#*@}"

    log INFO "check" "尝试启用远程服务器公钥认证：${server_user}@${server_host}:${port}"

    # 检查是否有密码
    if [ -z "$password" ]; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  🔧 需要远程服务器密码"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "要启用公钥认证，需要先用密码登录远程服务器。"
        echo ""
        echo "请选择操作方式："
        echo ""
        echo "  1️⃣  手动执行（推荐）"
        echo "     我会给你详细的操作步骤，你复制粘贴到远程服务器执行"
        echo ""
        echo "  2️⃣  自动执行"
        echo "     你输入远程服务器密码，我自动帮你配置"
        echo "     （需要安装 sshpass 工具）"
        echo ""
        echo "  3️⃣  跳过"
        echo "     暂不处理，稍后再说"
        echo ""

        local choice
        read -r -p "请选择 [1/2/3]: " choice

        case "$choice" in
            1)
                _show_manual_pubkey_instructions "$server" "$port"
                return 2  # 用户手动处理
                ;;
            2)
                # 检查 sshpass
                if ! command -v sshpass &>/dev/null; then
                    echo ""
                    print_warning "需要先安装 sshpass 工具"
                    echo ""
                    echo "安装命令："
                    if command -v apt-get &>/dev/null; then
                        echo "  sudo apt-get install -y sshpass"
                    elif command -v yum &>/dev/null; then
                        echo "  sudo yum install -y sshpass"
                    fi
                    echo ""
                    read -r -p "是否现在安装？[y/N]: " install_choice
                    if [ "$install_choice" = "y" ] || [ "$install_choice" = "Y" ]; then
                        if command -v apt-get &>/dev/null; then
                            apt-get install -y sshpass
                        elif command -v yum &>/dev/null; then
                            yum install -y sshpass
                        fi
                    else
                        _show_manual_pubkey_instructions "$server" "$port"
                        return 2
                    fi
                fi

                # 提示输入密码
                echo ""
                read -r -s -p "请输入远程服务器密码: " password
                echo ""
                ;;
            3|*)
                print_info "已跳过，你可以稍后手动配置"
                return 2
                ;;
        esac
    fi

    # 检查 sshpass
    if ! command -v sshpass &>/dev/null; then
        print_error "缺少 sshpass 工具" "E009"
        _show_manual_pubkey_instructions "$server" "$port"
        return 1
    fi

    # 执行远程命令启用公钥认证
    print_info "正在配置远程服务器..."

    local remote_commands='
# 检测 sshd 配置文件位置
SSHD_CONFIG=""
for cfg in /etc/ssh/sshd_config /etc/sshd_config; do
    [ -f "$cfg" ] && SSHD_CONFIG="$cfg" && break
done

if [ -z "$SSHD_CONFIG" ]; then
    echo "ERROR: 找不到 sshd_config"
    exit 1
fi

# 确保 .ssh 目录存在
mkdir -p ~/.ssh
chmod 700 ~/.ssh

# 启用 PubkeyAuthentication
if grep -q "^#*PubkeyAuthentication" "$SSHD_CONFIG"; then
    sed -i "s/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/" "$SSHD_CONFIG"
else
    echo "PubkeyAuthentication yes" >> "$SSHD_CONFIG"
fi

# 确保 AuthorizedKeysFile 配置正确
if ! grep -q "^AuthorizedKeysFile" "$SSHD_CONFIG"; then
    echo "AuthorizedKeysFile .ssh/authorized_keys" >> "$SSHD_CONFIG"
fi

# 重启 sshd
if command -v systemctl &>/dev/null; then
    systemctl restart sshd
elif command -v service &>/dev/null; then
    service sshd restart || service ssh restart
else
    /etc/init.d/sshd restart || /etc/init.d/ssh restart
fi

echo "SUCCESS: 公钥认证已启用"
'

    local result
    result=$(sshpass -p "$password" ssh -o StrictHostKeyChecking=accept-new \
             -o ConnectTimeout=10 \
             -p "$port" \
             "${server_user}@${server_host}" \
             "bash -c '$remote_commands'" 2>&1)

    if echo "$result" | grep -q "SUCCESS"; then
        print_success "远程服务器公钥认证已启用！"
        log INFO "check" "远程服务器公钥认证启用成功"

        # 提示用户上传公钥
        echo ""
        echo "接下来需要把你的公钥上传到远程服务器："
        echo ""
        echo "  ssh-copy-id -p ${port} ${server_user}@${server_host}"
        echo ""
        return 0
    else
        print_error "启用失败" "E014"
        echo ""
        echo "错误信息：$result"
        echo ""
        _show_manual_pubkey_instructions "$server" "$port"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_show_manual_pubkey_instructions
# 功能：显示手动启用公钥认证的步骤（内部函数）
# 参数：
#   $1 - server  服务器地址
#   $2 - port    SSH端口
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_show_manual_pubkey_instructions() {
    local server="$1"
    local port="${2:-22}"
    local server_user="${server%@*}"
    local server_host="${server#*@}"

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  📋 手动启用公钥认证步骤"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "第1步：登录远程服务器"
    echo "────────────────────────────────────────────────────"
    echo "  ssh -p ${port} ${server_user}@${server_host}"
    echo "  （输入密码登录）"
    echo ""
    echo "第2步：在远程服务器上执行以下命令"
    echo "────────────────────────────────────────────────────"
    echo "  # 启用公钥认证"
    echo "  sudo sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config"
    echo ""
    echo "  # 确保配置了 authorized_keys 路径"
    echo "  grep -q '^AuthorizedKeysFile' /etc/ssh/sshd_config || \\"
    echo "    echo 'AuthorizedKeysFile .ssh/authorized_keys' | sudo tee -a /etc/ssh/sshd_config"
    echo ""
    echo "  # 重启 sshd 服务"
    echo "  sudo systemctl restart sshd"
    echo ""
    echo "第3步：退出远程服务器，上传你的公钥"
    echo "────────────────────────────────────────────────────"
    echo "  exit"
    echo "  ssh-copy-id -p ${port} ${server_user}@${server_host}"
    echo ""
    echo "第4步：测试免密登录"
    echo "────────────────────────────────────────────────────"
    echo "  ssh -p ${port} ${server_user}@${server_host} 'echo 成功！'"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
}

# --------------------
# Privoxy安装检测（E7-S02）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：check_privoxy_install
# 功能：检测 Privoxy 是否已安装，未安装时询问用户是否自动安装
# 参数：无
# 返回：
#   0 - Privoxy 已安装或安装成功
#   1 - 用户取消安装或安装失败
# 示例：
#   check_privoxy_install
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
check_privoxy_install() {
    log INFO "check" "开始检测 Privoxy 安装状态..."

    # AC-01: 检测 Privoxy 是否已安装
    if command -v privoxy &>/dev/null; then
        local privoxy_version
        privoxy_version=$(privoxy --version 2>/dev/null | head -1 || echo "未知版本")
        log INFO "check" "Privoxy 已安装：$privoxy_version"
        print_success "Privoxy 已安装"
        return 0
    fi

    log INFO "check" "Privoxy 未安装，准备询问用户..."

    # AC-02: 未安装时询问是否自动安装
    echo ""
    print_warning "检测到 Privoxy 未安装"
    echo ""
    echo "Privoxy 是一个 HTTP 代理转换工具，可以将 SOCKS5 代理转换为 HTTP 代理。"
    echo "如果你需要让浏览器或其他只支持 HTTP 代理的程序使用代理，需要安装它。"
    echo ""

    # 检测是否为交互式终端
    local confirm
    if [ -t 0 ]; then
        # 交互模式，询问用户
        echo -n "是否自动安装 Privoxy？[y/n]: "
        read -r confirm
    else
        # 非交互模式，默认安装
        confirm="y"
        log INFO "check" "非交互模式，自动确认安装"
    fi

    # 处理用户选择
    case "$confirm" in
        y|Y|yes|YES)
            # AC-03: 用户选 y 则自动安装
            log INFO "check" "用户选择自动安装 Privoxy"
            echo ""
            print_info "正在安装 Privoxy..."

            # 检测操作系统并选择包管理器
            local install_cmd
            if [ -f /etc/debian_version ]; then
                # Debian/Ubuntu
                install_cmd="apt-get update && apt-get install -y privoxy"
                log DEBUG "check" "检测到 Debian/Ubuntu 系统，使用 apt-get"
            elif [ -f /etc/redhat-release ]; then
                # CentOS/RHEL
                install_cmd="yum install -y privoxy"
                log DEBUG "check" "检测到 CentOS/RHEL 系统，使用 yum"
            else
                # 未知系统，尝试检测可用的包管理器
                if command -v apt-get &>/dev/null; then
                    install_cmd="apt-get update && apt-get install -y privoxy"
                elif command -v yum &>/dev/null; then
                    install_cmd="yum install -y privoxy"
                elif command -v dnf &>/dev/null; then
                    install_cmd="dnf install -y privoxy"
                else
                    # AC-05: 安装失败时提示原因
                    print_error "无法确定系统包管理器" "E007"
                    echo ""
                    echo "请手动安装 Privoxy："
                    echo "• Ubuntu/Debian: sudo apt-get install privoxy"
                    echo "• CentOS/RHEL: sudo yum install privoxy"
                    echo "• Fedora: sudo dnf install privoxy"
                    echo ""
                    log ERROR "check" "无法确定系统包管理器"
                    return 1
                fi
            fi

            # 执行安装
            log INFO "check" "执行安装命令: $install_cmd"
            if eval "$install_cmd" 2>&1; then
                # 验证安装是否成功
                if command -v privoxy &>/dev/null; then
                    print_success "Privoxy 安装成功"
                    log INFO "check" "Privoxy 安装成功"
                    return 0
                else
                    # AC-05: 安装失败时提示原因
                    print_error "Privoxy 安装后无法找到命令" "E007"
                    echo ""
                    echo "可能是 PATH 环境变量问题，请尝试："
                    echo "• 重新打开终端"
                    echo "• 运行：hash -r"
                    echo "• 检查：which privoxy"
                    echo ""
                    log ERROR "check" "Privoxy 安装后无法找到命令"
                    return 1
                fi
            else
                # AC-05: 安装失败时提示原因
                print_error "Privoxy 安装失败" "E007"
                echo ""
                echo "可能原因："
                echo "1. 网络连接问题"
                echo "2. 软件源不可用"
                echo "3. 磁盘空间不足"
                echo ""
                echo "请尝试手动安装："
                echo "• Ubuntu/Debian: sudo apt-get update && sudo apt-get install privoxy"
                echo "• CentOS/RHEL: sudo yum install privoxy"
                echo ""
                log ERROR "check" "Privoxy 安装命令执行失败"
                return 1
            fi
            ;;
        n|N|no|NO)
            # AC-04: 用户选 n 则提示手动安装命令
            log INFO "check" "用户选择不自动安装"
            echo ""
            print_info "你可以稍后手动安装 Privoxy："
            echo ""
            echo "安装命令："
            if [ -f /etc/debian_version ]; then
                echo "• Ubuntu/Debian: sudo apt-get install privoxy"
            elif [ -f /etc/redhat-release ]; then
                echo "• CentOS/RHEL: sudo yum install privoxy"
            else
                echo "• Ubuntu/Debian: sudo apt-get install privoxy"
                echo "• CentOS/RHEL: sudo yum install privoxy"
                echo "• Fedora: sudo dnf install privoxy"
            fi
            echo ""
            echo "安装后重新运行此命令即可。"
            echo ""
            return 1
            ;;
        *)
            # 无效输入
            print_warning "无效输入，已取消安装"
            echo ""
            echo "如需安装，请重新运行命令并输入 y 或 n。"
            echo ""
            log WARN "check" "用户输入无效，取消安装"
            return 1
            ;;
    esac
}

# --------------------
# HTTP代理转换配置（E7-S03）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：configure_http_proxy
# 功能：配置 Privoxy 将 SOCKS5 代理转换为 HTTP 代理
# 参数：无
# 返回：
#   0 - 配置成功
#   1 - 配置失败
# 验收标准：
#   AC-01: 生成 Privoxy 配置文件 /etc/privoxy/autosocks.conf
#   AC-02: HTTP 代理端口 8080 (listen-address 127.0.0.1:8080)
#   AC-03: 指向 SOCKS5 代理 (forward-socks5t)
#   AC-04: 重启 Privoxy 服务
#   AC-05: 测试 HTTP 代理
#   AC-06: 输出代理地址
# 前置条件：
#   - 需要 root 权限（由调用者确保）
#   - Privoxy 已安装（调用 check_privoxy_install）
#   - SOCKS5 代理正在运行
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
configure_http_proxy() {
    log INFO "http-proxy" "开始配置 HTTP 代理转换..."

    # AC-01: 检查 Privoxy 是否已安装
    if ! command -v privoxy &>/dev/null; then
        print_error "Privoxy 未安装，请先运行 autosocks 并选择安装 Privoxy" "E007"
        log ERROR "http-proxy" "Privoxy 未安装"
        return 1
    fi

    # 检查 SOCKS5 代理是否正在运行
    if ! ss -tln 2>/dev/null | grep -q ":${LOCAL_PORT} "; then
        if ! netstat -tln 2>/dev/null | grep -q ":${LOCAL_PORT} "; then
            print_warning "SOCKS5 代理 (端口 ${LOCAL_PORT}) 似乎未运行"
            echo "  请先启动代理：autosocks start"
            echo ""
            log WARN "http-proxy" "SOCKS5 代理未运行，端口 ${LOCAL_PORT}"
            # 不直接返回错误，允许用户配置但不测试
        fi
    fi

    # AC-01: 生成 Privoxy 配置文件
    log INFO "http-proxy" "生成 Privoxy 配置文件: $PRIVOXY_CONF_FILE"

    # 确保配置目录存在
    local privoxy_dir
    privoxy_dir=$(dirname "$PRIVOXY_CONF_FILE")
    if [ ! -d "$privoxy_dir" ]; then
        mkdir -p "$privoxy_dir" 2>/dev/null || {
            print_error "无法创建配置目录: $privoxy_dir" "E006"
            log ERROR "http-proxy" "无法创建配置目录"
            return 1
        }
    fi

    # AC-02, AC-03: 生成配置内容
    # 根据 LOCAL_BIND 决定 HTTP 代理监听地址
    local http_listen="${LOCAL_BIND:-127.0.0.1}"
    if [ "$http_listen" = "0.0.0.0" ]; then
        # 局域网模式：监听所有接口
        http_listen="0.0.0.0"
    fi

    # 检测端口是否被占用（排除 privoxy 自己）
    if _is_port_in_use "${HTTP_PROXY_PORT}"; then
        if ! ss -tlnp 2>/dev/null | grep ":${HTTP_PROXY_PORT} " | grep -q privoxy; then
            print_warning "端口 ${HTTP_PROXY_PORT} 已被其他程序占用"
            local available_port
            available_port=$(_find_available_port "${HTTP_PROXY_PORT}")
            if [ "$available_port" != "-1" ]; then
                print_info "自动切换到可用端口: ${available_port}"
                HTTP_PROXY_PORT="$available_port"
            else
                print_error "无法找到可用端口，请手动指定端口"
                echo "  使用方法：autosocks config --http-port 端口号"
                return 1
            fi
        fi
    fi

    # 直接修改 Privoxy 主配置文件
    local privoxy_main_config="/etc/privoxy/config"

    # 备份原配置
    if [ -f "$privoxy_main_config" ] && [ ! -f "${privoxy_main_config}.autosocks.bak" ]; then
        cp "$privoxy_main_config" "${privoxy_main_config}.autosocks.bak" 2>/dev/null || true
    fi

    # 重写主配置文件
    cat > "$privoxy_main_config" << EOF
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AutoSOCKS HTTP 代理配置
# 由 AutoSOCKS 自动生成，请勿手动修改
# 生成时间: $(date '+%Y-%m-%d %H:%M:%S')
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# HTTP 代理监听地址
listen-address ${http_listen}:${HTTP_PROXY_PORT}

# 转发到 SOCKS5 代理
forward-socks5t / 127.0.0.1:${LOCAL_PORT} .

# 基本配置
enable-remote-toggle 0
enable-remote-http-toggle 0
enable-edit-actions 0
enforce-blocks 0
buffer-limit 4096

# 规则文件
actionsfile /etc/privoxy/default.action
filterfile /etc/privoxy/default.filter

# 超时设置
timeout 300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EOF

    # 同时生成标记文件（用于状态检测）
    if ! cat > "$PRIVOXY_CONF_FILE" << EOF
# AutoSOCKS HTTP 代理标记文件
# 表示 HTTP 代理已启用
# 监听地址：${http_listen}:${HTTP_PROXY_PORT}
# 生成时间：$(date '+%Y-%m-%d %H:%M:%S')
EOF
    then
        print_error "配置文件写入失败" "E006"
        log ERROR "http-proxy" "配置文件写入失败"
        return 1
    fi

    # 设置正确的文件权限
    chmod 644 "$PRIVOXY_CONF_FILE" 2>/dev/null || true
    print_success "配置文件已生成: $PRIVOXY_CONF_FILE"
    log INFO "http-proxy" "配置文件生成成功"

    # AC-04: 重启 Privoxy 服务
    log INFO "http-proxy" "正在重启 Privoxy 服务..."

    # 先停止再启动，确保干净重启
    systemctl stop privoxy 2>/dev/null || true
    sleep 1

    # 杀死可能残留的 privoxy 进程
    pkill -x privoxy 2>/dev/null || true
    sleep 1

    if systemctl start privoxy 2>/dev/null; then
        print_success "Privoxy 服务已重启"
        log INFO "http-proxy" "Privoxy 服务重启成功"

        # 等待服务完全启动
        sleep 1
    else
        print_warning "Privoxy 服务重启失败，尝试直接启动..."
        # 尝试直接启动（某些系统可能没有 systemd）
        if privoxy --user privoxy /etc/privoxy/config 2>/dev/null; then
            print_success "Privoxy 已启动"
            log INFO "http-proxy" "Privoxy 直接启动成功"
        else
            print_warning "Privoxy 启动可能需要手动干预"
            log WARN "http-proxy" "Privoxy 启动失败"
        fi
    fi

    # AC-05: 测试 HTTP 代理
    local socks_running=false
    if ss -tln 2>/dev/null | grep -q ":${LOCAL_PORT} " || \
       netstat -tln 2>/dev/null | grep -q ":${LOCAL_PORT} "; then
        socks_running=true
    fi

    if [ "$socks_running" = true ]; then
        print_info "正在测试 HTTP 代理..."
        log INFO "http-proxy" "开始 HTTP 代理测试"

        # 使用 curl 测试 HTTP 代理
        local test_result
        local test_start_time
        local test_end_time
        local latency_ms

        test_start_time=$(date +%s%3N 2>/dev/null || date +%s)
        test_result=$(curl -x "http://127.0.0.1:${HTTP_PROXY_PORT}" \
            -s -o /dev/null -w "%{http_code}" \
            --connect-timeout 5 \
            "http://www.gstatic.com/generate_204" 2>/dev/null)
        test_end_time=$(date +%s%3N 2>/dev/null || date +%s)

        # 计算延迟
        if date +%s%3N &>/dev/null; then
            latency_ms=$((test_end_time - test_start_time))
        else
            latency_ms=$((test_end_time - test_start_time))
            latency_ms=$((latency_ms * 1000))
        fi

        if [ "$test_result" = "204" ] || [ "$test_result" = "200" ]; then
            print_success "HTTP 代理测试通过 (延迟: ${latency_ms}ms)"
            log INFO "http-proxy" "HTTP 代理测试通过，延迟 ${latency_ms}ms"
        else
            print_warning "HTTP 代理测试未通过 (HTTP $test_result)"
            echo "  这可能是正常的，取决于你的代理服务器和网络环境"
            log WARN "http-proxy" "HTTP 代理测试返回 HTTP $test_result"
        fi
    else
        print_info "SOCKS5 代理未运行，跳过 HTTP 代理测试"
        echo "  启动代理后可手动测试："
        echo "  curl -x http://127.0.0.1:${HTTP_PROXY_PORT} http://www.gstatic.com/generate_204"
        log INFO "http-proxy" "跳过 HTTP 代理测试（SOCKS5 未运行）"
    fi

    # AC-06: 输出代理地址
    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  HTTP 代理配置完成${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  HTTP 代理地址：${BLUE}127.0.0.1:${HTTP_PROXY_PORT}${NC}"
    echo ""
    echo "  使用方法："
    echo "  • 浏览器设置：代理服务器 127.0.0.1 端口 ${HTTP_PROXY_PORT}"
    echo "  • 命令行使用：export http_proxy=http://127.0.0.1:${HTTP_PROXY_PORT}"
    echo "  • curl 测试：  curl -x http://127.0.0.1:${HTTP_PROXY_PORT} http://example.com"
    echo ""
    log INFO "http-proxy" "HTTP 代理配置完成，地址 127.0.0.1:${HTTP_PROXY_PORT}"

    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：cleanup_http_proxy_config
# 功能：清理 HTTP 代理配置（卸载时调用）
# 参数：无
# 返回：
#   0 - 清理成功（包括配置文件不存在的情况）
#   1 - 清理失败
# 说明：
#   - 删除 /etc/privoxy/autosocks.conf
#   - 不停止 Privoxy 服务（可能被其他程序使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cleanup_http_proxy_config() {
    log INFO "http-proxy" "开始清理 HTTP 代理配置..."

    local privoxy_main_config="/etc/privoxy/config"

    # 恢复原始配置
    if [ -f "${privoxy_main_config}.autosocks.bak" ]; then
        mv "${privoxy_main_config}.autosocks.bak" "$privoxy_main_config"
        print_success "已恢复 Privoxy 原始配置"
        log INFO "http-proxy" "Privoxy 配置已恢复"

        # 重启 Privoxy 使配置生效
        systemctl restart privoxy 2>/dev/null || true
    fi

    # 删除标记文件
    if [ -f "$PRIVOXY_CONF_FILE" ]; then
        rm -f "$PRIVOXY_CONF_FILE"
        log INFO "http-proxy" "标记文件已删除"
    fi

    return 0
}

# ==================== 区域5：服务管理 ====================
# 本区域由 E4 系列故事实现

# --------------------
# 服务配置生成（E4-S01）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_create_config
# 功能：生成 systemd 服务配置文件
# 参数：无
# 返回：
#   0 - 配置文件生成成功
#   1 - 配置文件生成失败
# 说明：
#   - 生成 /etc/systemd/system/autosocks.service 文件
#   - 配置开机自启依赖（After/Wants network-online.target）
#   - 配置断线重连（Restart=always, RestartSec=3）
#   - 执行 systemctl daemon-reload 使配置生效
# 前置条件：
#   - 需要 root 权限（由调用者确保）
#   - SERVICE_FILE 常量已定义
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_create_config() {
    local service_file="$SERVICE_FILE"

    log INFO "service" "开始生成 systemd 服务配置文件..."

    # 生成服务配置文件
    cat > "$service_file" << 'EOF'
[Unit]
Description=AutoSOCKS Proxy Service
Documentation=https://github.com/pwl1987/AutoSOCKS
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=-/etc/autosocks/.env
ExecStart=/usr/local/bin/autosocks --daemon
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

    # 检查文件是否创建成功
    if [ ! -f "$service_file" ]; then
        log ERROR "service" "服务配置文件创建失败: $service_file"
        return 1
    fi

    # 设置文件权限为 644
    chmod 644 "$service_file" || {
        log ERROR "service" "无法设置服务配置文件权限: $service_file"
        return 1
    }

    log INFO "service" "服务配置文件已生成: $service_file (权限: 644)"

    # 重新加载 systemd 配置
    if ! systemctl daemon-reload 2>/dev/null; then
        log ERROR "service" "systemctl daemon-reload 执行失败"
        return 1
    fi

    log INFO "service" "systemd 配置已重新加载"
    return 0
}

# --------------------
# 服务注册和注销（E4-S02）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_enable
# 功能：启用服务（开机自启）
# 参数：无
# 返回：
#   0 - 启用成功
#   1 - 启用失败
# 说明：
#   - 执行 systemctl enable autosocks
#   - 设置服务为开机自启
# 前置条件：
#   - 需要 root 权限（由调用者确保）
#   - 服务配置文件已存在（由 service_create_config 创建）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_enable() {
    log INFO "service" "开始启用服务（开机自启）..."

    if systemctl enable autosocks 2>&1; then
        log INFO "service" "服务已启用（开机自启）"
        return 0
    else
        print_error "启用服务失败" "E005"
        log ERROR "service" "systemctl enable 执行失败"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_disable
# 功能：禁用服务（取消开机自启）
# 参数：无
# 返回：
#   0 - 禁用成功
#   1 - 禁用失败
# 说明：
#   - 执行 systemctl disable autosocks
#   - 取消服务的开机自启设置
# 前置条件：
#   - 需要 root 权限（由调用者确保）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_disable() {
    log INFO "service" "开始禁用服务..."

    if systemctl disable autosocks 2>&1; then
        log INFO "service" "服务已禁用"
        return 0
    else
        print_error "禁用服务失败" "E005"
        log ERROR "service" "systemctl disable 执行失败"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_remove
# 功能：停止并删除服务配置
# 参数：无
# 返回：
#   0 - 删除成功（即使服务不存在也返回成功）
# 说明：
#   - 停止服务（如果正在运行）
#   - 禁用服务（如果已启用）
#   - 删除服务配置文件
#   - 重新加载 systemd 配置
# 前置条件：
#   - 需要 root 权限（由调用者确保）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_remove() {
    log INFO "service" "开始删除服务配置..."

    # 停止服务（忽略失败，可能未运行）
    systemctl stop autosocks 2>/dev/null || true
    log DEBUG "service" "已停止服务（如果存在）"

    # 禁用服务（忽略失败，可能未启用）
    systemctl disable autosocks 2>/dev/null || true
    log DEBUG "service" "已禁用服务（如果存在）"

    # 删除服务文件
    if [ -f "$SERVICE_FILE" ]; then
        rm -f "$SERVICE_FILE" || {
            print_error "删除服务配置文件失败" "E005"
            log ERROR "service" "无法删除服务文件: $SERVICE_FILE"
            return 1
        }
        log INFO "service" "已删除服务配置文件: $SERVICE_FILE"
    else
        log DEBUG "service" "服务配置文件不存在，跳过删除"
    fi

    # 重新加载 systemd 配置
    systemctl daemon-reload 2>/dev/null || true
    log DEBUG "service" "已重新加载 systemd 配置"

    log INFO "service" "服务配置已删除"
    return 0
}

# --------------------
# 服务启停控制（E4-S03）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_wait_service_state
# 功能：等待服务状态变化
# 参数：
#   $1 - expected_state 期望状态 (active/inactive)
#   $2 - max_wait       最大等待秒数（默认10）
# 返回：
#   0 - 状态已变化为期望值
#   1 - 等待超时
# 说明：内部函数，供 service_start/stop/restart 调用
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_wait_service_state() {
    local expected_state="$1"
    local max_wait="${2:-10}"
    local wait_count=0

    log DEBUG "service" "等待服务状态变为: $expected_state (最多 ${max_wait} 秒)"

    while [ "$wait_count" -lt "$max_wait" ]; do
        local current_state
        current_state=$(systemctl is-active autosocks 2>/dev/null)

        if [ "$current_state" = "$expected_state" ]; then
            log DEBUG "service" "服务状态已变为: $expected_state (耗时 ${wait_count} 秒)"
            return 0
        fi

        sleep 1
        wait_count=$((wait_count + 1))
    done

    log WARN "service" "等待服务状态超时 (期望: $expected_state, 当前: $current_state)"
    return 1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_start
# 功能：启动 systemd 服务
# 参数：无
# 返回：
#   0 - 启动成功
#   1 - 启动失败
# 说明：
#   - 调用 systemctl start autosocks
#   - 等待服务状态变化（最多10秒）
#   - 操作失败时输出错误信息和可能原因
# 前置条件：
#   - 需要 root 权限（由调用者确保）
#   - 服务配置文件已存在
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_start() {
    log INFO "service" "开始启动服务..."

    # 检查服务配置文件是否存在
    if [ ! -f "$SERVICE_FILE" ]; then
        print_error "服务未安装" "E005"
        echo ""
        echo "试试这个："
        echo "• 先安装：autosocks install"
        echo ""
        log ERROR "service" "服务配置文件不存在: $SERVICE_FILE"
        return 1
    fi

    # 执行启动命令
    if ! systemctl start autosocks 2>&1; then
        print_error "启动服务失败" "E005"
        echo ""
        echo "可能原因："
        echo "1. 服务配置文件损坏"
        echo "2. systemd 未正常运行"
        echo "3. 权限不足"
        echo ""
        echo "试试这个："
        echo "• 检查配置：cat $SERVICE_FILE"
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "systemctl start 执行失败"
        return 1
    fi

    # 等待服务状态变为 active
    if ! _wait_service_state "active" 10; then
        print_error "服务启动超时" "E005"
        echo ""
        echo "可能原因："
        echo "1. SSH 连接失败"
        echo "2. 服务器不可达"
        echo "3. 认证失败"
        echo ""
        echo "试试这个："
        echo "• 查看日志：autosocks logs"
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "服务启动超时"
        return 1
    fi

    log INFO "service" "服务启动成功"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_stop
# 功能：停止 systemd 服务
# 参数：无
# 返回：
#   0 - 停止成功
#   1 - 停止失败
# 说明：
#   - 调用 systemctl stop autosocks
#   - 等待服务状态变化（最多10秒）
#   - 操作失败时输出错误信息和可能原因
# 前置条件：
#   - 需要 root 权限（由调用者确保）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_stop() {
    log INFO "service" "开始停止服务..."

    # 检查服务配置文件是否存在
    if [ ! -f "$SERVICE_FILE" ]; then
        print_error "服务未安装" "E005"
        echo ""
        echo "试试这个："
        echo "• 先安装：autosocks install"
        echo ""
        log ERROR "service" "服务配置文件不存在: $SERVICE_FILE"
        return 1
    fi

    # 执行停止命令
    if ! systemctl stop autosocks 2>&1; then
        print_error "停止服务失败" "E005"
        echo ""
        echo "可能原因："
        echo "1. 服务配置文件损坏"
        echo "2. systemd 未正常运行"
        echo "3. 权限不足"
        echo ""
        echo "试试这个："
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "systemctl stop 执行失败"
        return 1
    fi

    # 等待服务状态变为 inactive
    if ! _wait_service_state "inactive" 10; then
        print_error "服务停止超时" "E005"
        echo ""
        echo "可能原因："
        echo "1. 服务进程无响应"
        echo "2. systemd 异常"
        echo ""
        echo "试试这个："
        echo "• 强制停止：systemctl kill autosocks"
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "服务停止超时"
        return 1
    fi

    log INFO "service" "服务停止成功"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_restart
# 功能：重启 systemd 服务
# 参数：无
# 返回：
#   0 - 重启成功
#   1 - 重启失败
# 说明：
#   - 调用 systemctl restart autosocks
#   - 等待服务状态变化（最多10秒）
#   - 操作失败时输出错误信息和可能原因
# 前置条件：
#   - 需要 root 权限（由调用者确保）
#   - 服务配置文件已存在
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_restart() {
    log INFO "service" "开始重启服务..."

    # 检查服务配置文件是否存在
    if [ ! -f "$SERVICE_FILE" ]; then
        print_error "服务未安装" "E005"
        echo ""
        echo "试试这个："
        echo "• 先安装：autosocks install"
        echo ""
        log ERROR "service" "服务配置文件不存在: $SERVICE_FILE"
        return 1
    fi

    # 执行重启命令
    if ! systemctl restart autosocks 2>&1; then
        print_error "重启服务失败" "E005"
        echo ""
        echo "可能原因："
        echo "1. 服务配置文件损坏"
        echo "2. systemd 未正常运行"
        echo "3. 权限不足"
        echo ""
        echo "试试这个："
        echo "• 检查配置：cat $SERVICE_FILE"
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "systemctl restart 执行失败"
        return 1
    fi

    # 等待服务状态变为 active
    if ! _wait_service_state "active" 10; then
        print_error "服务重启超时" "E005"
        echo ""
        echo "可能原因："
        echo "1. SSH 连接失败"
        echo "2. 服务器不可达"
        echo "3. 认证失败"
        echo ""
        echo "试试这个："
        echo "• 查看日志：autosocks logs"
        echo "• 检查状态：systemctl status autosocks"
        echo ""
        log ERROR "service" "服务重启超时"
        return 1
    fi

    log INFO "service" "服务重启成功"
    return 0
}

# --------------------
# 服务状态查询（E4-S04）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_is_active
# 功能：检查服务是否运行
# 参数：无
# 返回：
#   0 - 服务正在运行
#   1 - 服务未运行
# 说明：
#   - 使用 systemctl is-active --quiet 判断服务状态
#   - 静默模式，不输出任何信息
# 示例：
#   if service_is_active; then
#       echo "服务正在运行"
#   fi
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_is_active() {
    systemctl is-active --quiet autosocks 2>/dev/null
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_status
# 功能：获取服务运行状态
# 参数：无
# 返回：状态字符串到标准输出
#   active   - 服务正在运行
#   inactive - 服务已停止
#   failed   - 服务失败
#   unknown  - 无法获取状态
# 说明：
#   - 使用 systemctl is-active 获取状态
#   - 适合需要显示状态文本的场景
# 示例：
#   status=$(service_status)
#   echo "服务状态：$status"
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_status() {
    local status
    status=$(systemctl is-active autosocks 2>/dev/null)
    echo "${status:-unknown}"
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_test_proxy
# 功能：测试 SOCKS5 代理是否可用
# 参数：无
# 返回：
#   0 - 代理可用（同时输出代理IP到stdout）
#   1 - 代理不可用
# 说明：
#   - 使用 curl 通过 SOCKS5 代理访问 ip.sb 获取出口IP
#   - 超时时间5秒
#   - 返回的IP地址可用于验证代理是否生效
# 示例：
#   if proxy_ip=$(service_test_proxy); then
#       echo "代理出口IP：$proxy_ip"
#   fi
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_test_proxy() {
    local proxy_ip
    local port="${LOCAL_PORT:-1080}"

    log DEBUG "service" "测试代理连通性：127.0.0.1:${port}"

    proxy_ip=$(curl --socks5 "127.0.0.1:${port}" \
                    http://ip.sb \
                    -m 5 \
                    -s \
                    2>/dev/null | tr -d '\n\r')

    if [ -n "$proxy_ip" ]; then
        echo "$proxy_ip"
        log DEBUG "service" "代理连通性测试成功，出口IP：$proxy_ip"
        return 0
    fi

    log DEBUG "service" "代理连通性测试失败"
    return 1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_uptime
# 功能：获取服务运行时长（秒）
# 参数：无
# 返回：运行秒数到标准输出
#   0      - 服务未运行或无法获取时间
#   >0     - 服务已运行的秒数
# 说明：
#   - 从 systemd 获取 ActiveEnterTimestamp 属性
#   - 计算当前时间与启动时间的差值
# 示例：
#   uptime=$(service_uptime)
#   echo "已运行 ${uptime} 秒"
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_uptime() {
    # 检查服务是否运行
    if ! service_is_active; then
        echo "0"
        return
    fi

    # 获取服务启动时间戳
    local start_time
    start_time=$(systemctl show autosocks \
                    --property=ActiveEnterTimestamp \
                    --value 2>/dev/null)

    # 如果无法获取启动时间，返回0
    if [ -z "$start_time" ]; then
        log DEBUG "service" "无法获取服务启动时间"
        echo "0"
        return
    fi

    # 将启动时间转换为时间戳（秒）
    local start_sec
    # 处理不同系统的时间格式
    # systemd 返回格式如: "Sun 2026-02-15 10:30:15 CST" 或 "2026-02-15 10:30:15 CST"
    start_sec=$(date -d "$start_time" +%s 2>/dev/null || echo "0")

    if [ "$start_sec" = "0" ]; then
        log DEBUG "service" "无法解析启动时间：$start_time"
        echo "0"
        return
    fi

    # 计算运行时长
    local now_sec
    now_sec=$(date +%s)
    echo $((now_sec - start_sec))
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_latency
# 功能：测量代理延迟（毫秒）
# 参数：无
# 返回：
#   0 - 测量成功（延迟毫秒数输出到stdout）
#   1 - 测量失败（代理不可用）
# 说明：
#   - 使用 curl 的 time_total 获取响应时间
#   - 返回毫秒精度的延迟值
# 示例：
#   if latency=$(service_latency); then
#       echo "代理延迟：${latency}ms"
#   fi
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_latency() {
    local port="${LOCAL_PORT:-1080}"
    local latency_ms

    log DEBUG "service" "测量代理延迟：127.0.0.1:${port}"

    # 使用 curl 获取响应时间（秒），转换为毫秒
    local time_sec
    time_sec=$(curl --socks5 "127.0.0.1:${port}" \
                    http://ip.sb \
                    -m 5 \
                    -s \
                    -o /dev/null \
                    -w '%{time_total}' \
                    2>/dev/null)

    # 检查是否成功
    if [ -z "$time_sec" ] || [ "$time_sec" = "0.000" ]; then
        log DEBUG "service" "代理延迟测量失败"
        return 1
    fi

    # 转换为毫秒（保留整数）
    # 使用 awk 进行浮点运算
    latency_ms=$(echo "$time_sec" | awk '{printf "%.0f", $1 * 1000}')

    echo "${latency_ms}"
    log DEBUG "service" "代理延迟：${latency_ms}ms"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：service_format_uptime
# 功能：将秒数格式化为友好显示
# 参数：$1 - 运行秒数
# 返回：友好的时间字符串到stdout
# 说明：
#   - 自动选择合适的单位（天/小时/分钟/秒）
#   - 小白友好的显示格式
# 示例：
#   echo "运行时长：$(service_format_uptime 3665)"
#   # 输出：运行时长：1小时1分钟
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
service_format_uptime() {
    local seconds="$1"

    if [ -z "$seconds" ] || [ "$seconds" = "0" ]; then
        echo "0秒"
        return
    fi

    local days=$((seconds / 86400))
    local hours=$(( (seconds % 86400) / 3600 ))
    local minutes=$(( (seconds % 3600) / 60 ))
    local secs=$((seconds % 60))

    local result=""

    if [ $days -gt 0 ]; then
        result="${days}天"
    fi

    if [ $hours -gt 0 ]; then
        result="${result}${hours}小时"
    fi

    if [ $minutes -gt 0 ]; then
        result="${result}${minutes}分钟"
    fi

    # 如果小于1分钟，显示秒数
    if [ -z "$result" ] && [ $secs -gt 0 ]; then
        result="${secs}秒"
    fi

    # 如果结果为空（可能是0秒），显示0秒
    if [ -z "$result" ]; then
        result="0秒"
    fi

    echo "$result"
}

# ==================== 区域6：核心功能 ====================
# 本区域由 E1-S06, E5, E6 系列故事实现

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 服务器地址输入（E5-S02a）
# 功能：交互式引导用户输入服务器地址，即时校验格式并测试连接
# 参数：无
# 返回：
#   0 - 成功（SERVER_HOST 和 SERVER_USER 已设置）
#   1 - 用户取消或失败
# 说明：
#   - 提示格式示例，引导用户输入
#   - 即时校验 user@ip 格式
#   - 校验 IP 地址格式和每段范围（0-255）
#   - 调用 check_server 测试连接
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
input_server_address() {
    log INFO "install" "开始引导用户输入服务器地址"

    while true; do
        echo ""
        echo "请输入服务器地址"
        echo "格式：用户名@IP地址"
        echo "示例：root@192.168.1.100"
        echo ""
        echo -n "地址："
        read -r server_addr

        # AC-02: 校验格式 - 必须包含 @
        if ! echo "$server_addr" | grep -qE '@'; then
            print_error "格式错误：地址中缺少 @" "E012"
            echo ""
            echo "正确格式：用户名@IP地址"
            echo "例如：root@192.168.1.100"
            continue
        fi

        # 提取用户名和 IP 部分
        local input_user="${server_addr%@*}"
        local input_ip="${server_addr#*@}"

        # AC-02: 校验用户名格式（字母或下划线开头，可包含数字）
        if ! echo "$input_user" | grep -qE '^[a-zA-Z_][a-zA-Z0-9_-]*$'; then
            print_error "格式错误：用户名格式不正确" "E012"
            echo ""
            echo "用户名规则："
            echo "  • 以字母或下划线开头"
            echo "  • 只能包含字母、数字、下划线、短横线"
            echo "  • 例如：root, admin, user_1"
            continue
        fi

        # AC-02: 校验 IP 地址格式（x.x.x.x）
        if ! echo "$input_ip" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
            print_error "格式错误：IP 地址格式不正确" "E012"
            echo ""
            echo "正确格式：192.168.1.100"
            continue
        fi

        # AC-02: 校验 IP 每段范围（0-255）
        local ip_valid=true
        local i=1
        local segment
        while [ $i -le 4 ]; do
            segment=$(echo "$input_ip" | cut -d'.' -f$i)
            if [ "$segment" -gt 255 ]; then
                ip_valid=false
                break
            fi
            i=$((i + 1))
        done

        if [ "$ip_valid" = false ]; then
            print_error "格式错误：IP 地址每段应在 0-255 之间" "E012"
            echo ""
            echo "你的输入：$input_ip"
            echo "问题：第 $i 段 $segment 超出范围"
            continue
        fi

        # AC-03: 测试连接
        print_info "正在测试连接 ${input_user}@${input_ip} ..."
        log INFO "install" "测试服务器连接: ${input_user}@${input_ip}"

        if check_server "${input_user}@${input_ip}" "${SERVER_PORT:-22}"; then
            # AC-05: 设置全局变量
            SERVER_HOST="$input_ip"
            SERVER_USER="$input_user"
            print_success "服务器连接成功"
            log INFO "install" "服务器地址已设置: ${SERVER_USER}@${SERVER_HOST}"
            return 0
        fi

        # AC-04: 连接失败，询问是否重试
        echo ""
        local retry
        read -r -p "是否重新输入？[y/n] " retry
        if [ "$retry" != "y" ] && [ "$retry" != "Y" ]; then
            log INFO "install" "用户取消服务器地址输入"
            return 1
        fi
    done
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：select_auth_method
# 功能：交互式引导用户选择认证方式（密钥或密码）
# 参数：无
# 返回：
#   0 - 成功选择并验证认证
#   1 - 用户取消或认证失败
# 说明：
#   E5-S02b 实现，验收标准：
#   AC-01: 提示选择认证方式（1.密钥 2.密码）
#   AC-02: 密钥模式检测默认密钥是否存在
#   AC-03: 密码模式显示安全警告
#   AC-04: 使用 read -s 读取密码（不显示）
#   AC-05: 测试认证是否成功
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
select_auth_method() {
    log INFO "install" "开始引导用户选择认证方式"

    # AC-01: 显示认证方式选择菜单
    while true; do
        echo ""
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${BLUE}  请选择认证方式${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo "  1. 密钥认证（推荐，最安全）"
        echo "     - 需要已有 SSH 密钥文件"
        echo "     - 密钥路径：$HOME/.ssh/id_rsa"
        echo ""
        echo "  2. 密码认证（有安全风险）"
        echo "     - 需要输入服务器密码"
        echo "     - 密码将被加密存储"
        echo ""
        echo -n "请选择 [1/2]："
        read -r auth_choice

        case "$auth_choice" in
            1)
                # AC-02: 密钥认证模式
                if _select_key_auth; then
                    return 0
                fi
                # 失败后继续循环，让用户重新选择
                ;;
            2)
                # AC-03, AC-04: 密码认证模式
                if _select_password_auth; then
                    return 0
                fi
                # 失败后继续循环，让用户重新选择
                ;;
            *)
                print_error "无效选择，请输入 1 或 2" "E012"
                ;;
        esac
    done
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_select_key_auth
# 功能：处理密钥认证选择（内部函数）
# 参数：无
# 返回：
#   0 - 密钥认证设置成功
#   1 - 用户取消或认证失败
# 说明：AC-02 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_select_key_auth() {
    log INFO "install" "用户选择密钥认证"

    # AC-02: 检测默认密钥是否存在
    local default_key="$HOME/.ssh/id_rsa"
    local key_file=""

    if [ -f "$default_key" ]; then
        echo ""
        print_success "检测到默认密钥文件：$default_key"
        echo ""
        echo -n "使用此密钥？[Y/n]："
        read -r use_default

        if [ "$use_default" = "n" ] || [ "$use_default" = "N" ]; then
            # 用户想使用其他密钥
            echo ""
            echo -n "请输入密钥文件路径："
            read -r key_file

            # 去除可能的引号
            key_file=$(echo "$key_file" | tr -d "\"'")

            # 展开 ~ 符号
            key_file="${key_file/#\~/$HOME}"

            # 转换为绝对路径（处理相对路径）
            if [[ "$key_file" != /* ]]; then
                key_file="$(pwd)/$key_file"
            fi

            if [ ! -f "$key_file" ]; then
                print_error "密钥文件不存在：$key_file" "E010"
                echo ""
                echo "常见密钥位置："
                echo "  • $HOME/.ssh/id_rsa"
                echo "  • $HOME/.ssh/id_ed25519"
                echo "  • $HOME/.ssh/your_key_name"
                return 1
            fi
        else
            key_file="$default_key"
        fi
    else
        # AC-02: 默认密钥不存在，提示路径
        echo ""
        print_warning "未检测到默认密钥文件"
        echo ""
        echo "默认密钥路径：$default_key"
        echo ""
        echo "选项："
        echo "  1. 输入已有密钥路径"
        echo "  2. 创建新密钥"
        echo "  3. 返回重新选择认证方式"
        echo ""
        echo -n "请选择 [1/2/3]："
        read -r key_option

        case "$key_option" in
            1)
                echo ""
                echo -n "请输入密钥文件路径："
                read -r key_file

                # 去除可能的引号
                key_file=$(echo "$key_file" | tr -d "\"'")

                # 展开 ~ 符号
                key_file="${key_file/#\~/$HOME}"

                # 转换为绝对路径（处理相对路径）
                if [[ "$key_file" != /* ]]; then
                    key_file="$(pwd)/$key_file"
                fi

                if [ ! -f "$key_file" ]; then
                    print_error "密钥文件不存在：$key_file" "E010"
                    return 1
                fi
                ;;
            2)
                # 生成新密钥
                echo ""
                print_info "将创建新的 SSH 密钥..."
                echo ""
                if ! ssh-keygen -t rsa -b 4096 -f "$default_key" -N ""; then
                    print_error "密钥生成失败" "E010"
                    return 1
                fi
                print_success "密钥已生成：$default_key"
                key_file="$default_key"
                ;;
            3)
                return 1
                ;;
            *)
                print_error "无效选择" "E012"
                return 1
                ;;
        esac
    fi

    # 检查并修复密钥权限
    if ! check_key_perm "$key_file"; then
        return 1
    fi

    # 设置认证配置
    AUTH_TYPE="key"
    AUTH_KEY_PATH="$key_file"

    # AC-05: 测试认证是否成功
    echo ""
    print_info "正在测试密钥认证..."

    # 调试：显示测试参数
    log DEBUG "install" "密钥测试参数: key_file=$key_file, SERVER_USER=$SERVER_USER, SERVER_HOST=$SERVER_HOST, SERVER_PORT=${SERVER_PORT:-22}"

    # 使用指定的密钥测试连接
    local ssh_exit_code
    ssh -o BatchMode=yes \
           -o ConnectTimeout=10 \
           -o StrictHostKeyChecking=accept-new \
           -o IdentityFile="$key_file" \
           -p "${SERVER_PORT:-22}" \
           "${SERVER_USER}@${SERVER_HOST}" \
           exit 2>/dev/null
    ssh_exit_code=$?

    log DEBUG "install" "SSH 退出码: $ssh_exit_code"

    if [ $ssh_exit_code -eq 0 ]; then
        print_success "密钥认证成功"
        log INFO "install" "密钥认证测试通过: $key_file"
        return 0
    else
        # 认证失败 - 先检测是否是远程服务器未启用公钥认证
        log INFO "install" "密钥认证失败，检测远程服务器公钥认证状态..."

        local pubkey_result
        check_pubkey_auth "${SERVER_USER}@${SERVER_HOST}" "${SERVER_PORT:-22}"
        pubkey_result=$?

        if [ $pubkey_result -eq 1 ]; then
            # E014: 远程服务器未启用公钥认证
            print_error "远程服务器未启用公钥认证" "E014"
            echo ""
            echo "服务器：${SERVER_USER}@${SERVER_HOST}:${SERVER_PORT:-22}"
            echo ""
            echo "问题：远程服务器的 SSH 没有开启公钥登录功能"
            echo ""
            read -r -p "是否尝试自动启用公钥认证？[y/N]: " enable_choice
            echo ""

            if [ "$enable_choice" = "y" ] || [ "$enable_choice" = "Y" ]; then
                enable_pubkey_auth "${SERVER_USER}@${SERVER_HOST}" "${SERVER_PORT:-22}"
                local enable_result=$?
                if [ $enable_result -eq 0 ]; then
                    # 启用成功，提示用户上传公钥后重试
                    echo ""
                    print_info "配置完成后，请重新运行安装命令："
                    echo "  autosocks install --server ${SERVER_USER}@${SERVER_HOST}"
                    echo ""
                    return 1
                fi
            else
                _show_manual_pubkey_instructions "${SERVER_USER}@${SERVER_HOST}" "${SERVER_PORT:-22}"
            fi
            log WARN "install" "远程服务器未启用公钥认证"
            return 1
        fi

        # 公钥认证已启用，但认证仍然失败 - 其他原因
        print_error "密钥认证失败" "E004"
        echo ""
        echo "可能原因："
        echo "  • 服务器上没有配置你的公钥"
        echo "  • 密钥文件不正确"
        echo ""
        echo "试试这些："
        echo "  • 上传公钥：ssh-copy-id -i ${key_file}.pub -p ${SERVER_PORT:-22} ${SERVER_USER}@${SERVER_HOST}"
        echo "  • 手动测试：ssh -i $key_file -p ${SERVER_PORT:-22} ${SERVER_USER}@${SERVER_HOST}"
        echo ""
        log WARN "install" "密钥认证测试失败"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_select_password_auth
# 功能：处理密码认证选择（内部函数）
# 参数：无
# 返回：
#   0 - 密码认证设置成功
#   1 - 用户取消
# 说明：AC-03, AC-04 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_select_password_auth() {
    log INFO "install" "用户选择密码认证"

    # SSH_PASSWORD_CONFIRM 只用于临时确认，声明为 local
    local SSH_PASSWORD_CONFIRM=""

    # AC-03: 显示安全警告
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  ⚠️  安全警告${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "密码认证存在以下安全风险："
    echo "  • 密码将被存储在系统文件中（虽然加密）"
    echo "  • 可能被有系统访问权限的人获取"
    echo "  • 不如密钥认证安全"
    echo ""
    echo -e "${GREEN}推荐做法：${NC}"
    echo "  • 使用密钥认证（选项 1）"
    echo "  • 如果必须用密码，请使用强密码"
    echo ""
    echo -n "确认使用密码认证？[y/N]："
    read -r confirm_pwd

    if [ "$confirm_pwd" != "y" ] && [ "$confirm_pwd" != "Y" ]; then
        echo ""
        print_info "已取消密码认证，请选择其他方式"
        return 1
    fi

    # AC-04: 使用 read -s 读取密码（不显示）
    echo ""
    echo -n "请输入服务器密码："
    read -rs SSH_PASSWORD
    echo ""

    # 验证密码不为空
    if [ -z "$SSH_PASSWORD" ]; then
        print_error "密码不能为空" "E012"
        return 1
    fi

    # 确认密码
    echo -n "请再次输入密码确认："
    read -rs SSH_PASSWORD_CONFIRM
    echo ""

    if [ "$SSH_PASSWORD" != "$SSH_PASSWORD_CONFIRM" ]; then
        print_error "两次输入的密码不一致" "E012"
        return 1
    fi

    # 设置认证配置
    AUTH_TYPE="password"
    AUTH_KEY_PATH=""

    # AC-05: 测试认证（密码模式下无法自动验证，显示警告）
    echo ""
    print_warning "密码模式无法自动验证认证，请确保密码正确"
    print_success "密码已设置"
    log INFO "install" "密码认证已设置"

    # 提示用户后续可以手动测试
    echo ""
    echo "💡 提示：安装完成后，可以使用以下命令测试连接："
    echo "   ssh -p ${SERVER_PORT:-22} ${SERVER_USER}@${SERVER_HOST}"
    echo ""

    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 安装前预检查（E5-S01）
# 功能：执行所有必要的预检查，确保安装环境满足要求
# 参数：无
# 返回：
#   0 - 全部检查通过
#   1 - 有检查失败
# 说明：
#   按依赖关系顺序执行检查，任一失败立即中止
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
install_precheck() {
    echo ""
    echo "正在检查系统环境..."
    echo ""

    # 记录检查开始
    log INFO "install" "开始安装预检查"

    # 1. 检查 root 权限（必须先检查，否则后续操作可能失败）
    if ! check_root; then
        log ERROR "install" "预检查失败：权限不足"
        return 1
    fi

    # 2. 检查 SSH 是否安装
    if ! check_ssh; then
        log ERROR "install" "预检查失败：SSH 未安装"
        return 1
    fi

    # 3. 检查 systemd 是否可用
    if ! check_systemd; then
        log ERROR "install" "预检查失败：systemd 不可用"
        return 1
    fi

    # 4. 检查端口是否被占用
    if ! check_port "${LOCAL_PORT:-1080}"; then
        log ERROR "install" "预检查失败：端口被占用"
        return 1
    fi

    # 5. 检查网络是否通畅
    if ! check_network; then
        log ERROR "install" "预检查失败：网络不通"
        return 1
    fi

    # 所有检查通过
    echo ""
    print_success "环境检查通过"
    echo ""

    log INFO "install" "预检查全部通过"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E8-S01: 命令行参数解析
# 功能：统一解析命令行参数，支持短选项、长选项、选项值
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 参数解析结果存储变量（全局）
PARSED_COMMAND=""
PARSED_LAN=""
PARSED_SHOW=""
PARSED_DAEMON=""
PARSED_HELP=""

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：parse_args
# 功能：解析命令行参数，支持短选项和长选项
# 参数：$@ - 命令行参数
# 返回：
#   0 - 解析成功
#   2 - 参数错误
# 副作用：
#   设置 PARSED_* 全局变量
# 说明：
#   - 支持 --option=value 和 --option value 两种格式
#   - 支持 -p 1081 短选项格式
#   - 支持 --help/-h 显示帮助
#   - 支持 --daemon 守护模式
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
parse_args() {
    # 重置所有解析变量
    PARSED_COMMAND=""
    PARSED_LAN=""
    PARSED_SHOW=""
    PARSED_DAEMON=""
    PARSED_HELP=""

    # 如果没有参数，设置默认命令为 help
    if [ $# -eq 0 ]; then
        PARSED_COMMAND="help"
        return 0
    fi

    # 全局选项：必须出现在第一个位置（在命令前）
    # --profile NAME → 切换 profile 路径
    if [ "${1:-}" = "--profile" ]; then
        local _prof="${2:-}"
        if [ -z "$_prof" ]; then
            print_error "--profile 需要参数" "E009"
            return 2
        fi
        if ! _switch_profile "$_prof"; then
            return 2
        fi
        shift 2
        # 之后继续解析命令
        if [ $# -eq 0 ]; then
            PARSED_COMMAND="help"
            return 0
        fi
    fi

    # 第一个参数可能是命令或选项
    local first_arg="$1"

    # 检查是否是选项（以 - 开头）
    case "$first_arg" in
        --daemon)
            PARSED_DAEMON="true"
            return 0
            ;;
        --help|-h)
            PARSED_COMMAND="help"
            shift
            # 检查是否有 --all 参数
            if [ "${1:-}" = "--all" ]; then
                PARSED_SHOW="all"
            fi
            return 0
            ;;
        --version|-V)
            PARSED_COMMAND="version"
            return 0
            ;;
        # 高级命令：以 -- 前缀直接映射到命令名（借鉴 ssh-proxy.sh 命令风格）
        --doctor)
            PARSED_COMMAND="doctor"; return 0 ;;
        --check-now)
            PARSED_COMMAND="check-now"; return 0 ;;
        --latency)
            PARSED_COMMAND="latency"; return 0 ;;
        --tunnels)
            PARSED_COMMAND="tunnels"; return 0 ;;
        --validate-config)
            PARSED_COMMAND="validate-config"; return 0 ;;
        --gen-completions)
            PARSED_COMMAND="gen-completions"; return 0 ;;
        --ready)
            PARSED_COMMAND="ready"; return 0 ;;
        --list-profiles)
            PARSED_COMMAND="list-profiles"; return 0 ;;
        --fingerprint-pin)
            PARSED_COMMAND="fingerprint-pin"; return 0 ;;
        --webhook-test)
            PARSED_COMMAND="webhook-test"; return 0 ;;
        --restart)
            PARSED_COMMAND="restart"; return 0 ;;
        --log)
            PARSED_COMMAND="log"; return 0 ;;
        --self-update)
            PARSED_COMMAND="self-update"; return 0 ;;
        --reconfigure)
            PARSED_COMMAND="reconfigure"; return 0 ;;
        --shell-integration)
            PARSED_COMMAND="shell-integration"; return 0 ;;
        -*)
            # 以 - 开头但不是已知选项，报错
            print_error "未知选项：$first_arg" "E012"
            echo ""
            echo "可用选项："
            echo "  --help, -h             显示帮助"
            echo "  --version, -V          显示版本"
            echo "  --daemon               守护模式（systemd 使用）"
            echo "  --doctor               一键自检"
            echo "  --check-now            立即健康检查"
            echo "  --latency [N]          延迟探测（默认 3 样本）"
            echo "  --tunnels              列出活跃代理"
            echo "  --validate-config      验证配置正确性"
            echo "  --gen-completions      输出 bash 补全脚本"
            echo "  --ready [N]            等待隧道就绪（秒）"
            echo "  --restart              重启代理"
            echo "  --list-profiles        列出所有 profile"
            echo "  --fingerprint-pin      校验远端 SSH 指纹"
            echo "  --webhook-test         测试 WEBHOOK_URL 推送"
            echo "  --log [N]              查看最近 N 行日志（默认 50）"
            echo "  --self-update          检查并更新 autosocks"
            echo "  --reconfigure          交互式重新配置向导"
            echo "  servers [list|add|rm]  管理备用服务器"
            echo "  health [start|stop]    健康检查守护进程"
            echo "  --shell-integration    安装 Shell 代理自动恢复"
            return 2
            ;;
    esac

    # 第一个参数是命令
    PARSED_COMMAND="$first_arg"
    shift

    # 解析剩余参数
    while [ $# -gt 0 ]; do
        local arg="$1"

        case "$arg" in
            # 长选项（带等号）
            --server=*)
                shift
                ;;
            --port=*)
                shift
                ;;
            --auth=*)
                shift
                ;;
            --key=*)
                shift
                ;;
            --lines=*)
                shift
                ;;

            # 长选项（开关类型）
            --lan)
                PARSED_LAN="true"
                shift
                ;;
            --force)
                shift
                ;;
            --keep-config)
                shift
                ;;
            --follow)
                shift
                ;;
            --json)
                shift
                ;;
            --show)
                PARSED_SHOW="true"
                shift
                ;;
            --all)
                PARSED_SHOW="all"
                shift
                ;;

            # 长选项（需要值的类型）
            --server)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --server 需要参数" "E009"
                    echo ""
                    echo "正确格式：--server user@1.2.3.4"
                    return 2
                fi
                shift 2
                ;;
            --port)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --port 需要参数" "E009"
                    echo ""
                    echo "正确格式：--port 1080"
                    return 2
                fi
                shift 2
                ;;
            --http-port)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --http-port 需要参数" "E009"
                    echo ""
                    echo "正确格式：--http-port 8080"
                    return 2
                fi
                shift 2
                ;;
            --auth)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --auth 需要参数" "E009"
                    echo ""
                    echo "正确格式：--auth key 或 --auth password"
                    return 2
                fi
                shift 2
                ;;
            --key)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --key 需要参数" "E009"
                    echo ""
                    echo "正确格式：--key /path/to/key"
                    return 2
                fi
                shift 2
                ;;
            --lines)
                if [ -z "${2:-}" ]; then
                    print_error "选项 --lines 需要参数" "E009"
                    echo ""
                    echo "正确格式：--lines 50"
                    return 2
                fi
                shift 2
                ;;

            # 短选项
            -p)
                if [ -z "${2:-}" ]; then
                    print_error "选项 -p 需要端口号参数" "E009"
                    echo ""
                    echo "正确格式：-p 1080"
                    return 2
                fi
                shift 2
                ;;
            -s)
                if [ -z "${2:-}" ]; then
                    print_error "选项 -s 需要服务器地址参数" "E009"
                    echo ""
                    echo "正确格式：-s user@1.2.3.4"
                    return 2
                fi
                shift 2
                ;;
            -f)
                shift
                ;;
            -h)
                PARSED_HELP="true"
                shift
                ;;

            # 帮助选项
            --help)
                PARSED_HELP="true"
                shift
                ;;

            # 未知选项
            -*)
                print_error "未知选项：$arg" "E012"
                echo ""
                echo "查看帮助：autosocks help --all"
                return 2
                ;;

            # 非选项参数（可能是值）
            *)
                # 根据命令处理额外的位置参数
                # 对于 config --lan on 这种情况，处理 on/off
                if [ "$PARSED_COMMAND" = "config" ] && [ "$PARSED_LAN" = "true" ]; then
                    case "$arg" in
                        on|off)
                            PARSED_LAN="$arg"
                            shift
                            continue
                            ;;
                    esac
                fi

                # 其他情况，跳过（让命令函数自己处理）
                shift
                ;;
        esac
    done

    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：cmd_env
# 功能：导出代理环境变量
# 参数：$1 - 可选 unset 子命令
# 返回：0
# 说明：输出 export 语句，供 eval 使用
# 用法：eval $(autosocks env)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_env() {
    local subcmd="${1:-}"

    case "$subcmd" in
        --unset|unset|off)
            # 取消环境变量
            echo "unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY no_proxy"
            echo "# ✅ 代理环境变量已清除" >&2
            return 0
            ;;
        --help|-h|help)
            echo "用法："
            echo "  eval \$(autosocks env)      # 设置代理环境变量"
            echo "  eval \$(autosocks env unset) # 清除代理环境变量"
            echo ""
            echo "或在 ~/.bashrc 中添加："
            echo "  alias proxy-on='eval \$(autosocks env)'"
            echo "  alias proxy-off='eval \$(autosocks env unset)'"
            return 0
            ;;
    esac

    # 加载配置
    config_load || return 1

    local socks_port="${LOCAL_PORT:-1080}"
    local http_port="${HTTP_PROXY_PORT:-8118}"

    # 检测 Privoxy 实际监听的端口
    local privoxy_port
    privoxy_port=$(ss -tlnp 2>/dev/null | grep privoxy | grep -oP ':\K[0-9]+' | head -1)
    if [ -n "$privoxy_port" ]; then
        http_port="$privoxy_port"
    fi

    # 检查代理是否运行
    if ! service_is_active; then
        print_warning "代理服务未运行" >&2
        echo "  请先启动：autosocks start" >&2
        return 1
    fi

    # 输出 export 语句（供 eval 使用）
    echo "export http_proxy=http://127.0.0.1:${http_port}"
    echo "export https_proxy=http://127.0.0.1:${http_port}"
    echo "export HTTP_PROXY=http://127.0.0.1:${http_port}"
    echo "export HTTPS_PROXY=http://127.0.0.1:${http_port}"
    echo "export ALL_PROXY=socks5://127.0.0.1:${socks_port}"
    echo "export NO_PROXY=localhost,127.0.0.1,::1"
    echo "export no_proxy=localhost,127.0.0.1,::1"

    # 输出提示信息到 stderr（不会影响 eval）
    echo "# ✅ 代理环境变量已设置" >&2
    echo "# SOCKS5: 127.0.0.1:${socks_port}" >&2
    echo "# HTTP:   127.0.0.1:${http_port}" >&2
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：cmd_version
# 功能：显示版本信息
# 参数：无
# 返回：0
# 说明：E8-S01 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_version() {
    echo "AutoSOCKS v${VERSION}"

    if [ -f "$VERSION_FILE" ]; then
        # 读取版本文件
        local install_date=""

        while IFS='=' read -r key value; do
            # 去除引号
            value="${value%\"}"
            value="${value#\"}"

            case "$key" in
                INSTALLED_VERSION)
                    # TODO: 可以使用此变量显示已安装版本
                    ;;
                INSTALL_DATE)
                    install_date="$value"
                    ;;
            esac
        done < "$VERSION_FILE" 2>/dev/null

        if [ -n "$install_date" ]; then
            echo "安装日期：${install_date}"
        fi
    fi

    log "INFO" "main" "用户查看版本信息"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：cmd_rollback
# 功能：回滚到旧版本
# 参数：无
# 返回：
#   0 - 成功
#   1 - 失败（无备份文件或权限问题）
# 说明：E8-S04 实现
#   - 检查是否存在备份文件 /usr/local/bin/autosocks.bak
#   - 将备份文件恢复为主程序
#   - 显示回滚后的版本号
#   - 无备份时给出友好提示
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_rollback() {
    log INFO "rollback" "用户请求回滚到旧版本"

    # AC-05: 检查备份文件是否存在
    if [ ! -f "$SCRIPT_BACKUP" ]; then
        print_error "没有可回滚的旧版本" "E013"
        echo ""
        echo "说明："
        echo "  • 未找到备份文件：$SCRIPT_BACKUP"
        echo "  • 可能是首次安装，或备份已被删除"
        echo ""
        log WARN "rollback" "回滚失败：备份文件不存在"
        return 1
    fi

    # 检查备份文件是否可读
    if [ ! -r "$SCRIPT_BACKUP" ]; then
        print_error "无法读取备份文件" "E001"
        echo ""
        echo "试试这个："
        echo "• 使用 sudo 执行：sudo autosocks rollback"
        echo ""
        log ERROR "rollback" "备份文件不可读: $SCRIPT_BACKUP"
        return 1
    fi

    # 获取旧版本号（从备份文件中提取）
    local old_version=""
    old_version=$(grep '^VERSION=' "$SCRIPT_BACKUP" 2>/dev/null | head -1 | cut -d'=' -f2 | tr -d '"')

    if [ -z "$old_version" ]; then
        old_version="未知版本"
    fi

    # 显示回滚确认信息
    print_info "即将回滚到版本：v${old_version}"
    echo ""

    # AC-03: 执行回滚（恢复备份）
    log INFO "rollback" "正在从备份恢复: $SCRIPT_BACKUP -> $SCRIPT_FILE"

    if ! cp "$SCRIPT_BACKUP" "$SCRIPT_FILE" 2>/dev/null; then
        print_error "回滚失败：无法恢复备份文件" "E001"
        echo ""
        echo "试试这个："
        echo "• 使用 sudo 执行：sudo autosocks rollback"
        echo ""
        log ERROR "rollback" "复制备份文件失败"
        return 1
    fi

    # 设置执行权限
    chmod 755 "$SCRIPT_FILE" 2>/dev/null

    # AC-04: 显示回滚成功信息
    print_success "已成功回滚到版本：v${old_version}"
    echo ""
    echo "回滚详情："
    echo "  • 当前版本：v${old_version}"
    echo "  • 备份文件：$SCRIPT_BACKUP（已保留）"
    echo ""
    echo "💡 提示："
    echo "  • 如需恢复新版本，请重新执行 autosocks install"
    echo "  • 备份文件仍保留，可再次回滚"
    echo ""

    log INFO "rollback" "回滚成功: 当前版本 v${old_version}"
    return 0
}


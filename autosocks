# --------------------
# 8.10 列出活跃代理（list_tunnels）
# --------------------

list_tunnels() {
    local json_mode="${LIST_TUNNELS_JSON:-0}"
    local pid_dir="${PID_DIR:-/var/run/autosocks}"

    if [ "$json_mode" != "1" ]; then
        printf "%-12s %-8s %-8s %-10s\n" "NAME" "PORT" "PID" "RUNTIME"
        echo "---------------------------------------------"
    else
        printf '['
    fi

    local found=0
    for pid_file in "$pid_dir"/autosocks*.pid; do
        [ -f "$pid_file" ] || continue
        [[ "$pid_file" == *checker* ]] && continue
        [[ "$pid_file" == *-http* ]] && continue
        local pid
        pid=$(_read_pid_file "$pid_file")
        [ -n "$pid" ] || continue
        is_pid_alive "$pid" || continue

        local port="${LOCAL_PORT:-1080}"
        local runtime="?"
        # 尝试读取 start_time（如果存在）
        local start_file="${pid_file%.pid}.start"
        if [ -f "$start_file" ]; then
            local start_ts
            start_ts=$(cat "$start_file" 2>/dev/null || echo "")
            if [[ "$start_ts" =~ ^[0-9]+$ ]]; then
                local now_ts
                now_ts=$(date +%s)
                local secs=$((now_ts - start_ts))
                if (( secs >= 86400 )); then
                    runtime="$((secs/86400))d"
                elif (( secs >= 3600 )); then
                    runtime="$((secs/3600))h"
                else
                    runtime="$((secs/60))m"
                fi
            fi
        fi

        if [ "$json_mode" = "1" ]; then
            [ $found -gt 0 ] && printf ","
            printf '{"name":"autosocks","port":%s,"pid":%s,"runtime":"%s"}' "$port" "$pid" "$runtime"
        else
            printf "%-12s %-8s %-8s %-10s\n" "autosocks" "$port" "$pid" "$runtime"
        fi
        ((found++))
    done

    if [ "$json_mode" = "1" ]; then
        printf ']\n'
    elif ((found == 0)); then
        echo "  (无活跃代理)"
    fi
}


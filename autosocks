        else
            _doc "SSH 密钥权限安全（建议 600）" 1
        fi
    else
        printf '%b\n' "  ${YELLOW}⚠${NC} 未配置 SSH 密钥（使用密码认证）"
    fi

    # 依赖
    command -v ssh &>/dev/null && _doc "ssh 已安装" 0 || _doc "ssh 已安装" 1
    command -v autossh &>/dev/null && _doc "autossh 已安装（推荐）" 0 || _doc "autossh 已安装（推荐）" 1
    command -v sshpass &>/dev/null && _doc "sshpass 已安装（密码认证用）" 0 || _doc "sshpass 已安装（密码认证用）" 1
    command -v curl &>/dev/null && _doc "curl 已安装" 0 || _doc "curl 已安装" 1
    command -v nc &>/dev/null && _doc "nc 已安装" 0 || _doc "nc 已安装" 1
    command -v gost &>/dev/null && _doc "gost 已安装（HTTP 代理可选）" 0 || _doc "gost 已安装（HTTP 代理可选）" 1

    # 服务
    if systemctl is-active autosocks &>/dev/null; then
        _doc "代理服务运行中" 0
        if port_is_open 127.0.0.1 "${LOCAL_PORT:-1080}"; then
            _doc "SOCKS5 端口 ${LOCAL_PORT:-1080} 开放" 0
        else
            _doc "SOCKS5 端口 ${LOCAL_PORT:-1080} 开放" 1
        fi
    else
        printf '%b\n' "  ${YELLOW}⚠${NC} 代理未启动"
    fi

    echo ""
    printf '%b\n' "结果: ${GREEN}通过 $pass${NC}, ${RED}失败 $fail${NC}"
    echo ""
    echo "诊断命令:"
    echo "  autosocks --check-now       # 立即健康检查"
    echo "  autosocks --latency 5       # 延迟探测"
    echo "  autosocks --tunnels         # 列出活跃代理"
    (( fail == 0 )) && return 0 || return 1
}


# 参数：无
# 返回：0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_status_text_failed() {
    echo ""
    echo -e "${RED}❌ 未运行${NC}"
    echo ""
    echo -e "📋 原因：服务启动失败"

    # 尝试获取失败原因
    local fail_reason
    fail_reason=$(systemctl status autosocks --no-pager 2>/dev/null | grep -i "Main PID\|Status\|Error" | head -3)
    if [ -n "$fail_reason" ]; then
        echo ""
        echo -e "📋 详细信息："
        echo "$fail_reason" | while read -r line; do
            echo "   $line"
        done
    fi

    echo ""
    echo -e "${BLUE}💡 提示：运行 autosocks restart 尝试重启服务${NC}"
    echo -e "${BLUE}💡 提示：运行 autosocks logs 查看详细日志${NC}"
    echo ""
    log WARN "status" "服务启动失败"
}


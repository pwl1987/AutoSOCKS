validate_config() {
    config_load || return 1

    echo "=== 配置验证 ==="
    local all_ok=1

    [ -n "$SERVER_HOST" ] && printf '%b\n' "  ${GREEN}✓${NC} SERVER_HOST = $SERVER_HOST" \
        || { printf '%b\n' "  ${RED}✗${NC} SERVER_HOST 未配置"; all_ok=0; }
    [ -n "$SERVER_USER" ] && printf '%b\n' "  ${GREEN}✓${NC} SERVER_USER = $SERVER_USER" \
        || { printf '%b\n' "  ${RED}✗${NC} SERVER_USER 未配置"; all_ok=0; }

    # 端口范围
    if [[ "${SERVER_PORT:-22}" =~ ^[0-9]+$ ]] && (( SERVER_PORT >= 1 && SERVER_PORT <= 65535 )); then
        printf '%b\n' "  ${GREEN}✓${NC} SERVER_PORT = $SERVER_PORT"
    else
        printf '%b\n' "  ${RED}✗${NC} SERVER_PORT 超出范围"; all_ok=0
    fi

    if [[ "${LOCAL_PORT:-1080}" =~ ^[0-9]+$ ]] && (( LOCAL_PORT >= 1 && LOCAL_PORT <= 65535 )); then
        printf '%b\n' "  ${GREEN}✓${NC} LOCAL_PORT = $LOCAL_PORT"
    else
        printf '%b\n' "  ${RED}✗${NC} LOCAL_PORT 超出范围"; all_ok=0
    fi

    # 端口占用
    if port_is_open 127.0.0.1 "${LOCAL_PORT:-1080}" 2>/dev/null; then
        local pid
        pid=$(pid_by_port "${LOCAL_PORT:-1080}" 2>/dev/null || echo "")
        printf '%b\n' "  ${YELLOW}⚠${NC} LOCAL_PORT 已被占用 (PID: ${pid:-?})"
    else
        printf '%b\n' "  ${GREEN}✓${NC} LOCAL_PORT ${LOCAL_PORT:-1080} 空闲"
    fi

    # 服务器可达性
    if port_is_open "${SERVER_HOST}" "${SERVER_PORT:-22}" 5 2>/dev/null; then
        printf '%b\n' "  ${GREEN}✓${NC} 服务器 ${SERVER_HOST}:${SERVER_PORT:-22} 可达"
    else
        printf '%b\n' "  ${RED}✗${NC} 服务器 ${SERVER_HOST}:${SERVER_PORT:-22} 不可达"
        all_ok=0
    fi

    # 密钥/密码
    if [ "${AUTH_TYPE:-key}" = "key" ]; then
        if [ -n "${AUTH_KEY_PATH:-}" ] && [ -f "$AUTH_KEY_PATH" ]; then
            printf '%b\n' "  ${GREEN}✓${NC} SSH 密钥存在: $AUTH_KEY_PATH"
            if key_perms_ok "$AUTH_KEY_PATH"; then
                printf '%b\n' "  ${GREEN}✓${NC} 密钥权限安全"
            else
                printf '%b\n' "  ${YELLOW}⚠${NC} 密钥权限不安全（建议 600）"
            fi
        else
            printf '%b\n' "  ${RED}✗${NC} SSH 密钥不存在: ${AUTH_KEY_PATH:-未配置}"
            all_ok=0
        fi
    fi

    echo ""
    (( all_ok == 1 )) && { printf '%b\n' "${GREEN}✓ 配置验证通过${NC}"; return 0; } \
        || { printf '%b\n' "${RED}✗ 配置验证失败，请修复后重试${NC}"; return 1; }
}


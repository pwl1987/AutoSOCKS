# ============================================================

# ============================================================
# 函数：_download_china_ip
# 功能：下载并更新国内IP列表
# 依赖：网络可达
# 返回：0成功，1失败
# ============================================================
_download_china_ip() {
    local list_file="$CHINA_IP_LIST_FILE"
    local list_url="$CHINA_IP_LIST_URL"
    local temp_file="/tmp/china_ip_list_download.txt"

    # 1. 创建目录
    mkdir -p "$(dirname "$list_file")" 2>/dev/null || true

    # 2. 下载IP列表（3次重试）
    local downloaded=false
    for i in 1 2 3; do
        echo "📥 正在下载国内IP列表... (尝试 $i/3)"
        if wget -q -O "$temp_file" "$list_url" 2>/dev/null; then
            # 验证下载内容
            if [ -s "$temp_file" ] && grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/' "$temp_file" 2>/dev/null; then
                mv "$temp_file" "$list_file"
                downloaded=true
                break
            fi
        fi
        echo "⚠️ 下载失败，2秒后重试..."
        sleep 2
    done

    if [ "$downloaded" = "false" ]; then
        # 3. 失败则使用缓存
        if [ -f "$list_file" ] && [ -s "$list_file" ]; then
            print_warning "下载失败，使用现有缓存"
            return 0
        else
            print_error "国内IP列表下载失败" "E801"
            return 1
        fi
    fi

    # 4. 统计规则数量
    local rule_count
    rule_count=$(wc -l < "$list_file")
    echo "📊 国内IP规则：$rule_count 条"

    return 0
}

# ============================================================
# 函数：_get_china_ip_count
# 功能：获取国内IP规则数量
# 返回：规则数量
# ============================================================
_get_china_ip_count() {
    if [ -f "$CHINA_IP_LIST_FILE" ] && [ -s "$CHINA_IP_LIST_FILE" ]; then
        wc -l < "$CHINA_IP_LIST_FILE"
    else
        echo "0"
    fi
}

# ============================================================
# 函数：_check_ip_list_exists
# 功能：检查IP列表是否存在且有效
# 返回：0存在，1不存在
# ============================================================
_check_ip_list_exists() {
    if [ -f "$CHINA_IP_LIST_FILE" ] && [ -s "$CHINA_IP_LIST_FILE" ]; then
        # 检查是否有有效内容
        if grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/' "$CHINA_IP_LIST_FILE" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}


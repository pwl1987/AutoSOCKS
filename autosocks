# --------------------
# 配置加载函数（E2-S01）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：config_load
# 功能：加载配置文件，支持默认值和格式校验
# 参数：无
# 返回：
#   0 - 加载成功（包括使用默认值）
#   1 - 配置文件格式错误
# 副作用：
#   设置全局配置变量
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
config_load() {
    log "DEBUG" "config" "开始加载配置文件: $CONFIG_FILE"

    # 有效的配置项名称列表（与 _AUTOSOCKS_CONFIG_WHITELIST 同步）
    local valid_keys="SERVER_HOST SERVER_USER SERVER_PORT LOCAL_PORT LOCAL_BIND AUTH_TYPE AUTH_KEY_PATH SSH_KEEPALIVE SSH_TIMEOUT RECONNECT_ENABLED RECONNECT_INTERVAL LOG_ENABLED LOG_PATH REMOTE_HTTP_PORT HTTP_PROXY_PORT NO_PROXY_LIST CHECK_INTERVAL MAX_FAIL MAX_RETRY CHECK_URL COMPRESS BIND_ADDRESS FINGERPRINT_PIN WEBHOOK_URL SSH_PASSWORD LOG_MAX_SIZE PASS_MAX_AGE"

    # 如果配置文件不存在，使用默认值
    if [ ! -f "$CONFIG_FILE" ]; then
        log "INFO" "config" "配置文件不存在，使用默认值"
        _config_set_defaults
        return 0
    fi

    # 如果配置文件不可读，报错
    if [ ! -r "$CONFIG_FILE" ]; then
        print_error "配置文件不可读：$CONFIG_FILE" "E006"
        log "ERROR" "config" "配置文件不可读: $CONFIG_FILE"
        return 1
    fi

    # 先设置默认值
    _config_set_defaults

    # 逐行读取并校验配置文件
    local line_num=0
    local line_content=""
    local key=""
    local value=""
    local temp_config_file="/tmp/autosocks_config_$$"

    # 清空临时文件
    : > "$temp_config_file"

    while IFS= read -r line_content || [ -n "$line_content" ]; do
        line_num=$((line_num + 1))

        # 跳过空行
        if [ -z "$line_content" ]; then
            continue
        fi

        # 去除行首空格（使用 Bash 内置替换）
        line_content="${line_content#"${line_content%%[![:space:]]*}"}"

        # 跳过注释行
        if [[ "$line_content" == \#* ]]; then
            continue
        fi

        # 跳过只有空格的行
        if [[ "$line_content" =~ ^[[:space:]]*$ ]]; then
            continue
        fi

        # 校验格式：KEY="value" 或 KEY='value' 或 KEY=value
        # 提取 key（等号前面的部分）
        if [[ "$line_content" =~ ^([A-Za-z_][A-Za-z0-9_]*)= ]]; then
            key="${BASH_REMATCH[1]}"
        else
            print_error "配置文件格式错误（第 ${line_num} 行）" "E006"
            echo "  内容：$line_content"
            echo "  错误：无法识别的格式，应为 KEY=\"value\""
            rm -f "$temp_config_file"
            log "ERROR" "config" "配置格式错误（第 ${line_num} 行）: $line_content"
            return 1
        fi

        # 检查 key 是否有效
        if ! echo "$valid_keys" | grep -qw "$key"; then
            print_error "配置文件包含无效配置项（第 ${line_num} 行）" "E006"
            echo "  无效配置项：$key"
            echo "  有效配置项：$valid_keys"
            rm -f "$temp_config_file"
            log "ERROR" "config" "无效配置项（第 ${line_num} 行）: $key"
            return 1
        fi

        # 将有效行写入临时文件（去除行内注释）
        # 提取值部分
        local value_part="${line_content#*=}"

        # 处理引号包裹的值
        if [[ "$value_part" =~ ^\"([^\"]*)\"[[:space:]]*(\#.*)?$ ]] || \
           [[ "$value_part" =~ ^\'([^\']*)\'[[:space:]]*(\#.*)?$ ]]; then
            # 引号包裹的值，提取引号内的内容
            echo "${key}=\"${BASH_REMATCH[1]}\"" >> "$temp_config_file"
        elif [[ "$value_part" =~ ^([^[:space:]\#]+)[[:space:]]*(\#.*)?$ ]]; then
            # 无引号的值
            echo "${key}=\"${BASH_REMATCH[1]}\"" >> "$temp_config_file"
        else
            # 无法解析的格式
            print_error "配置文件格式错误（第 ${line_num} 行）" "E006"
            echo "  内容：$line_content"
            echo "  错误：无法解析值部分"
            rm -f "$temp_config_file"
            log "ERROR" "config" "值解析错误（第 ${line_num} 行）: $line_content"
            return 1
        fi

    done < "$CONFIG_FILE"

    # 加载临时配置文件
    if [ -s "$temp_config_file" ]; then
        # shellcheck source=/dev/null
        source "$temp_config_file" 2>/dev/null || {
            print_error "配置文件加载失败" "E006"
            rm -f "$temp_config_file"
            log "ERROR" "config" "配置文件 source 失败"
            return 1
        }
    fi

    # 清理临时文件
    rm -f "$temp_config_file"

    # 值校验（Region 8 增强：类型/范围/路径遍历防护）
    local _vk _vv
    for _vk in SERVER_PORT LOCAL_PORT HTTP_PROXY_PORT REMOTE_HTTP_PORT \
               SSH_KEEPALIVE SSH_TIMEOUT RECONNECT_INTERVAL CHECK_INTERVAL \
               MAX_RETRY MAX_FAIL LOG_MAX_SIZE AUTH_TYPE LOCAL_BIND \
               AUTH_KEY_PATH SERVER_HOST; do
        _vv="${!_vk:-}"
        [ -n "$_vv" ] || continue
        if ! _validate_config_value "$_vk" "$_vv"; then
            log "ERROR" "config" "配置值校验失败: $_vk=$_vv"
            return 1
        fi
    done

    log "INFO" "config" "配置文件加载成功"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_set_defaults
# 功能：设置所有配置项为默认值
# 参数：无
# 返回：无
# 说明：内部函数，由 config_load 调用
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_set_defaults() {
    SERVER_HOST="$DEFAULT_SERVER_HOST"
    SERVER_USER="$DEFAULT_SERVER_USER"
    SERVER_PORT="$DEFAULT_SERVER_PORT"
    LOCAL_PORT="$DEFAULT_LOCAL_PORT"
    LOCAL_BIND="$DEFAULT_LOCAL_BIND"
    AUTH_TYPE="$DEFAULT_AUTH_TYPE"
    AUTH_KEY_PATH="$DEFAULT_AUTH_KEY_PATH"
    SSH_KEEPALIVE="$DEFAULT_SSH_KEEPALIVE"
    SSH_TIMEOUT="$DEFAULT_SSH_TIMEOUT"
    RECONNECT_ENABLED="$DEFAULT_RECONNECT_ENABLED"
    RECONNECT_INTERVAL="$DEFAULT_RECONNECT_INTERVAL"
    LOG_ENABLED="$DEFAULT_LOG_ENABLED"
    # Region 8 新增默认值
    REMOTE_HTTP_PORT="$DEFAULT_REMOTE_HTTP_PORT"
    HTTP_PROXY_PORT="$DEFAULT_HTTP_PROXY_PORT"
    CHECK_INTERVAL="$DEFAULT_CHECK_INTERVAL"
    MAX_FAIL="$DEFAULT_MAX_FAIL"
    MAX_RETRY="$DEFAULT_MAX_RETRY"
    CHECK_URL="$DEFAULT_CHECK_URL"
    LOG_MAX_SIZE="$DEFAULT_LOG_MAX_SIZE"
    # LOG_PATH 预留功能
    log "DEBUG" "config" "已设置默认配置值"

# 输出成功信息（绿色）
# 参数: $1 - 消息内容
print_success() {
    local message="$1"
    echo -e "${GREEN}✅ ${message}${NC}"
}

# 输出错误信息（红色，到stderr）
# 参数: $1 - 消息内容
#       $2 - 错误码（可选）
print_error() {
    local message="$1"
    local error_code="${2:-}"

    if [ -n "$error_code" ]; then
        echo -e "${RED}❌ ${message} [错误码：${error_code}]${NC}" >&2
    else
        echo -e "${RED}❌ ${message}${NC}" >&2
    fi
}

# 输出警告信息（黄色）
# 参数: $1 - 消息内容
print_warning() {
    local message="$1"
    echo -e "${YELLOW}⚠️  ${message}${NC}"
}

# 输出提示信息（蓝色）
# 参数: $1 - 消息内容
print_info() {
    local message="$1"
    echo -e "${BLUE}💡 ${message}${NC}"
}

# --------------------
# 日志工具函数（E1-S04）
# --------------------

# 写日志到文件
# 参数: $1 - level   日志级别 (DEBUG/INFO/WARN/ERROR)
#       $2 - module  模块名
#       $3 - message 日志消息
log() {
    local level="$1"
    local module="$2"
    local message="$3"

    # DEBUG级别只在调试模式下记录
    if [ "$level" = "DEBUG" ] && [ -z "${AUTOSOCKS_DEBUG:-}" ]; then
        return
    fi

    # 检查是否启用日志
    if [ "${LOG_ENABLED:-true}" != "true" ]; then
        return
    fi

    # 日志轮转（Region 8 增强：rotate_log 在写入前调用）
    rotate_log

    # 获取时间戳（尝试获取毫秒，如果系统支持）
    local timestamp
    if date '+%3N' 2>/dev/null | grep -q '^[0-9]\{3\}$'; then
        timestamp=$(date '+%Y-%m-%d %H:%M:%S.%3N')
    else
        timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    fi

    # 确保日志目录存在
    local log_dir
    log_dir=$(dirname "${LOG_FILE:-/var/log/autosocks.log}")
    if [ ! -d "$log_dir" ]; then
        mkdir -p "$log_dir" 2>/dev/null || return
    fi

    # 写入日志文件
    echo "[$timestamp] [$level] [$module] $message" >> "${LOG_FILE:-/var/log/autosocks.log}"
}


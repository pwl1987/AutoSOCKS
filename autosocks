# --------------------
# 配置保存函数（E2-S02）
# --------------------

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：config_save
# 功能：将当前配置保存到配置文件
# 参数：无
# 返回：
#   0 - 保存成功
#   1 - 保存失败（无法创建目录或设置权限）
# 副作用：
#   创建/覆盖配置文件 /etc/autosocks/config.conf
#   设置文件权限为 600
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
config_save() {
    local conf_file="$CONFIG_FILE"
    local conf_dir
    conf_dir=$(dirname "$conf_file")

    # 创建目录（如果不存在）
    if [ ! -d "$conf_dir" ]; then
        mkdir -p "$conf_dir" || {
            print_error "无法创建配置目录：$conf_dir" "E006"
            log "ERROR" "config" "无法创建配置目录: $conf_dir"
            return 1
        }
        log "INFO" "config" "已创建配置目录: $conf_dir"
    fi

    # 生成配置文件内容
    cat > "$conf_file" << EOF
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AutoSOCKS 配置文件
# 位置：/etc/autosocks/config.conf
# 格式：key="value"（key和value之间用等号，value用双引号）
# 注意：修改后需要重启服务：autosocks restart
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── 服务器配置 ───
SERVER_HOST="${SERVER_HOST}"
SERVER_USER="${SERVER_USER}"
SERVER_PORT="${SERVER_PORT}"

# ─── 本地配置 ───
LOCAL_PORT="${LOCAL_PORT}"
LOCAL_BIND="${LOCAL_BIND}"

# ─── 认证配置 ───
AUTH_TYPE="${AUTH_TYPE}"
AUTH_KEY_PATH="${AUTH_KEY_PATH}"

# ─── SSH选项 ───
SSH_KEEPALIVE="${SSH_KEEPALIVE}"
SSH_TIMEOUT="${SSH_TIMEOUT}"

# ─── 重连配置 ───
RECONNECT_ENABLED="${RECONNECT_ENABLED}"
RECONNECT_INTERVAL="${RECONNECT_INTERVAL}"

# ─── 日志配置 ───
LOG_ENABLED="${LOG_ENABLED}"
EOF

    # 设置文件权限
    chmod 600 "$conf_file" || {
        print_error "无法设置配置文件权限" "E006"
        log "ERROR" "config" "无法设置配置文件权限: $conf_file"
        return 1
    }

    log "INFO" "config" "配置已保存：$conf_file"
    return 0
}


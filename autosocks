# E6-S06: 日志查看命令
# 功能：查看日志文件内容，支持指定行数和实时跟踪
# 参数：
#   --lines N     显示最近 N 行日志（默认 50）
#   --follow      实时跟踪日志（类似 tail -f）
#   -h, --help    显示帮助信息
# 返回：0=成功，1=日志文件不存在
# 示例：
#   autosocks logs              # 显示最近 50 行
#   autosocks logs --lines 100  # 显示最近 100 行
#   autosocks logs --follow     # 实时跟踪日志
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_logs() {
    local lines=50
    local follow=false

    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lines)
                if [[ -z "${2:-}" ]] || [[ "$2" =~ ^- ]]; then
                    print_error "--lines 需要指定行数" "E012"
                    return 1
                fi
                lines="$2"
                shift 2
                ;;
            --lines=*)
                lines="${1#*=}"
                shift
                ;;
            --follow|-f)
                follow=true
                shift
                ;;
            -h|--help)
                echo "用法：autosocks logs [选项]"
                echo ""
                echo "查看 AutoSOCKS 运行日志"
                echo ""
                echo "选项："
                echo "  --lines N     显示最近 N 行日志（默认 50）"
                echo "  --follow      实时跟踪日志（Ctrl+C 退出）"
                echo "  -h, --help    显示此帮助信息"
                echo ""
                echo "示例："
                echo "  autosocks logs              # 显示最近 50 行"
                echo "  autosocks logs --lines 100  # 显示最近 100 行"
                echo "  autosocks logs --follow     # 实时跟踪日志"
                return 0
                ;;
            # 位置参数（数字）：视为 --lines N 的简写
            [0-9]*)
                if [[ "$1" =~ ^[0-9]+$ ]]; then
                    lines="$1"
                    shift
                else
                    print_error "未知选项：$1" "E012"
                    return 1
                fi
                ;;
            *)
                print_error "未知选项：$1" "E012"
                echo "使用 'autosocks logs --help' 查看帮助"
                return 1
                ;;
        esac
    done

    # 检查日志文件是否存在（在记录日志之前）
    if [[ ! -f "$LOG_FILE" ]]; then
        print_warning "日志文件不存在：$LOG_FILE"
        echo ""
        echo "可能的原因："
        echo "  • AutoSOCKS 尚未运行过"
        echo "  • 日志功能已禁用（LOG_ENABLED=false）"
        echo "  • 日志文件被手动删除"
        echo ""
        echo "尝试启动服务以生成日志："
        echo "  autosocks start"
        return 1
    fi

    # 记录操作日志（日志文件存在才记录）
    log INFO "logs" "查看日志（行数：$lines，跟踪：$follow）"

    # 执行日志查看
    if [[ "$follow" == "true" ]]; then
        # 实时跟踪模式
        print_info "实时跟踪日志（按 Ctrl+C 退出）..."
        echo ""
        tail -f "$LOG_FILE"
    else
        # 显示指定行数
        if [[ ! "$lines" =~ ^[0-9]+$ ]] || [[ "$lines" -lt 1 ]]; then
            print_error "无效的行数：$lines" "E012"
            return 1
        fi

        tail -n "$lines" "$LOG_FILE"
    fi

    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E9-S01: 检测远程服务器公钥认证状态
# 功能：检测远程服务器是否启用了 SSH 公钥认证
# 参数：
#   无参数时使用配置文件中的服务器地址
#   --server ADDR  指定服务器地址
# 返回：0=已启用，1=未启用，2=无法检测
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_check_pubkey() {
    local server=""

    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --server)
                if [[ -z "${2:-}" ]] || [[ "$2" =~ ^- ]]; then
                    print_error "--server 需要指定服务器地址" "E012"
                    return 1
                fi
                server="$2"
                shift 2
                ;;
            --server=*)
                server="${1#*=}"
                shift
                ;;
            -h|--help)
                echo "用法：autosocks check-pubkey [选项]"
                echo ""
                echo "检测远程服务器是否启用了 SSH 公钥认证"
                echo ""
                echo "选项："
                echo "  --server ADDR  指定服务器地址（格式：user@ip）"
                echo "  -h, --help     显示此帮助信息"
                echo ""
                echo "示例："
                echo "  autosocks check-pubkey                    # 使用配置的服务器"
                echo "  autosocks check-pubkey --server root@1.2.3.4"
                echo ""
                return 0
                ;;
            *)
                print_error "未知选项：$1" "E012"
                echo "使用 'autosocks check-pubkey --help' 查看帮助"
                return 1
                ;;
        esac
    done

    # 如果没有指定服务器，使用配置文件中的
    if [[ -z "$server" ]]; then
        config_load || return 1
        if [[ -z "$SERVER_HOST" ]]; then
            print_error "未配置服务器地址" "E009"
            echo ""
            echo "请先配置服务器："
            echo "  autosocks config --server user@ip"
            echo ""
            echo "或直接指定："
            echo "  autosocks check-pubkey --server user@ip"
            return 1
        fi
        server="${SERVER_USER}@${SERVER_HOST}"
    fi

    log INFO "check" "检测远程服务器公钥认证状态: $server"
    print_info "正在检测 $server 的公钥认证状态..."
    echo ""

    # 调用检测函数
    local result
    check_pubkey_auth "$server" "${SERVER_PORT:-22}"
    result=$?

    case $result in
        0)
            print_success "远程服务器已启用公钥认证 ✓"
            echo ""
            echo "你可以使用密钥登录该服务器。"
            ;;
        1)
            print_error "远程服务器未启用公钥认证" "E014"
            echo ""
            echo "这意味着即使你上传了公钥，SSH 也不会使用密钥认证。"
            echo ""
            echo "要启用公钥认证，请运行："
            echo "  autosocks enable-pubkey --server $server"
            echo ""
            ;;
        2)
            print_warning "无法检测公钥认证状态"
            echo ""
            echo "可能原因："
            echo "  • 无法连接到服务器"
            echo "  • 服务器 SSH 配置异常"
            echo ""
            echo "请手动检查："
            echo "  ssh $server 'grep PubkeyAuthentication /etc/ssh/sshd_config'"
            ;;
    esac

    return $result
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E9-S02: 启用远程服务器公钥认证
# 功能：在远程服务器上启用 SSH 公钥认证
# 参数：
#   无参数时使用配置文件中的服务器地址
#   --server ADDR  指定服务器地址
# 返回：0=成功，1=失败，2=用户手动处理
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_enable_pubkey() {
    local server=""

    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --server)
                if [[ -z "${2:-}" ]] || [[ "$2" =~ ^- ]]; then
                    print_error "--server 需要指定服务器地址" "E012"
                    return 1
                fi
                server="$2"
                shift 2
                ;;
            --server=*)
                server="${1#*=}"
                shift
                ;;
            -h|--help)
                echo "用法：autosocks enable-pubkey [选项]"
                echo ""
                echo "在远程服务器上启用 SSH 公钥认证"
                echo ""
                echo "选项："
                echo "  --server ADDR  指定服务器地址（格式：user@ip）"
                echo "  -h, --help     显示此帮助信息"
                echo ""
                echo "说明："
                echo "  此命令需要远程服务器的密码才能执行。"
                echo "  如果无法自动执行，会提供手动操作步骤。"
                echo ""
                echo "示例："
                echo "  autosocks enable-pubkey                    # 使用配置的服务器"
                echo "  autosocks enable-pubkey --server root@1.2.3.4"
                echo ""
                return 0
                ;;
            *)
                print_error "未知选项：$1" "E012"
                echo "使用 'autosocks enable-pubkey --help' 查看帮助"
                return 1
                ;;
        esac
    done

    # 如果没有指定服务器，使用配置文件中的
    if [[ -z "$server" ]]; then
        config_load || return 1
        if [[ -z "$SERVER_HOST" ]]; then
            print_error "未配置服务器地址" "E009"
            echo ""
            echo "请先配置服务器："
            echo "  autosocks config --server user@ip"
            echo ""
            echo "或直接指定："
            echo "  autosocks enable-pubkey --server user@ip"
            return 1
        fi
        server="${SERVER_USER}@${SERVER_HOST}"
    fi

    log INFO "check" "启用远程服务器公钥认证: $server"

    # 先检查当前状态
    echo ""
    print_info "先检测当前公钥认证状态..."
    echo ""

    local current_status
    check_pubkey_auth "$server" "${SERVER_PORT:-22}"
    current_status=$?

    if [[ $current_status -eq 0 ]]; then
        print_success "远程服务器已启用公钥认证，无需操作！"
        return 0
    fi

    # 调用启用函数
    enable_pubkey_auth "$server" "${SERVER_PORT:-22}"
    return $?
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HTTP 代理命令
# 功能：启用/禁用/查看 HTTP 代理状态
# 参数：
#   on      启用 HTTP 代理（通过 Privoxy）
#   off     禁用 HTTP 代理
#   status  查看状态
# 返回：0=成功，1=失败
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_http_proxy() {
    local action="${1:-status}"

    case "$action" in
        on|enable|start)
            _http_proxy_enable
            ;;
        off|disable|stop)
            _http_proxy_disable
            ;;
        status|show)
            _http_proxy_status
            ;;
        -h|--help)
            echo "用法：autosocks http-proxy [on|off|status]"
            echo ""
            echo "管理 HTTP/HTTPS 代理（通过 Privoxy 转换 SOCKS5）"
            echo ""
            echo "命令："
            echo "  on, enable   启用 HTTP 代理"
            echo "  off, disable 禁用 HTTP 代理"
            echo "  status       查看状态（默认）"
            echo ""
            echo "说明："
            echo "  • HTTP 代理需要先安装 Privoxy"
            echo "  • 启用后会自动配置并启动 Privoxy"
            echo "  • 默认端口：8080"
            echo ""
            echo "示例："
            echo "  autosocks http-proxy on      # 启用"
            echo "  autosocks http-proxy off     # 禁用"
            echo "  autosocks http-proxy status  # 查看状态"
            echo ""
            echo "使用 HTTP 代理："
            echo "  export http_proxy=http://127.0.0.1:8080"
            echo "  export https_proxy=http://127.0.0.1:8080"
            echo ""
            return 0
            ;;
        *)
            print_error "未知操作：$action" "E012"
            echo ""
            echo "有效操作：on, off, status"
            echo "使用 'autosocks http-proxy --help' 查看帮助"
            return 1
            ;;
    esac
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 启用 HTTP 代理（内部函数）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_http_proxy_enable() {
    log INFO "http-proxy" "用户请求启用 HTTP 代理"

    # 加载配置以获取端口号等
    config_load || return 1

    # 检查 SOCKS5 代理是否运行
    if ! systemctl is-active autosocks &>/dev/null; then
        print_warning "SOCKS5 代理未运行，先启动它"
        echo ""
        read -r -p "是否现在启动 SOCKS5 代理？[Y/n]: " start_socks
        if [ "$start_socks" != "n" ] && [ "$start_socks" != "N" ]; then
            if ! systemctl start autosocks 2>/dev/null; then
                print_error "启动 SOCKS5 代理失败"
                return 1
            fi
            sleep 2
        else
            print_error "HTTP 代理需要 SOCKS5 代理先运行"
            return 1
        fi
    fi

    # 检查并安装 Privoxy
    if ! command -v privoxy &>/dev/null; then
        echo ""
        print_warning "Privoxy 未安装"
        echo ""
        echo "Privoxy 用于将 SOCKS5 代理转换为 HTTP 代理。"
        echo ""
        read -r -p "是否现在安装 Privoxy？[Y/n]: " install_privoxy

        if [ "$install_privoxy" != "n" ] && [ "$install_privoxy" != "N" ]; then
            print_info "正在安装 Privoxy..."

            local install_cmd=""
            if command -v apt-get &>/dev/null; then
                install_cmd="apt-get update && apt-get install -y privoxy"
            elif command -v yum &>/dev/null; then
                install_cmd="yum install -y privoxy"
            elif command -v dnf &>/dev/null; then
                install_cmd="dnf install -y privoxy"
            fi

            if [ -n "$install_cmd" ]; then
                if ! eval "$install_cmd"; then
                    print_error "Privoxy 安装失败"
                    return 1
                fi
            else
                print_error "无法确定包管理器，请手动安装 Privoxy"
                return 1
            fi
        else
            print_error "HTTP 代理需要 Privoxy"
            return 1
        fi
    fi

    # 配置 HTTP 代理
    print_info "正在配置 HTTP 代理..."

    # 加载配置获取 LOCAL_PORT
    config_load || return 1

    # 调用配置函数
    if configure_http_proxy; then
        echo ""
        print_success "HTTP 代理已启用！"
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  代理地址"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""

        local lan_ip=""
        if [ "${LOCAL_BIND}" = "0.0.0.0" ]; then
            lan_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
            echo "  SOCKS5:  127.0.0.1:${LOCAL_PORT} (本机)"
            echo "           ${lan_ip}:${LOCAL_PORT} (局域网)"
            echo "  HTTP:    127.0.0.1:${HTTP_PROXY_PORT} (本机)"
            echo "           ${lan_ip}:${HTTP_PROXY_PORT} (局域网)"
        else
            echo "  SOCKS5:  127.0.0.1:${LOCAL_PORT}"
            echo "  HTTP:    127.0.0.1:${HTTP_PROXY_PORT}"
        fi
        echo ""
        echo "使用方法："
        echo "  export http_proxy=http://127.0.0.1:${HTTP_PROXY_PORT}"
        echo "  export https_proxy=http://127.0.0.1:${HTTP_PROXY_PORT}"
        echo ""
        echo "测试命令："
        echo "  curl -x http://127.0.0.1:${HTTP_PROXY_PORT} http://ip.sb"
        echo ""
        return 0
    else
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 禁用 HTTP 代理（内部函数）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_http_proxy_disable() {
    log INFO "http-proxy" "用户请求禁用 HTTP 代理"

    if [ ! -f "$PRIVOXY_CONF_FILE" ]; then
        print_warning "HTTP 代理未启用"
        return 0
    fi

    print_info "正在禁用 HTTP 代理..."

    # 清理配置
    cleanup_http_proxy_config

    print_success "HTTP 代理已禁用"
    echo ""
    echo "SOCKS5 代理仍在运行：127.0.0.1:${LOCAL_PORT}"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 查看 HTTP 代理状态（内部函数）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_http_proxy_status() {
    log INFO "http-proxy" "查看 HTTP 代理状态"

    # 加载配置
    config_load || return 1

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  HTTP 代理状态"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # 检查 Privoxy 是否安装
    if command -v privoxy &>/dev/null; then
        echo "  Privoxy:    ✅ 已安装"
    else
        echo "  Privoxy:    ❌ 未安装"
        echo ""
        echo "  运行 'autosocks http-proxy on' 会自动安装"
        return 0
    fi

    # 检查配置文件是否存在
    if [ -f "$PRIVOXY_CONF_FILE" ]; then
        echo "  配置文件:  ✅ $PRIVOXY_CONF_FILE"
    else
        echo "  配置文件:  ❌ 不存在（HTTP 代理未启用）"
        return 0
    fi

    # 检查 Privoxy 服务状态
    if systemctl is-active privoxy &>/dev/null; then
        echo "  服务状态:  ✅ 运行中"
    else
        echo "  服务状态:  ❌ 未运行"
    fi

    # 检测 Privoxy 实际监听的端口
    local actual_http_port
    actual_http_port=$(ss -tlnp 2>/dev/null | grep privoxy | grep -oP ':\K[0-9]+' | head -1)
    if [ -z "$actual_http_port" ]; then
        actual_http_port="${HTTP_PROXY_PORT:-8080}"
    fi

    # 检查端口是否监听
    if ss -tln 2>/dev/null | grep -q ":${actual_http_port}"; then
        echo "  端口监听:  ✅ ${actual_http_port}"
    else
        echo "  端口监听:  ❌ ${actual_http_port} 未监听"
    fi

    echo ""
    echo "  HTTP 代理地址: http://127.0.0.1:${actual_http_port}"
    echo ""

    # 测试连接
    echo "  正在测试 HTTP 代理..."
    local test_result
    test_result=$(curl -x "http://127.0.0.1:${actual_http_port}" -m 5 -s -o /dev/null -w "%{http_code}" http://www.gstatic.com/generate_204 2>/dev/null)

    if [ "$test_result" = "204" ] || [ "$test_result" = "200" ]; then
        echo "  连接测试:  ✅ 正常"
    else
        echo "  连接测试:  ❌ 失败 (HTTP $test_result)"
    fi

    echo ""
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E2-S03: 配置显示和修改命令
# 功能：显示当前配置、修改服务器地址/端口/局域网共享设置
# 参数：
#   --show         显示当前所有配置
#   --server ADDR  修改服务器地址（格式：user@ip）
#   --port PORT    修改本地端口
#   --lan on/off   开启/关闭局域网共享
# 返回：0=成功，1=失败
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_config() {
    local option="${1:-}"
    local value="${2:-}"

    # 先加载配置（确保使用最新值）
    config_load || return 1

    case "$option" in
        --show|"")
            _config_show
            ;;
        --server)
            _config_set_server "$value"
            ;;
        --port)
            _config_set_port "$value"
            ;;
        --http-port)
            _config_set_http_port "$value"
            ;;
        --lan)
            _config_set_lan "$value"
            ;;
        *)
            print_error "未知选项：$option" "E012"
            echo ""
            echo "有效选项："
            echo "  --show             显示当前配置"
            echo "  --server ADDR      修改服务器地址"
            echo "  --port PORT        修改 SOCKS5 端口"
            echo "  --http-port PORT   修改 HTTP 代理端口"
            echo "  --lan on/off       开关局域网共享"
            ;;
    esac
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_show
# 功能：按分类显示当前所有配置
# 参数：无
# 返回：0
# 说明：AC-01, AC-02 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_show() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  AutoSOCKS 当前配置${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    # 服务器配置
    echo -e "${GREEN}【服务器配置】${NC}"
    if [ -n "$SERVER_HOST" ]; then
        echo "  服务器地址    ${SERVER_USER}@${SERVER_HOST}"
    else
        echo "  服务器地址    （未配置）"
    fi
    echo "  SSH端口       ${SERVER_PORT}"
    echo ""

    # 本地配置
    echo -e "${GREEN}【本地配置】${NC}"
    echo "  本地端口      ${LOCAL_PORT}"
    if [ "$LOCAL_BIND" = "0.0.0.0" ]; then
        echo "  局域网共享    已开启（${LOCAL_BIND}）"
    else
        echo "  局域网共享    已关闭（${LOCAL_BIND}）"
    fi
    echo ""

    # 认证配置
    echo -e "${GREEN}【认证配置】${NC}"
    echo "  认证方式      ${AUTH_TYPE}"
    if [ -n "$AUTH_KEY_PATH" ]; then
        echo "  密钥路径      ${AUTH_KEY_PATH}"
    else
        echo "  密钥路径      （使用默认）"
    fi
    echo ""

    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    log "INFO" "config" "用户查看配置"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_set_server
# 功能：修改服务器地址
# 参数：$1 - 服务器地址（格式：user@ip 或 ip）
# 返回：0=成功，1=失败
# 说明：AC-03, AC-07, AC-08 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_set_server() {
    local server_addr="$1"

    # 校验参数
    if [ -z "$server_addr" ]; then
        print_error "缺少服务器地址参数" "E009"
        echo ""
        echo "正确格式：autosocks config --server user@1.2.3.4"
        return 1
    fi

    # 解析 user@ip 格式
    local new_user=""
    local new_host=""

    if [[ "$server_addr" == *"@"* ]]; then
        # 格式：user@ip
        new_user="${server_addr%%@*}"
        new_host="${server_addr#*@}"
    else
        # 格式：仅 ip，保持当前用户
        new_user="$SERVER_USER"
        new_host="$server_addr"
    fi

    # 校验主机名/IP格式（基础校验）
    if [ -z "$new_host" ]; then
        print_error "服务器地址格式错误" "E012"
        echo ""
        echo "正确格式："
        echo "  user@192.168.1.100"
        echo "  root@1.2.3.4"
        return 1
    fi

    # 更新配置
    SERVER_USER="$new_user"
    SERVER_HOST="$new_host"

    # 保存配置
    if config_save; then
        print_success "服务器地址已修改：${SERVER_USER}@${SERVER_HOST}"
        echo ""
        print_warning "修改需要重启服务才能生效"
        echo "  执行：autosocks restart"
        log "INFO" "config" "服务器地址已修改: ${SERVER_USER}@${SERVER_HOST}"
        return 0
    else
        print_error "配置保存失败" "E006"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_set_port
# 功能：修改本地端口
# 参数：$1 - 端口号（1-65535）
# 返回：0=成功，1=失败
# 说明：AC-04, AC-07, AC-08 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_set_port() {
    local port="$1"

    # 校验参数
    if [ -z "$port" ]; then
        print_error "缺少端口号参数" "E009"
        echo ""
        echo "正确格式：autosocks config --port 1081"
        return 1
    fi

    # 校验端口范围
    if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        print_error "端口号无效（应为 1-65535）" "E012"
        echo ""
        echo "有效端口范围：1 - 65535"
        echo "常用端口：1080, 8080, 1081"
        return 1
    fi

    # 检测端口是否被占用（排除 autosocks 的 SSH 隧道）
    if _is_port_in_use "$port"; then
        # 检查是否是 autosocks 的 SSH 隧道占用
        if ss -tlnp 2>/dev/null | grep ":${port} " | grep -q ssh; then
            :  # 是 autosocks 自己占用，允许设置
        else
            print_warning "端口 ${port} 已被其他程序占用"
            local available_port
            available_port=$(_find_available_port "$port")
            if [ "$available_port" != "-1" ] && [ "$available_port" != "$port" ]; then
                print_info "自动切换到可用端口：${available_port}"
                port="$available_port"
            else
                print_error "无法找到可用端口"
                echo "  请手动指定其他端口：autosocks config --port 端口号"
                return 1
            fi
        fi
    fi

    # 更新配置
    LOCAL_PORT="$port"

    # 保存配置
    if config_save; then
        print_success "SOCKS5 端口已设置：${LOCAL_PORT}"
        echo ""
        print_warning "修改需要重启服务才能生效"
        echo "  执行：autosocks restart"
        log "INFO" "config" "本地端口已修改: ${LOCAL_PORT}"
        return 0
    else
        print_error "配置保存失败" "E006"
        return 1
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_is_port_in_use
# 功能：检测端口是否被占用
# 参数：$1 - 端口号
# 返回：0=已被占用，1=可用
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_is_port_in_use() {
    local port="$1"
    if ss -tln 2>/dev/null | grep -q ":${port} " || \
       netstat -tln 2>/dev/null | grep -q ":${port} "; then
        return 0  # 被占用
    fi
    return 1  # 可用
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_find_available_port
# 功能：从指定端口开始寻找可用端口
# 参数：$1 - 起始端口（默认 1080）
# 返回：输出可用端口号
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_find_available_port() {
    local start_port="${1:-1080}"
    local port="$start_port"
    local max_attempts=100

    while [ $((port - start_port)) -lt $max_attempts ]; do
        if ! _is_port_in_use "$port"; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done

    # 如果找不到，返回 -1
    echo "-1"
    return 1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_get_local_ip
# 功能：获取本机局域网IP地址
# 参数：无
# 返回：输出本机IP地址（字符串）
# 说明：用于局域网共享时显示可用地址
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_get_local_ip() {
    local local_ip=""

    # 方法1：使用 hostname -I（最常用）
    if command -v hostname &>/dev/null; then
        local_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
        if [ -n "$local_ip" ] && [ "$local_ip" != "127.0.0.1" ]; then
            echo "$local_ip"
            return 0
        fi
    fi

    # 方法2：使用 ip 命令
    if command -v ip &>/dev/null; then
        local_ip=$(ip route get 1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}')
        if [ -n "$local_ip" ] && [ "$local_ip" != "127.0.0.1" ]; then
            echo "$local_ip"
            return 0
        fi
    fi

    # 方法3：使用 ifconfig（兼容旧系统）
    if command -v ifconfig &>/dev/null; then
        local_ip=$(ifconfig 2>/dev/null | grep -Eo 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -Eo '([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | head -1)
        if [ -n "$local_ip" ]; then
            echo "$local_ip"
            return 0
        fi
    fi

    # 无法获取，返回空
    echo ""
    return 1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_set_lan
# 功能：开启/关闭局域网共享
# 参数：$1 - on 或 off
# 返回：0=成功，1=失败
# 说明：E7-S01 验收标准实现
#   AC-01: --lan on 开启共享（LOCAL_BIND=0.0.0.0）
#   AC-02: 显示安全警告并确认
#   AC-03: 重启服务生效
#   AC-04: 显示可用地址（本机IP:端口）
#   AC-05: --lan off 关闭共享（LOCAL_BIND=127.0.0.1）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_set_lan() {
    local lan_mode="$1"

    # 校验参数
    if [ -z "$lan_mode" ]; then
        print_error "缺少参数" "E009"
        echo ""
        echo "正确格式："
        echo "  autosocks config --lan on   # 开启局域网共享"
        echo "  autosocks config --lan off  # 关闭局域网共享"
        return 1
    fi

    # 转为小写进行比较
    lan_mode=$(echo "$lan_mode" | tr '[:upper:]' '[:lower:]')

    case "$lan_mode" in
        on|yes|true|1)
            # AC-02: 显示安全警告并确认
            echo ""
            print_warning "需要确认"
            echo ""
            echo "你要开启局域网共享。"
            echo ""
            echo "这意味着："
            echo "  • 同一WiFi下的设备可以访问你的代理"
            echo "  • 别人可以通过你的电脑IP地址使用代理"
            echo ""
            echo "风险提醒："
            echo "  🔴 不要在咖啡厅、机场等公共WiFi下开启"
            echo "  🔴 开启后请确保你的服务器安全"
            echo "  🟡 不使用时建议关闭"
            echo ""

            # 询问用户确认
            local confirm=""
            if [ -t 0 ]; then
                # 交互模式
                read -r -p "确认开启局域网共享吗？[y/n]：" confirm
            else
                # 非交互模式，直接确认
                confirm="y"
            fi

            # 转为小写
            confirm=$(echo "$confirm" | tr '[:upper:]' '[:lower:]')

            if [[ ! "$confirm" =~ ^y|yes$ ]]; then
                echo ""
                print_info "已取消开启局域网共享"
                return 0
            fi

            # AC-01: 设置绑定地址为 0.0.0.0
            LOCAL_BIND="0.0.0.0"
            ;;
        off|no|false|0)
            # AC-05: 关闭局域网共享
            LOCAL_BIND="127.0.0.1"
            ;;
        *)
            print_error "参数无效（应为 on 或 off）" "E012"
            echo ""
            echo "有效选项：on, off"
            return 1
            ;;
    esac

    # 保存配置
    if ! config_save; then
        print_error "配置保存失败" "E006"
        return 1
    fi

    # 输出结果
    echo ""
    if [ "$LOCAL_BIND" = "0.0.0.0" ]; then
        print_success "局域网共享已开启"
        echo ""

        # AC-04: 显示可用地址（本机IP:端口）
        local local_ip
        local_ip=$(_get_local_ip)

        echo "📍 其他设备可用的代理地址："
        if [ -n "$local_ip" ]; then
            echo "   ${local_ip}:${LOCAL_PORT}"
        else
            echo "   <本机IP>:${LOCAL_PORT}"
            echo "   （无法自动获取本机IP，请手动查看：ip addr 或 hostname -I）"
        fi
        echo ""
        echo "💡 使用方法："
        echo "   在手机或其他设备的代理设置中，填入上面的地址"
    else
        print_success "局域网共享已关闭"
        echo ""
        echo "  仅本机可以使用代理（127.0.0.1:${LOCAL_PORT}）"
    fi

    echo ""

    # 同步更新 HTTP 代理配置（如果已启用）
    if [ -f "$PRIVOXY_CONF_FILE" ]; then
        print_info "同步更新 HTTP 代理配置..."
        configure_http_proxy >/dev/null 2>&1 || true
    fi

    # AC-03: 自动重启服务使配置生效
    print_info "正在重启服务以应用配置..."

    # 检查服务是否存在
    if [ -f "$SERVICE_FILE" ]; then
        # 调用 cmd_restart 函数
        if cmd_restart; then
            log "INFO" "config" "局域网共享已修改并重启服务: ${LOCAL_BIND}"
            return 0
        else
            print_warning "服务重启失败，请手动重启：autosocks restart"
            log "WARN" "config" "服务重启失败，局域网共享配置已保存: ${LOCAL_BIND}"
            return 0
        fi
    else
        print_warning "服务未安装，配置已保存"
        echo "  安装后配置会自动生效"
        log "INFO" "config" "局域网共享已修改（服务未安装）: ${LOCAL_BIND}"
        return 0
    fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 函数名：_config_set_http_port
# 功能：修改 HTTP 代理端口
# 参数：$1 - 新端口
# 返回：0=成功，1=失败
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_config_set_http_port() {
    local new_port="$1"

    # 校验参数
    if [ -z "$new_port" ]; then
        print_error "缺少端口参数" "E009"
        echo ""
        echo "正确格式："
        echo "  autosocks config --http-port 8080"
        return 1
    fi

    # 校验端口格式
    if ! echo "$new_port" | grep -qE '^[0-9]+$'; then
        print_error "端口格式错误" "E012"
        echo ""
        echo "端口必须是数字，例如：8080"
        return 1
    fi

    # 校验端口范围
    if [ "$new_port" -lt 1 ] || [ "$new_port" -gt 65535 ]; then
        print_error "端口超出范围" "E012"
        echo ""
        echo "端口范围：1-65535"
        return 1
    fi

    # 检测端口是否被占用（排除 privoxy 自己）
    if _is_port_in_use "$new_port"; then
        # 检查是否是 privoxy 自己占用
        if ss -tlnp 2>/dev/null | grep ":${new_port} " | grep -q privoxy; then
            :  # 是自己占用，允许
        else
            print_warning "端口 ${new_port} 已被其他程序占用"
            local available_port
            available_port=$(_find_available_port "$new_port")
            if [ "$available_port" != "-1" ] && [ "$available_port" != "$new_port" ]; then
                print_info "自动切换到可用端口：${available_port}"
                new_port="$available_port"
            else
                print_error "无法找到可用端口"
                echo "  请手动指定其他端口：autosocks config --http-port 端口号"
                return 1
            fi
        fi
    fi

    # 修改 HTTP_PROXY_PORT 变量
    HTTP_PROXY_PORT="$new_port"

    # 如果 HTTP 代理已启用，重新生成配置
    if [ -f "$PRIVOXY_CONF_FILE" ]; then
        print_info "正在更新 HTTP 代理配置..."
        configure_http_proxy
    else
        print_success "HTTP 代理端口已设置为 ${new_port}"
        echo ""
        echo "  运行 'autosocks http-proxy on' 启用 HTTP 代理"
    fi

    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E2-S04: 配置导出命令
# 功能：导出当前配置到标准输出
# 参数：无
# 返回：0=成功，1=失败
# 说明：AC-01, AC-02, AC-05 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_export() {
    # 先加载配置（确保使用最新值）
    config_load || return 1

    # 输出配置内容（格式与配置文件兼容）
    echo "# AutoSOCKS 配置导出"
    echo "# 导出时间：$(date '+%Y-%m-%d %H:%M:%S')"
    echo "# 格式：key=\"value\""
    echo ""
    echo "# ─── 服务器配置 ───"
    echo "SERVER_HOST=\"${SERVER_HOST}\""
    echo "SERVER_USER=\"${SERVER_USER}\""
    echo "SERVER_PORT=\"${SERVER_PORT}\""
    echo ""
    echo "# ─── 本地配置 ───"
    echo "LOCAL_PORT=\"${LOCAL_PORT}\""
    echo "LOCAL_BIND=\"${LOCAL_BIND}\""
    echo ""
    echo "# ─── 认证配置 ───"
    echo "AUTH_TYPE=\"${AUTH_TYPE}\""
    # 注意：不导出密钥路径（密钥文件需要手动备份）
    echo "AUTH_KEY_PATH=\"\""
    echo ""
    echo "# ─── SSH选项 ───"
    echo "SSH_KEEPALIVE=\"${SSH_KEEPALIVE}\""
    echo "SSH_TIMEOUT=\"${SSH_TIMEOUT}\""
    echo ""
    echo "# ─── 重连配置 ───"
    echo "RECONNECT_ENABLED=\"${RECONNECT_ENABLED}\""
    echo "RECONNECT_INTERVAL=\"${RECONNECT_INTERVAL}\""
    echo ""
    echo "# ─── 日志配置 ───"
    echo "LOG_ENABLED=\"${LOG_ENABLED}\""

    # 输出密钥备份提示到 stderr（不影响重定向）
    echo "" >&2
    print_warning "密钥文件未导出，需手动备份：" >&2
    if [ -n "$AUTH_KEY_PATH" ] && [ -f "$AUTH_KEY_PATH" ]; then
        echo "  密钥路径：${AUTH_KEY_PATH}" >&2
    else
        local default_key="$HOME/.ssh/id_rsa"
        if [ -f "$default_key" ]; then
            echo "  密钥路径：${default_key}" >&2
        else
            echo "  （未找到默认密钥文件）" >&2
        fi
    fi
    echo "" >&2
    echo "  备份命令：cp ~/.ssh/id_rsa ~/密钥备份/" >&2

    log "INFO" "config" "配置已导出"
    return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E2-S04: 配置导入命令
# 功能：从标准输入导入配置
# 参数：无（从 stdin 读取）
# 返回：0=成功，1=失败
# 说明：AC-03, AC-04, AC-06 实现
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
cmd_import() {
    # 先加载当前配置作为基础
    config_load || return 1

    local temp_file="/tmp/autosocks_import_$$"

    # 确保函数退出时删除临时文件
    # shellcheck disable=SC2094
    trap 'rm -f "$temp_file"' EXIT

    # 从 stdin 读取数据
    if [ -t 0 ]; then
        # 交互模式，提示用户
        print_error "请通过管道或重定向提供配置数据" "E009"
        echo ""
        echo "正确用法："
        echo "  autosocks import < backup.txt"
        echo "  cat backup.txt | autosocks import"
        return 1
    fi

    # 保存输入到临时文件
    cat > "$temp_file"

    # 检查输入是否为空
    if [ ! -s "$temp_file" ]; then
        print_error "导入数据为空" "E006"
        rm -f "$temp_file"
        return 1
    fi

    # 有效的配置项名称列表
    local valid_keys="SERVER_HOST SERVER_USER SERVER_PORT LOCAL_PORT LOCAL_BIND AUTH_TYPE AUTH_KEY_PATH SSH_KEEPALIVE SSH_TIMEOUT RECONNECT_ENABLED RECONNECT_INTERVAL LOG_ENABLED LOG_PATH"

    # 逐行校验配置格式
    local line_num=0
    local line_content=""
    local key=""
    local value=""
    local has_valid_line=false

    while IFS= read -r line_content || [ -n "$line_content" ]; do
        line_num=$((line_num + 1))

        # 跳过空行
        [ -z "$line_content" ] && continue

        # 去除行首空格
        line_content="${line_content#"${line_content%%[![:space:]]*}"}"

        # 跳过注释行
        [[ "$line_content" == \#* ]] && continue

        # 跳过只有空格的行
        [[ "$line_content" =~ ^[[:space:]]*$ ]] && continue

        # 校验格式：KEY="value" 或 KEY='value' 或 KEY=value
        if [[ "$line_content" =~ ^([A-Za-z_][A-Za-z0-9_]*)= ]]; then
            key="${BASH_REMATCH[1]}"
        else
            print_error "导入配置格式错误（第 ${line_num} 行）" "E012"
            echo "  内容：$line_content"
            echo "  错误：无法识别的格式，应为 KEY=\"value\""
            return 1
        fi

        # 检查 key 是否有效
        if ! echo "$valid_keys" | grep -qw "$key"; then
            print_error "导入配置包含无效配置项（第 ${line_num} 行）" "E012"
            echo "  无效配置项：$key"
            echo "  有效配置项：$valid_keys"
            return 1
        fi

        has_valid_line=true

    done < "$temp_file"

    # 检查是否有有效配置
    if [ "$has_valid_line" = false ]; then
        print_error "导入数据中未找到有效配置" "E006"
        return 1
    fi

    # 格式校验通过，应用配置
    # 使用临时环境变量方式加载
    while IFS= read -r line_content || [ -n "$line_content" ]; do
        # 跳过空行和注释
        [ -z "$line_content" ] && continue
        line_content="${line_content#"${line_content%%[![:space:]]*}"}"
        [[ "$line_content" == \#* ]] && continue
        [[ "$line_content" =~ ^[[:space:]]*$ ]] && continue

        # 提取 key 和 value
        if [[ "$line_content" =~ ^([A-Za-z_][A-Za-z0-9_]*)= ]]; then
            key="${BASH_REMATCH[1]}"
            local value_part="${line_content#*=}"

            # 处理引号包裹的值
            if [[ "$value_part" =~ ^\"([^\"]*)\" ]]; then
                value="${BASH_REMATCH[1]}"
            elif [[ "$value_part" =~ ^\'([^\']*)\' ]]; then
                value="${BASH_REMATCH[1]}"
            elif [[ "$value_part" =~ ^([^[:space:]\#]+) ]]; then
                value="${BASH_REMATCH[1]}"
            else
                value=""
            fi

            # 应用配置（直接设置变量）
            case "$key" in
                SERVER_HOST) SERVER_HOST="$value" ;;
                SERVER_USER) SERVER_USER="$value" ;;
                SERVER_PORT) SERVER_PORT="$value" ;;
                LOCAL_PORT) LOCAL_PORT="$value" ;;
                LOCAL_BIND) LOCAL_BIND="$value" ;;
                AUTH_TYPE) AUTH_TYPE="$value" ;;
                AUTH_KEY_PATH) AUTH_KEY_PATH="$value" ;;
                SSH_KEEPALIVE) SSH_KEEPALIVE="$value" ;;
                SSH_TIMEOUT) SSH_TIMEOUT="$value" ;;
                RECONNECT_ENABLED) RECONNECT_ENABLED="$value" ;;
                RECONNECT_INTERVAL) RECONNECT_INTERVAL="$value" ;;
                LOG_ENABLED) LOG_ENABLED="$value" ;;
                LOG_PATH)
                    # TODO: 实现自定义日志路径功能
                    # LOG_PATH="$value"
                    ;;
            esac
        fi
    done < "$temp_file"

    # 清理临时文件
    rm -f "$temp_file"

    # 保存配置到文件
    if config_save; then
        print_success "配置导入成功"
        echo ""
        echo "  服务器地址：${SERVER_USER}@${SERVER_HOST}"
        echo "  本地端口：${LOCAL_PORT}"
        echo ""
        print_warning "配置已更新，需要重启服务才能生效"
        echo "  执行：autosocks restart"
        log "INFO" "config" "配置已导入"
        return 0
    else
        print_error "配置保存失败" "E006"
        return 1
    fi
}


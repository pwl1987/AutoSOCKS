# 函数名：_status_json_active
# 功能：服务运行中的 JSON 输出
# 参数：无
# 返回：0
# 说明：实现 AC-01 ~ AC-07 所有验收标准
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_status_json_active() {
    local server_user="${SERVER_USER:-root}"
    local server_host="${SERVER_HOST:-unknown}"
    local server="${server_user}@${server_host}"
    local local_port="${LOCAL_PORT:-1080}"
    local uptime_sec
    uptime_sec=$(service_uptime)

    # HTTP 代理信息
    local http_port="${HTTP_PROXY_PORT:-8080}"
    local http_status="disabled"
    local http_bind="127.0.0.1"

    if [ -f "$PRIVOXY_CONF_FILE" ] && systemctl is-active privoxy &>/dev/null; then
        local actual_http_port
        actual_http_port=$(ss -tlnp 2>/dev/null | grep privoxy | grep -oP ':\K[0-9]+' | head -1)
        if [ -n "$actual_http_port" ]; then
            http_port="$actual_http_port"
        fi

        # 测试 HTTP 代理
        local http_code
        http_code=$(curl -x "http://127.0.0.1:${http_port}" -m 3 -s -o /dev/null -w "%{http_code}" http://www.gstatic.com/generate_204 2>/dev/null)
        if [ "$http_code" = "204" ] || [ "$http_code" = "200" ]; then
            http_status="running"
        else
            http_status="installed"
        fi
    elif command -v privoxy &>/dev/null; then
        http_status="installed"
    fi

    # 获取局域网绑定
    local local_bind="${LOCAL_BIND:-127.0.0.1}"
    http_bind="$local_bind"

    # 代理测试
    local latency
    local proxy_test_json
    if latency=$(service_latency); then
        proxy_test_json="${latency}"
    else
        proxy_test_json="null"
        log WARN "status" "代理测试失败"
    fi

    # 输出 JSON（使用 printf 避免 echo 的转义问题）
    printf '%s\n' "{"
    printf '  "status": "active",'"\n"
    printf '  "server": "%s",'"\n" "$server"
    printf '  "socks5": {"port": %s, "status": "running"},'"\n" "$local_port"
    printf '  "http": {"port": %s, "status": "%s", "bind": "%s"},'"\n" "$http_port" "$http_status" "$http_bind"
    printf '  "uptime_seconds": %s,'"\n" "$uptime_sec"
    if [ "$proxy_test_json" = "null" ]; then
        printf '  "proxy_test": %s,'"\n" "$proxy_test_json"
    else
        printf '  "proxy_test": %s,'"\n" "$proxy_test_json"
    fi
    printf '  "version": "%s"'"\n" "$VERSION"
    printf '%s\n' "}"

    log INFO "status" "服务运行中，已运行 ${uptime_sec} 秒"
}


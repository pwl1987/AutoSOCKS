    # 密码
    if [ -f "$PASS_FILE" ]; then
        _load_password_into_memory
        if [ -n "$SSH_PASSWORD" ]; then
            _doc "密码可解密" 0
            SSH_PASSWORD=""  # 立即清空
        else
            _doc "密码可解密" 1
        fi
    else
        _doc "密码文件存在（未配置 = 密钥认证）" 0
    fi

    # 密钥
    if [ -n "${AUTH_KEY_PATH:-}" ] && [ -f "$AUTH_KEY_PATH" ]; then
        _doc "SSH 密钥存在 ($AUTH_KEY_PATH)" 0
        if key_perms_ok "$AUTH_KEY_PATH"; then

# --------------------
# 9.1 自更新机制
# --------------------

# 借鉴 clash-for-linux-master 的 GitHub 镜像池 + 评分排序 + 冷却机制
# 文件位置：scripts/core/common.sh 第 553-989 行

AUTOSOCKS_UPDATE_URL="${AUTOSOCKS_UPDATE_URL:-https://raw.githubusercontent.com/your-org/autosocks/main/autosocks}"
AUTOSOCKS_VERSION_URL="${AUTOSOCKS_VERSION_URL:-https://raw.githubusercontent.com/your-org/autosocks/main/VERSION}"
readonly _MIRROR_SOURCES=(
    "origin|${AUTOSOCKS_UPDATE_URL}"
    "ghfast|https://ghfast.top/${AUTOSOCKS_UPDATE_URL#https://}"
    "ghproxy|https://ghproxy.net/${AUTOSOCKS_UPDATE_URL#https://}"
)
readonly _MIRROR_STATE_FILE="${CONFIG_DIR:-/etc/autosocks}/.mirror-state"

# 镜像评分（借鉴 clash download_mirror_score）
_mirror_score() {
    local name="$1"
    local state_file="${_MIRROR_STATE_FILE}"
    local score=0

    if [ ! -f "$state_file" ]; then
        echo "0"
        return
    fi

    local success_ts fail_count consec_fail last_fail_ts
    success_ts=$(awk -F'|' -v n="$name" '$1==n{print $2}' "$state_file" 2>/dev/null)
    fail_count=$(awk -F'|' -v n="$name" '$1==n{print $3}' "$state_file" 2>/dev/null)
    consec_fail=$(awk -F'|' -v n="$name" '$1==n{print $4}' "$state_file" 2>/dev/null)
    last_fail_ts=$(awk -F'|' -v n="$name" '$1==n{print $5}' "$state_file" 2>/dev/null)

    # 基础分
    [[ "$name" == "origin" ]] && ((score += 5))

    # 最近成功加分（衰减）
    local now
    now=$(date +%s)
    if [[ "$success_ts" =~ ^[0-9]+$ ]] && (( now - success_ts < 3600 )); then
        ((score += 200 - (now - success_ts) / 18))
    fi

    # 连续失败扣分
    if [[ "$consec_fail" =~ ^[0-9]+$ ]] && ((consec_fail > 0)); then
        ((score -= 20 * consec_fail))
    fi

    # 冷却期（最近失败 < 5 分钟）大幅扣分
    if [[ "$last_fail_ts" =~ ^[0-9]+$ ]] && (( now - last_fail_ts < 300 )); then
        ((score -= 1000))
    fi

    echo "$score"
}

# 更新镜像状态
_update_mirror_state() {
    local name="$1" field="$2" value="$3"
    local state_file="${_MIRROR_STATE_FILE}"
    local dir
    dir=$(dirname "$state_file")
    [ -d "$dir" ] || mkdir -p "$dir" 2>/dev/null || return 0

    if [ ! -f "$state_file" ]; then
        : > "$state_file"
    fi

    local found=0
    local tmp
    tmp=$(mktemp 2>/dev/null) || return 0
    while IFS='|' read -r n s fc cf lf; do
        if [ "$n" = "$name" ]; then
            found=1
            case "$field" in
                success)  echo "${n}|${value}|${fc}|0|${lf}" >> "$tmp" ;;
                fail)     echo "${n}|${s}|$((fc+1))|$((cf+1))|${value}" >> "$tmp" ;;
            esac
        else
            echo "${n}|${s}|${fc}|${cf}|${lf}" >> "$tmp"
        fi
    done < "$state_file"
    ((found == 0)) && case "$field" in
        success) echo "${name}|${value}|0|0|0" >> "$tmp" ;;
        fail)    echo "${name}|0|1|1|${value}" >> "$tmp" ;;
    esac
    mv "$tmp" "$state_file" 2>/dev/null || rm -f "$tmp"
}

# 下载文件（多镜像尝试）
_download_with_mirrors() {
    local url="$1" output="$2"
    local -a sorted=()

    # 按评分排序镜像
    local entry name mirror_url
    for entry in "${_MIRROR_SOURCES[@]}"; do
        name="${entry%%|*}"
        sorted+=("$(_mirror_score "$name")|${entry#*|}|${name}")
    done

    # 从高到低排序
    local IFS=$'\n'
    local -a ranked
    # shellcheck disable=SC2207
    ranked=($(printf '%s\n' "${sorted[@]}" | sort -rn))
    unset IFS

    for entry in "${ranked[@]}"; do
        local mirror_url="${entry#*|}"
        mirror_url="${mirror_url%|*}"
        local mname="${entry##*|}"

        if curl -fsSL --connect-timeout 10 --max-time 60 -o "$output" "$mirror_url" 2>/dev/null; then
            _update_mirror_state "$mname" "success" "$(date +%s)"
            return 0
        else
            _update_mirror_state "$mname" "fail" "$(date +%s)"
        fi
    done

    return 1
}

# 自更新命令
cmd_self_update() {
    log INFO "update" "检查更新..."

    # 下载最新版本号
    local tmp_version
    tmp_version=$(mktemp 2>/dev/null) || { print_error "无法创建临时文件" "E009"; return 1; }

    if ! _download_with_mirrors "$AUTOSOCKS_VERSION_URL" "$tmp_version"; then
        rm -f "$tmp_version"
        print_error "无法获取最新版本号" "E003"
        return 1
    fi

    local latest_version
    latest_version=$(cat "$tmp_version" 2>/dev/null | tr -d '[:space:]')
    rm -f "$tmp_version"

    if [ -z "$latest_version" ]; then
        print_error "版本信息为空" "E003"
        return 1
    fi

    if [ "$VERSION" = "$latest_version" ]; then
        print_success "已是最新版本: v${VERSION}"
        return 0
    fi

    echo "发现新版本: v${VERSION} → v${latest_version}"
    echo ""
    echo "更新内容："
    echo "  当前版本：v${VERSION}"
    echo "  最新版本：v${latest_version}"
    echo ""
    echo "是否更新？[Y/n]"

    local answer
    read -r answer 2>/dev/null || answer="y"
    [[ "${answer,,}" =~ ^(y|)$ ]] || { echo "已取消"; return 0; }

    # 备份当前脚本
    if [ -f "$SCRIPT_FILE" ]; then
        cp -f "$SCRIPT_FILE" "${SCRIPT_FILE}.bak.${VERSION}" 2>/dev/null || {
            print_error "备份失败" "E005"; return 1;
        }
    fi

    # 下载新版本
    local tmp_script
    tmp_script=$(mktemp 2>/dev/null) || { print_error "无法创建临时文件" "E009"; return 1; }

    echo "正在下载 v${latest_version}..."

    if ! _download_with_mirrors "$AUTOSOCKS_UPDATE_URL" "$tmp_script"; then
        rm -f "$tmp_script"
        print_error "下载失败" "E003"
        return 1
    fi

    # 验证下载的脚本（基础检查：非空 + bash 语法）
    if [ ! -s "$tmp_script" ]; then
        rm -f "$tmp_script"
        print_error "下载的文件为空" "E003"
        return 1
    fi

    if ! bash -n "$tmp_script" 2>/dev/null; then
        rm -f "$tmp_script"
        print_error "下载的脚本语法校验失败" "E006"
        return 1
    fi

    # 替换脚本
    chmod +x "$tmp_script"
    if ! mv "$tmp_script" "$SCRIPT_FILE" 2>/dev/null; then
        rm -f "$tmp_script"
        print_error "替换脚本失败（需要 root 权限）" "E001"
        return 1
    fi

    # 更新版本文件
    echo "$latest_version" > "${VERSION_FILE:-${CONFIG_DIR:-/etc/autosocks}/version}" 2>/dev/null

    print_success "已更新到 v${latest_version}"
    echo ""
    echo "提示：如需回滚，运行 autosocks rollback"

    log INFO "update" "自更新成功: ${VERSION} -> ${latest_version}"
    return 0
}

# --------------------
# 9.2 多服务器故障转移
# --------------------

# 借鉴 clash-for-linux-master 的策略组/节点选择设计
# 文件位置：scripts/core/proxy.sh 第 98-260 行

SERVERS_FILE="${CONFIG_DIR:-/etc/autosocks}/servers.conf"

# 添加服务器到服务器列表
server_add() {
    local user_host="$1"
    local port="${2:-22}"
    local priority="${3:-100}"
    local name="${4:-}"

    [ -z "$user_host" ] && { print_error "缺少服务器地址" "E009"; return 1; }

    local user host
    user="${user_host%%@*}"
    host="${user_host#*@}"

    [ -z "$name" ] && name="$host"

    local dir
    dir=$(dirname "${SERVERS_FILE}")
    [ -d "$dir" ] || mkdir -p "$dir" 2>/dev/null

    # 追加到服务器列表（格式：name|user|host|port|priority|fail_count|last_fail_ts）
    echo "${name}|${user}|${host}|${port}|${priority}|0|0" >> "$SERVERS_FILE"
    log INFO "server" "添加服务器: ${name} (${user}@${host}:${port})"
}

# 列出所有服务器
server_list() {
    [ -f "$SERVERS_FILE" ] || { echo "(无备用服务器)"; return 0; }
    printf "%-20s %-25s %-8s %-10s %-8s\n" "名称" "地址" "端口" "优先级" "状态"
    echo "--------------------------------------------------------------"
    while IFS='|' read -r name user host port priority fails last_fail; do
        [ -z "$name" ] && continue
        local status="可用"
        local now
        now=$(date +%s)
        if [[ "$last_fail" =~ ^[0-9]+$ ]] && (( now - last_fail < 300 )); then
            status="冷却中"
        fi
        ((fails > 3)) && status="不可用"
        printf "%-20s %-25s %-8s %-10s %-8s\n" "$name" "${user}@${host}" "$port" "$priority" "$status"
    done < "$SERVERS_FILE"
}

# 按优先级选择最佳服务器（故障转移核心）
server_select_best() {
    [ -f "$SERVERS_FILE" ] || return 1

    local now
    now=$(date +%s)
    local best="" best_priority=99999

    while IFS='|' read -r name user host port priority fails last_fail; do
        [ -z "$name" ] && continue

        # 跳过失败次数过多的（> 5 次）
        local f="${fails:-0}"
        (( f > 5 )) && continue

        # 跳过冷却中的（最近 5 分钟内失败过）
        if [[ "$last_fail" =~ ^[0-9]+$ ]] && (( now - last_fail < 300 )); then
            continue
        fi

        # 选择优先级数值最小的（数值越小越优先）
        local p="${priority:-100}"
        if (( p < best_priority )); then
            best_priority="$p"
            best="${user}|${host}|${port}"
        fi
    done < "$SERVERS_FILE"

    [ -z "$best" ] && return 1
    echo "$best"
}

# 标记服务器失败
server_mark_fail() {
    local host="$1"
    [ -f "$SERVERS_FILE" ] || return 0

    local tmp
    tmp=$(mktemp 2>/dev/null) || return 0
    while IFS='|' read -r name user host2 port priority fails last_fail; do
        if [ "$host2" = "$host" ]; then
            echo "${name}|${user}|${host2}|${port}|${priority}|$((fails+1))|$(date +%s)"
        else
            echo "${name}|${user}|${host2}|${port}|${priority}|${fails}|${last_fail}"
        fi
    done < "$SERVERS_FILE" > "$tmp"
    mv "$tmp" "$SERVERS_FILE" 2>/dev/null || rm -f "$tmp"
}

# 重置服务器失败计数（连接成功后调用）
server_reset_fails() {
    local host="$1"
    [ -f "$SERVERS_FILE" ] || return 0

    local tmp
    tmp=$(mktemp 2>/dev/null) || return 0
    while IFS='|' read -r name user host2 port priority fails last_fail; do
        if [ "$host2" = "$host" ]; then
            echo "${name}|${user}|${host2}|${port}|${priority}|0|0"
        else
            echo "${name}|${user}|${host2}|${port}|${priority}|${fails}|${last_fail}"
        fi
    done < "$SERVERS_FILE" > "$tmp"
    mv "$tmp" "$SERVERS_FILE" 2>/dev/null || rm -f "$tmp"
}

# 服务器管理命令
cmd_servers() {
    local sub="${1:-list}"
    case "$sub" in
        list|ls)
            server_list
            ;;
        add)
            [ -z "${2:-}" ] && { print_error "用法: autosocks servers add user@host [port] [priority] [name]" "E009"; return 1; }
            server_add "$2" "${3:-22}" "${4:-100}" "${5:-}"
            print_success "服务器已添加"
            ;;
        remove|rm)
            [ -z "${2:-}" ] && { print_error "用法: autosocks servers remove <host>" "E009"; return 1; }
            # 按主机名删除
            local tmp
            tmp=$(mktemp 2>/dev/null) || return 1
            [ -f "$SERVERS_FILE" ] && grep -v "|${2}|" "$SERVERS_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$SERVERS_FILE"
            print_success "已删除: $2"
            ;;
        failover)
            # 立即触发故障转移到最佳备用服务器
            local best
            best=$(server_select_best) || { print_error "无可用备用服务器" "E005"; return 1; }
            local user host port
            IFS='|' read -r user host port <<< "$best"
            print_success "故障转移到: ${user}@${host}:${port}"
            cmd_config --server "${user}@${host}" 2>/dev/null
            cmd_restart
            ;;
        *)
            echo "用法: autosocks servers [list|add|remove|failover]"
            ;;
    esac
}

# --------------------
# 9.3 健康检查守护循环
# --------------------

# 借鉴 clash-for-linux-master 的编译阶段守卫和持续监控设计
# 文件位置：scripts/core/config.sh 第 3855-4116 行

HEALTH_CHECK_PID_FILE="${PID_DIR:-/var/run/autosocks}/autosocks-health.pid"

# 持续健康检查循环（由 systemd 调用或作为后台任务）
health_check_loop() {
    local interval="${CHECK_INTERVAL:-30}"
    local max_fail="${MAX_FAIL:-3}"
    local max_retry="${MAX_RETRY:-5}"
    local fail_count=0
    local consecutive_fails=0
    local backoff="$interval"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] 健康检查守护启动 (间隔=${interval}s, 最大失败=${max_fail})" >> "${LOG_FILE:-/var/log/autosocks.log}" 2>/dev/null

    while true; do
        # 加载最新配置
        config_load 2>/dev/null || true

        local check_result=0
        if port_is_open 127.0.0.1 "${LOCAL_PORT:-1080}" 2>/dev/null; then
            # 端口开放，进一步测试代理
            local code
            code=$(curl -s --socks5 "127.0.0.1:${LOCAL_PORT:-1080}" --connect-timeout 5 --max-time 10 \
                -o /dev/null -w "%{http_code}" "${CHECK_URL:-https://cp.cloudflare.com}" 2>/dev/null || echo "")
            if [ -n "$code" ] && [[ "$code" =~ ^[23] ]]; then
                check_result=0
            else
                check_result=1
            fi
        else
            check_result=1
        fi

        if ((check_result == 0)); then
            if ((consecutive_fails > 0)); then
                log INFO "health" "代理恢复正常 (之前连续失败 ${consecutive_fails} 次)"
                send_webhook_alert "AutoSOCKS 代理已恢复正常"
            fi
            consecutive_fails=0
            fail_count=0
            backoff="$interval"
            # 重置当前服务器失败计数
            server_reset_fails "${SERVER_HOST:-}" 2>/dev/null
        else
            ((consecutive_fails++))
            ((fail_count++))
            log WARN "health" "健康检查失败 (${consecutive_fails}/${max_fail}), 下次检查 ${backoff}s 后"

            if ((consecutive_fails >= max_fail)); then
                log ERROR "health" "连续 ${max_fail} 次失败，尝试重连..."
                send_webhook_alert "AutoSOCKS 连续 ${consecutive_fails} 次健康检查失败，正在重连"

                # 尝试重启服务
                systemctl restart autosocks 2>/dev/null || true

                # 如果重启后仍失败，尝试故障转移
                if ((fail_count >= max_retry)); then
                    local best
                    best=$(server_select_best 2>/dev/null) || true
                    if [ -n "$best" ]; then
                        log INFO "health" "尝试故障转移到备用服务器..."
                        send_webhook_alert "AutoSOCKS 正在故障转移到备用服务器"
                        local user host port
                        IFS='|' read -r user host port <<< "$best"
                        cmd_config --server "${user}@${host}" 2>/dev/null
                        systemctl restart autosocks 2>/dev/null || true
                    fi
                    fail_count=0
                fi

                consecutive_fails=0
            fi

            # 指数退避：每次失败翻倍，最大 300 秒
            backoff=$((backoff * 2))
            ((backoff > 300)) && backoff=300
        fi

        sleep "$backoff"
    done
}

# 启动健康检查守护进程
cmd_health_start() {
    if [ -f "$HEALTH_CHECK_PID_FILE" ]; then
        local pid
        pid=$(_read_pid_file "$HEALTH_CHECK_PID_FILE")
        if [ -n "$pid" ] && is_pid_alive "$pid"; then
            print_warning "健康检查守护已在运行 (PID: $pid)"
            return 0
        fi
    fi

    # 后台启动
    (health_check_loop &)
    local pid=$!
    echo "$pid" > "$HEALTH_CHECK_PID_FILE"
    print_success "健康检查守护已启动 (PID: $pid, 间隔: ${CHECK_INTERVAL:-30}s)"
}

# 停止健康检查守护进程
cmd_health_stop() {
    [ -f "$HEALTH_CHECK_PID_FILE" ] || { print_warning "健康检查守护未运行"; return 0; }
    local pid
    pid=$(_read_pid_file "$HEALTH_CHECK_PID_FILE")
    if [ -n "$pid" ] && is_pid_alive "$pid"; then
        kill "$pid" 2>/dev/null
        sleep 0.5
        is_pid_alive "$pid" && kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$HEALTH_CHECK_PID_FILE"
    print_success "健康检查守护已停止"
}

# 健康检查管理命令
cmd_health() {
    local sub="${1:-status}"
    case "$sub" in
        start)   cmd_health_start ;;
        stop)    cmd_health_stop ;;
        restart) cmd_health_stop; sleep 1; cmd_health_start ;;
        status)
            if [ -f "$HEALTH_CHECK_PID_FILE" ]; then
                local pid
                pid=$(_read_pid_file "$HEALTH_CHECK_PID_FILE")
                if [ -n "$pid" ] && is_pid_alive "$pid"; then
                    print_success "健康检查守护运行中 (PID: $pid)"
                else
                    print_warning "健康检查守护已停止（PID 文件过期）"
                fi
            else
                print_warning "健康检查守护未启动"
            fi
            ;;
        *)
            echo "用法: autosocks health [start|stop|restart|status]"
            ;;
    esac
}

# --------------------
# 9.4 交互式重配置向导 + 端口冲突自动解决
# --------------------

# 借鉴 clash-for-linux-master 的端口冲突自动解决和交互式安装
# 文件位置：scripts/core/config.sh 第 2040-2071 行（resolve_runtime_ports）

# 端口冲突自动解决（在给定范围内寻找空闲端口）
resolve_available_port() {
    local preferred="$1"
    local min_port="${2:-$((preferred + 1))}"
    local max_port="${3:-$((preferred + 100))}"
    local exclude_csv="${4:-}"

    # 首选端口可用则直接返回
    if ! port_is_open 127.0.0.1 "$preferred" 2>/dev/null; then
        echo "$preferred"
        return 0
    fi

    # 在范围内搜索
    local port
    for ((port = min_port; port <= max_port; port++)); do
        # 跳过排除列表中的端口
        if [ -n "$exclude_csv" ] && echo ",$exclude_csv," | grep -q ",$port," 2>/dev/null; then
            continue
        fi
        if ! port_is_open 127.0.0.1 "$port" 2>/dev/null; then
            echo "$port"
            return 0
        fi
    done

    # 未找到
    echo ""
    return 1
}

# 交互式重配置向导（重新运行安装向导的核心部分）
cmd_reconfigure() {
    check_root || return 1

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AutoSOCKS 重新配置向导"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # 1. 服务器配置
    local current_server="${SERVER_USER:-root}@${SERVER_HOST:-}"
    echo "当前服务器: ${current_server}"
    echo -n "新服务器地址 (user@host, 留空保持不变): "
    local new_server
    read -r new_server 2>/dev/null || new_server=""

    if [ -n "$new_server" ]; then
        local new_user new_host
        new_user="${new_server%%@*}"
        new_host="${new_server#*@}"
        if [ -n "$new_host" ]; then
            SERVER_USER="$new_user"
            SERVER_HOST="$new_host"
            log INFO "reconfigure" "服务器更新: ${new_user}@${new_host}"
        fi
    fi

    # 2. 端口配置（带冲突自动解决）
    echo ""
    echo "当前 SOCKS5 端口: ${LOCAL_PORT:-1080}"
    echo -n "新端口 (留空保持不变): "
    local new_port
    read -r new_port 2>/dev/null || new_port=""

    if [ -n "$new_port" ]; then
        if port_is_open 127.0.0.1 "$new_port" 2>/dev/null; then
            # 端口被占用，自动寻找可用端口
            local resolved
            resolved=$(resolve_available_port "$new_port" "$((new_port + 1))" "$((new_port + 100))")
            if [ -n "$resolved" ]; then
                echo "  端口 $new_port 被占用，自动选择: $resolved"
                LOCAL_PORT="$resolved"
            else
                print_error "端口范围 $((new_port+1))-$((new_port+100)) 内无可用端口" "E002"
                return 1
            fi
        else
            LOCAL_PORT="$new_port"
        fi
    fi

    # 3. 认证方式
    echo ""
    echo "当前认证方式: ${AUTH_TYPE:-key}"
    echo "  1) 密钥认证"
    echo "  2) 密码认证"
    echo -n "选择 (留空保持不变): "
    local auth_choice
    read -r auth_choice 2>/dev/null || auth_choice=""

    case "$auth_choice" in
        1) AUTH_TYPE="key" ;;
        2) AUTH_TYPE="password" ;;
    esac

    # 4. HTTP 代理
    echo ""
    echo -n "是否启用 HTTP 代理？[y/N] "
    local http_choice
    read -r http_choice 2>/dev/null || http_choice=""
    if [[ "${http_choice,,}" == "y" ]]; then
        echo -n "HTTP 代理端口 [${HTTP_PROXY_PORT:-8080}]: "
        local http_port
        read -r http_port 2>/dev/null || http_port="${HTTP_PROXY_PORT:-8080}"
        HTTP_PROXY_PORT="${http_port:-${HTTP_PROXY_PORT:-8080}}"
    fi

    # 保存配置
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  配置摘要"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  服务器: ${SERVER_USER}@${SERVER_HOST}"
    echo "  SOCKS5 端口: ${LOCAL_PORT}"
    echo "  认证方式: ${AUTH_TYPE}"
    echo "  HTTP 代理端口: ${HTTP_PROXY_PORT:-未启用}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo -n "保存配置？[Y/n] "
    local save_choice
    read -r save_choice 2>/dev/null || save_choice="y"

    [[ "${save_choice,,}" =~ ^(y|)$ ]] || { echo "已取消"; return 0; }

    config_save || { print_error "保存配置失败" "E006"; return 1; }
    print_success "配置已保存"

    # 询问是否重启
    echo -n "是否立即重启服务？[Y/n] "
    local restart_choice
    read -r restart_choice 2>/dev/null || restart_choice="y"
    [[ "${restart_choice,,}" =~ ^(y|)$ ]] && cmd_restart

    return 0
}

# --------------------
# 9.5 标记块幂等注入
# --------------------

# 借鉴 clash-for-linux-master 的标记块模式管理 .bashrc / .profile
# 文件位置：scripts/core/common.sh 第 2659-2697 行
# 确保所有外部文件注入都是幂等的（多次执行结果相同）

readonly _MARKER_BEGIN="# >>> autosocks >>>"
readonly _MARKER_END="# <<< autosocks <<<"

# 在指定文件中注入标记块（幂等：先清除旧块再追加）
_inject_marker_block() {
    local file="$1"
    local content="$2"
    [ -f "$file" ] || touch "$file" 2>/dev/null || return 1

    # 清除旧标记块
    local tmp
    tmp=$(mktemp 2>/dev/null) || return 1
    awk -v begin="$_MARKER_BEGIN" -v end="$_MARKER_END" '
        $0 == begin {skip=1; next}
        $0 == end {skip=0; next}
        !skip {print}
    ' "$file" > "$tmp" 2>/dev/null && mv "$tmp" "$file" || { rm -f "$tmp"; return 1; }

    # 追加新标记块
    printf '\n%s\n%s\n%s\n' "$_MARKER_BEGIN" "$content" "$_MARKER_END" >> "$file"
}

# 从指定文件中移除标记块
_remove_marker_block() {
    local file="$1"
    [ -f "$file" ] || return 0

    local tmp
    tmp=$(mktemp 2>/dev/null) || return 0
    awk -v begin="$_MARKER_BEGIN" -v end="$_MARKER_END" '
        $0 == begin {skip=1; next}
        $0 == end {skip=0; next}
        !skip {print}
    ' "$file" > "$tmp" 2>/dev/null && mv "$tmp" "$file" || rm -f "$tmp"
}

# 安装 Shell 代理自动恢复到 .bashrc / .profile
cmd_install_shell_integration() {
    local shell_rc=""
    if [ -f "$HOME/.bashrc" ]; then
        shell_rc="$HOME/.bashrc"
    elif [ -f "$HOME/.zshrc" ]; then
        shell_rc="$HOME/.zshrc"
    elif [ -f "$HOME/.profile" ]; then
        shell_rc="$HOME/.profile"
    fi

    [ -z "$shell_rc" ] && { print_error "未找到 shell 配置文件" "E009"; return 1; }

    local content='eval "$(autosocks env 2>/dev/null)"'
    _inject_marker_block "$shell_rc" "$content" || { print_error "注入失败" "E005"; return 1; }

    print_success "Shell 代理自动恢复已安装到 $shell_rc"
    echo "  新终端打开时将自动设置代理环境变量"
}

# 移除 Shell 代理自动恢复
cmd_uninstall_shell_integration() {
    for rc_file in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile"; do
        [ -f "$rc_file" ] || continue
        _remove_marker_block "$rc_file"
    done
    print_success "Shell 代理自动恢复已移除"
}

# --------------------
# 9.6 安全增强
# --------------------

# 借鉴 clash-for-linux-master 的安全实践：
#   - 临时文件使用 mktemp 而非 PID 后缀
#   - trap 堆栈（多 trap 不覆盖）
#   - 配置文件完整性校验

# 临时文件安全创建（替代 /tmp/autosocks_xxx_$$ 模式）
autosocks_mktemp() {
    local prefix="${1:-autosocks}"
    local suffix="${2:-}"
    mktemp "${TMPDIR:-/tmp}/${prefix}.XXXXXX${suffix}" 2>/dev/null || {
        # fallback: 使用 /dev/urandom 生成随机后缀
        local rand
        rand=$(head -c 4 /dev/urandom | od -A n -t x1 | tr -d ' \n')
        echo "${TMPDIR:-/tmp}/${prefix}.${rand}${suffix}"
    }
}

# trap 堆栈：允许叠加多个 trap（不覆盖之前的）
# 借鉴 clash-for-linux-master 的做法，使用数组存储 trap 回调
_AUTOSOCKS_TRAP_STACK_EXIT=()
_AUTOSOCKS_TRAP_STACK_TERM=()
_AUTOSOCKS_TRAP_STACK_INT=()

_push_trap() {
    local signal="$1"
    local callback="$2"
    case "$signal" in
        EXIT) _AUTOSOCKS_TRAP_STACK_EXIT+=("$callback") ;;
        TERM) _AUTOSOCKS_TRAP_STACK_TERM+=("$callback") ;;
        INT)  _AUTOSOCKS_TRAP_STACK_INT+=("$callback") ;;
    esac
}

_autosocks_trap_dispatcher() {
    local signal="$1"
    local -a stack=()
    case "$signal" in
        EXIT) stack=("${_AUTOSOCKS_TRAP_STACK_EXIT[@]}") ;;
        TERM) stack=("${_AUTOSOCKS_TRAP_STACK_TERM[@]}") ;;
        INT)  stack=("${_AUTOSOCKS_TRAP_STACK_INT[@]}") ;;
    esac
    for cb in "${stack[@]}"; do
        eval "$cb" 2>/dev/null || true
    done
}

# 初始化 trap 堆栈
trap '_autosocks_trap_dispatcher EXIT' EXIT
trap '_autosocks_trap_dispatcher TERM' TERM
trap '_autosocks_trap_dispatcher INT' INT

# 配置文件完整性校验（SHA256）
config_checksum() {
    [ -f "$CONFIG_FILE" ] || return 1
    sha256sum "$CONFIG_FILE" 2>/dev/null | awk '{print $1}'
}

# 保存配置校验和
config_checksum_save() {
    local checksum_file="${CONFIG_DIR:-/etc/autosocks}/.checksum"
    config_checksum > "$checksum_file" 2>/dev/null
}

# 验证配置文件完整性
config_checksum_verify() {
    local checksum_file="${CONFIG_DIR:-/etc/autosocks}/.checksum"
    [ -f "$checksum_file" ] || return 0  # 无校验和文件时跳过
    [ -f "$CONFIG_FILE" ] || return 1

    local saved current
    saved=$(cat "$checksum_file" 2>/dev/null)
    current=$(config_checksum)

    [ "$saved" = "$current" ]
}


# ============================================================
# 函数：cmd_geo
# 功能：GeoIP分流命令入口
# 参数：
#   $1 - 子命令 (on/off/status/lookup/debug)
# 返回：0成功，1失败
# ============================================================
cmd_geo() {
    local subcommand="${1:-help}"
    shift 2>/dev/null || true

    case "$subcommand" in
        on)
            geo_on "$@"
            ;;
        off)
            geo_off "$@"
            ;;
        status)
            geo_status "$@"
            ;;
        lookup)
            geo_lookup "$@"
            ;;
        debug)
            geo_debug "$@"
            ;;
        help|--help|-h)
            geo_help
            ;;
        *)
            print_error "未知子命令：$subcommand" "E901"
            echo "  用法：autosocks geo <on|off|status|lookup|debug>"
            echo ""
            echo "  示例："
            echo "    autosocks geo on        # 开启分流"
            echo "    autosocks geo off       # 关闭分流"
            echo "    autosocks geo status    # 查看状态"
            echo "    autosocks geo lookup 8.8.8.8  # 查询IP归属地"
            echo "    autosocks geo debug    # 调试信息"
            return 2
            ;;
    esac
}


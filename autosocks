# ============================================================
# 函数：geo_lookup
# 功能：查询IP归属地
# 参数：
#   $1 - IP地址
# ============================================================
geo_lookup() {
    local ip="${1:-}"

    # 检查参数
    if [ -z "$ip" ]; then
        print_error "请指定IP地址" "E905"
        echo ""
        echo "  用法：autosocks geo lookup <IP>"
        echo "  示例：autosocks geo lookup 8.8.8.8"
        return 2
    fi

    # 验证IP格式
    if ! echo "$ip" | grep -qE '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$'; then
        print_error "IP格式错误" "E906"
        echo ""
        echo "  正确的IP示例：8.8.8.8 或 123.45.67.89"
        return 2
    fi

    # 检查DB-IP是否可用
    if ! _check_dbip_works; then
        print_error "DB-IP数据库未安装" "E907"
        echo ""
        echo "  请先运行：autosocks geo on"
        return 1
    fi

    # 查询归属地
    echo "🔍 IP归属地查询"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    local result
    result=$(geoiplookup "$ip" 2>/dev/null)

    if [ -z "$result" ]; then
        print_error "查询失败，未找到IP信息"
        return 1
    fi

    # 解析结果
    local country_code country_name
    country_code=$(echo "$result" | cut -d',' -f1 | xargs)
    country_name=$(echo "$result" | cut -d',' -f2 | xargs)

    echo "  IP地址     $ip"
    echo "  国家代码   ${country_code:-N/A}"
    echo "  归属地     ${country_name:-N/A}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    return 0
}


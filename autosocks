# --------------------
# 8.1 跨平台基础设施
# --------------------

# 跨平台 stat：$1=Linux 格式 $2=macOS 格式 $3=文件
_xstat() {
    stat -c "$1" "$3" 2>/dev/null || stat -f "$2" "$3" 2>/dev/null || echo ""
}

# 跨平台 timeout（macOS 无原生 timeout）
safe_timeout() {
    if command -v gtimeout &>/dev/null; then
        gtimeout "$@"
    elif command -v timeout &>/dev/null; then
        timeout "$@"
    else
        local dur="$1"; shift
        perl -e 'alarm $ARGV[0]; exec @ARGV' "$dur" "$@" 2>/dev/null || return 124
    fi
}

# 端口开放检测（多工具降级）
port_is_open() {
    local host="${1:-127.0.0.1}"
    local port="$2"
    local timeout_sec="${3:-1}"
    if command -v nc &>/dev/null; then
        nc -z -w "$timeout_sec" "$host" "$port" 2>/dev/null && return 0
    fi
    if command -v curl &>/dev/null; then
        curl -s --connect-timeout "$timeout_sec" -o /dev/null "tcp://$host:$port" 2>/dev/null && return 0
    fi
    safe_timeout "$timeout_sec" bash -c "echo >/dev/tcp/$host/$port" 2>/dev/null && return 0
    return 1
}

# 通过端口反查监听 PID（ss→lsof→netstat 降级）
pid_by_port() {
    local port="$1"
    if command -v ss &>/dev/null; then
        local p
        p=$(ss -tlnp "sport = :$port" 2>/dev/null | grep -m1 -oP 'pid=\K[0-9]+')
        [[ -n "$p" ]] && echo "$p" && return 0
    fi
    if command -v lsof &>/dev/null; then
        local p
        p=$(lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk 'NR>1{print $2; exit}')
        [[ -n "$p" ]] && echo "$p" && return 0
    fi
    if command -v netstat &>/dev/null; then
        local p
        p=$(netstat -anp tcp 2>/dev/null | awk -v p=".$port" '$0 ~ p && $0 ~ /LISTEN/{print $9; exit}')
        [[ -n "$p" ]] && echo "$p" && return 0
    fi
    return 1
}

# 检查 PID 是否存活
is_pid_alive() {
    local pid="${1:-}"
    [[ "$pid" =~ ^[1-9][0-9]*$ ]] || return 1
    [[ -d "/proc/$pid" ]]
}

# 读取 PID 文件并验证为正整数
_read_pid_file() {
    local file="$1"
    [[ -z "$file" || ! -f "$file" ]] && return 0
    local val
    val=$(cat "$file" 2>/dev/null) || return 0
    val="${val#"${val%%[![:space:]]*}"}"
    val="${val%"${val##*[![:space:]]}"}"
    [[ "$val" =~ ^[1-9][0-9]*$ ]] && echo "$val"
    true
}

# 端口回收：杀掉占用端口的旧 SSH 代理
reclaim_port() {
    local port="$1"
    local old_pid
    old_pid=$(pid_by_port "$port" 2>/dev/null) || return 1
    [[ -z "$old_pid" || ! "$old_pid" =~ ^[0-9]+$ ]] && return 1

    log INFO "reclaim" "端口 $port 被旧进程占用 (PID $old_pid)，正在回收..."
    kill "$old_pid" 2>/dev/null || return 1

    local waited=0
    while port_is_open 127.0.0.1 "$port"; do
        sleep 0.5
        ((waited++))
        if ((waited >= 10)); then
            kill -9 "$old_pid" 2>/dev/null || true
            sleep 0.5
            port_is_open 127.0.0.1 "$port" && return 1
            break
        fi
    done
    log INFO "reclaim" "已回收端口 $port (旧 PID $old_pid 已终止)"
    return 0
}

# 检查密钥文件权限（600/400）
key_perms_ok() {
    local key="${1:-${AUTH_KEY_PATH:-$HOME/.ssh/id_rsa}}"
    [[ -z "$key" || ! -f "$key" ]] && return 1
    local perms
    perms=$(_xstat %a %Lp "$key") || return 1
    [[ "$perms" == "600" || "$perms" == "400" ]]
}

# --------------------
# 8.2 日志增强：rotate_log + log_warn + log_error
# --------------------

LOG_MAX_SIZE=${LOG_MAX_SIZE:-1048576}  # 默认 1MB
readonly _LOG_ROTATE_KEEP=3

rotate_log() {
    [[ -z "${LOG_FILE:-}" || ! -f "$LOG_FILE" ]] && return 0
    local size
    size=$(_xstat %s %z "$LOG_FILE")
    [[ -z "$size" ]] && size=0
    if (( size > LOG_MAX_SIZE )); then
        local i
        for ((i = _LOG_ROTATE_KEEP; i >= 1; i--)); do
            local prev=$((i - 1))
            local dst="${LOG_FILE}.$i"
            ((i == _LOG_ROTATE_KEEP)) && { rm -f "$dst" 2>/dev/null; continue; }
            local src="${LOG_FILE}.$prev"
            [[ -f "$src" ]] && mv -f "$src" "$dst" 2>/dev/null
        done
        mv -f "$LOG_FILE" "${LOG_FILE}.1" 2>/dev/null
        : > "$LOG_FILE"
    fi
}

log_warn() {
    rotate_log
    local ts
    printf -v ts '%(%Y-%m-%d %H:%M:%S)T' -1 2>/dev/null || ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local msg="[$ts] WARN $1"
    printf '%b\n' "${YELLOW}⚠ $msg${NC}" >&2
    echo "$msg" >> "$LOG_FILE" 2>/dev/null
}

log_error() {
    rotate_log
    local ts
    printf -v ts '%(%Y-%m-%d %H:%M:%S)T' -1 2>/dev/null || ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local msg="[$ts] ERROR $1"
    printf '%b\n' "${RED}✗ $msg${NC}" >&2
    echo "$msg" >> "$LOG_FILE" 2>/dev/null
}

# --------------------
# 8.3 配置白名单 + 值校验
# --------------------

# 借用 ssh-proxy.sh 的白名单机制：
# 加载配置时只接受白名单内的 key，过滤掉可能由恶意配置文件注入的变量
readonly _AUTOSOCKS_CONFIG_WHITELIST="SERVER_HOST SERVER_USER SERVER_PORT LOCAL_PORT LOCAL_BIND AUTH_TYPE AUTH_KEY_PATH SSH_KEEPALIVE SSH_TIMEOUT RECONNECT_ENABLED RECONNECT_INTERVAL LOG_ENABLED LOG_PATH REMOTE_HTTP_PORT HTTP_PROXY_PORT NO_PROXY_LIST CHECK_INTERVAL MAX_FAIL MAX_RETRY CHECK_URL COMPRESS BIND_ADDRESS FINGERPRINT_PIN WEBHOOK_URL SSH_PASSWORD LOG_MAX_SIZE PASS_MAX_AGE"

# 验证配置值是否符合类型/范围（移植自 ssh-proxy.sh set_config）
_validate_config_value() {
    local key="$1"
    local val="$2"

    case "$key" in
        SERVER_PORT|LOCAL_PORT|HTTP_PROXY_PORT)
            if ! [[ "$val" =~ ^[0-9]+$ ]]; then
                print_error "$key 需要数字值" "E012"; return 1
            fi
            if (( val < 1 || val > 65535 )); then
                print_error "$key 超出端口范围 (1-65535): $val" "E012"; return 1
            fi
            ;;
        REMOTE_HTTP_PORT)
            if ! [[ "$val" =~ ^[0-9]+$ ]]; then
                print_error "$key 需要数字值" "E012"; return 1
            fi
            if (( val < 0 || val > 65535 )); then
                print_error "$key 超出范围 (0=禁用, 1-65535): $val" "E012"; return 1
            fi
            ;;
        SSH_KEEPALIVE|SSH_TIMEOUT|RECONNECT_INTERVAL|CHECK_INTERVAL|MAX_RETRY|PASS_MAX_AGE)
            if ! [[ "$val" =~ ^[0-9]+$ ]]; then
                print_error "$key 需要数字值" "E012"; return 1
            fi
            if (( val < 1 )); then
                print_error "$key 必须 >= 1: $val" "E012"; return 1
            fi
            if (( val > 86400 )); then
                print_error "$key 超出合理范围 (1-86400): $val" "E012"; return 1
            fi
            ;;
        LOG_MAX_SIZE)
            if ! [[ "$val" =~ ^[0-9]+$ ]]; then
                print_error "$key 需要数字值" "E012"; return 1
            fi
            if (( val < 1024 )); then
                print_error "$key 必须 >= 1024 字节: $val" "E012"; return 1
            fi
            if (( val > 1073741824 )); then
                print_error "$key 超出合理范围 (1GB): $val" "E012"; return 1
            fi
            ;;
        MAX_FAIL)
            if ! [[ "$val" =~ ^[0-9]+$ ]]; then
                print_error "$key 需要数字值" "E012"; return 1
            fi
            if (( val < 1 || val > 30 )); then
                print_error "$key 超出合理范围 (1-30): $val" "E012"; return 1
            fi
            ;;
        AUTH_TYPE)
            case "$val" in
                key|password|auto) ;;
                *) print_error "AUTH_TYPE 仅接受 key/password/auto" "E012"; return 1 ;;
            esac
            ;;
        LOCAL_BIND|BIND_ADDRESS)
            if [[ ! "$val" =~ ^(127\.0\.0\.1|0\.0\.0\.0|::1|::)$ ]]; then
                print_error "$key 应为 127.0.0.1/0.0.0.0/::1/::" "E012"; return 1
            fi
            ;;
        AUTH_KEY_PATH)
            # 路径遍历防护
            if [[ "$val" == *..* || "$val" == *$'\n'* ]]; then
                print_error "AUTH_KEY_PATH 路径不合法：包含 .. 或换行" "E006"; return 1
            fi
            ;;
        SERVER_HOST)
            # 主机名/IP 基础校验
            if [ -n "$val" ] && [[ ! "$val" =~ ^[a-zA-Z0-9._:-]+$ ]]; then
                print_error "SERVER_HOST 包含非法字符: $val" "E006"; return 1
            fi
            ;;
    esac
    return 0
}

# --------------------
# 8.4 密码 AES-256-CBC 加密（借鉴 ssh-proxy.sh save_password/load_password）
# --------------------

readonly _AUTOSOCKS_CIPHER_OPTS=(-aes-256-cbc -pbkdf2 -iter 100000)
PASS_FILE="${AUTOSOCKS_PASS_FILE:-/etc/autosocks/.pass}"
PASS_SALT_FILE="${AUTOSOCKS_PASS_SALT_FILE:-/etc/autosocks/.salt}"

_pass_phrase() {
    if [ -f "$PASS_SALT_FILE" ]; then
        cat "$PASS_SALT_FILE"
    else
        local s
        s=$(openssl rand -hex 16 2>/dev/null || head -c 16 /dev/urandom | xxd -p)
        local dir
        dir=$(dirname "$PASS_SALT_FILE")
        [ -d "$dir" ] || mkdir -p "$dir" 2>/dev/null
        (umask 077 && printf '%s' "$s" > "$PASS_SALT_FILE") || true
        chmod 600 "$PASS_SALT_FILE" 2>/dev/null || true
        echo "$s"
    fi
}

save_password() {
    local pass="$1"
    if [ -z "$pass" ]; then
        rm -f "$PASS_FILE" 2>/dev/null || true
        return 0
    fi
    local phrase
    phrase=$(_pass_phrase)
    echo "$pass" | openssl enc "${_AUTOSOCKS_CIPHER_OPTS[@]}" -pass pass:"$phrase" -a -salt > "$PASS_FILE" 2>/dev/null
    chmod 600 "$PASS_FILE" 2>/dev/null || true
}

# 加载密码到 SSH_PASSWORD 全局变量（仅供 daemon_mode 短期使用）
_load_password_into_memory() {
    [ -f "$PASS_FILE" ] || return 0
    local phrase
    phrase=$(_pass_phrase)
    SSH_PASSWORD=$(openssl enc "${_AUTOSOCKS_CIPHER_OPTS[@]}" -pass pass:"$phrase" -a -d -salt < "$PASS_FILE" 2>/dev/null || echo "")
}

# --------------------
# 8.5 健康检查 + 自动重连（借鉴 ssh-proxy.sh health_check_loop / handle_reconnect）
# --------------------

# 默认值（与 ssh-proxy.sh 对齐）
: "${CHECK_INTERVAL:=30}"
: "${MAX_FAIL:=3}"
: "${MAX_RETRY:=5}"
: "${CHECK_URL:=https://cp.cloudflare.com}"

# 立即健康检查（一次性）：通过 SOCKS5 探测 CHECK_URL
check_now() {
    config_load || return 1

    # 检查服务是否运行
    if ! systemctl is-active autosocks &>/dev/null; then
        print_error "代理服务未运行" "E005"
        return 1
    fi

    local code
    code=$(curl -s --socks5 "127.0.0.1:${LOCAL_PORT}" --connect-timeout 5 --max-time 10 \
        -o /dev/null -w "%{http_code}" "${CHECK_URL}" 2>/dev/null || echo "")
    if [ -n "$code" ] && [[ "$code" =~ ^[23] ]]; then
        print_success "健康检查通过 (HTTP ${code}, 端口 ${LOCAL_PORT})"
        return 0
    else
        print_error "健康检查失败 (HTTP ${code:-无响应}, 端口 ${LOCAL_PORT})" "E003"
        return 1
    fi
}

# 动态计算检查间隔（平均延迟 > 2s 时缩短间隔）
_calculate_check_interval() {
    local avg_latency="${1:-0}"
    local base="$CHECK_INTERVAL"
    if (( avg_latency > 2000 )); then
        base=$((CHECK_INTERVAL / 2))
        (( base < 10 )) && base=10
    fi
    echo "$base"
}

# 延迟探测（多次采样取均值）
cmd_latency() {
    local count="${1:-3}"
    config_load || return 1

    local socks_port="${LOCAL_PORT:-1080}"
    local target="${CHECK_URL:-https://cp.cloudflare.com}"
    local total=0
    local ok=0

    for ((i=1; i<=count; i++)); do
        local t
        t=$(curl -s --socks5 "127.0.0.1:${socks_port}" --connect-timeout 5 --max-time 10 \
            -o /dev/null -w "%{time_total}" "$target" 2>/dev/null || echo "")
        if [ -n "$t" ]; then
            local ms
            ms=$(awk -v t="$t" 'BEGIN{printf "%.0f", t*1000}')
            echo "  样本 $i: ${ms} ms"
            total=$((total + ms))
            ((ok++))
        else
            echo "  样本 $i: 失败"
        fi
    done

    if (( ok == 0 )); then
        print_error "延迟探测失败（所有样本均失败）" "E003"
        return 1
    fi

    local avg=$((total / ok))
    print_success "平均延迟 ${avg} ms (${ok}/${count} 样本, 目标 ${target})"
    return 0
}

# 等待隧道就绪（PID 存活 + 端口开放）
cmd_ready() {
    local timeout="${1:-10}"
    local pid_file="${PID_DIR:-/var/run/autosocks}/autosocks.pid"
    local socks_pid
    socks_pid=$(_read_pid_file "$pid_file")

    local start_ts
    start_ts=$(date +%s)
    while :; do
        local now_ts
        now_ts=$(date +%s)
        if (( now_ts - start_ts >= timeout )); then
            print_error "等待隧道就绪超时 (port ${LOCAL_PORT:-1080}, ${timeout}s)"
            return 124
        fi

        local ready=1
        if [ -n "$socks_pid" ] && ! is_pid_alive "$socks_pid"; then
            ready=0
        fi
        if ! port_is_open 127.0.0.1 "${LOCAL_PORT:-1080}"; then
            ready=0
        fi
        if (( ready == 1 )); then
            print_success "隧道就绪 (port ${LOCAL_PORT:-1080}, $((now_ts - start_ts))s)"
            return 0
        fi
        sleep 0.5
    done
}

# --------------------
# 8.6 HTTP 代理（gost SOCKS5→HTTP，可选；参考 ssh-proxy.sh start_http_proxy）
# --------------------

HTTP_PROXY_PID_FILE="${PID_DIR:-/var/run/autosocks}/autosocks-http.pid"

# 启动 gost HTTP 代理（如果安装了 gost）
start_http_proxy_via_gost() {
    if ! command -v gost &>/dev/null; then
        log INFO "http" "gost 未安装，跳过 HTTP 代理（仅 SOCKS5 可用）"
        return 0
    fi

    if ! port_is_open 127.0.0.1 "${LOCAL_PORT:-1080}" 2>/dev/null; then
        log WARN "http" "SOCKS5 端口 ${LOCAL_PORT:-1080} 未监听，HTTP 代理不启动"
        return 0
    fi

    local http_port="${HTTP_PROXY_PORT:-8080}"
    log INFO "http" "启动 gost: 127.0.0.1:${http_port} -> socks5://127.0.0.1:${LOCAL_PORT:-1080}"

    local log_dir
    log_dir=$(dirname "${LOG_FILE:-/var/log/autosocks.log}")
    [ -d "$log_dir" ] || mkdir -p "$log_dir" 2>/dev/null

    # 数组形式：避免注入
    ( gost -L "http://127.0.0.1:${http_port}" \
           -F "socks5://127.0.0.1:${LOCAL_PORT:-1080}" \
           &>> "$LOG_FILE" </dev/null & echo "$!" > "$HTTP_PROXY_PID_FILE" )

    # 等待就绪
    local i
    for ((i=0; i<30; i++)); do
        if port_is_open 127.0.0.1 "${http_port}" 2>/dev/null; then
            log INFO "http" "gost HTTP 代理就绪 (端口 ${http_port})"
            return 0
        fi
        sleep 0.1
    done
    log WARN "http" "gost HTTP 代理端口 ${http_port} 启动超时"
    return 0
}

stop_http_proxy_via_gost() {
    [ -f "$HTTP_PROXY_PID_FILE" ] || return 0
    local pid
    while IFS= read -r pid; do
        [ -z "$pid" ] && continue
        [[ "$pid" =~ ^[0-9]+$ ]] || continue
        kill "$pid" 2>/dev/null || true
    done < "$HTTP_PROXY_PID_FILE"
    rm -f "$HTTP_PROXY_PID_FILE" 2>/dev/null || true
}

# --------------------
# 8.7 WEBHOOK 告警 + 队列重试（借鉴 ssh-proxy.sh alert/queue_webhook/drain_webhook_queue）
# --------------------

WEBHOOK_QUEUE_FILE="${PID_DIR:-/var/run/autosocks}/webhook-queue"
WEBHOOK_URL="${WEBHOOK_URL:-}"

# JSON 字符串转义
_json_escape() {
    local s=$1
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\r'/\\r}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

send_webhook_alert() {
    local msg="$1"
    [ -z "$WEBHOOK_URL" ] && return 0
    local safe
    safe=$(_json_escape "$msg")
    local payload="{\"msgtype\":\"text\",\"text\":{\"content\":\"AutoSOCKS Alert: $safe\"}}"
    if ! curl -sf -X POST "$WEBHOOK_URL" -H "Content-Type: application/json" \
           -d "$payload" &>/dev/null; then
        # 失败入队
        _queue_webhook "$payload"
    fi
    _drain_webhook_queue
}

_queue_webhook() {
    local payload="$1"
    local dir
    dir=$(dirname "$WEBHOOK_QUEUE_FILE")
    [ -d "$dir" ] || mkdir -p "$dir" 2>/dev/null
    echo "$payload" >> "$WEBHOOK_QUEUE_FILE" 2>/dev/null
}

_drain_webhook_queue() {
    [ -f "$WEBHOOK_QUEUE_FILE" ] || return 0
    [ -n "$WEBHOOK_URL" ] || return 0
    local tmp
    tmp=$(mktemp 2>/dev/null) || return 0
    while IFS= read -r payload; do
        [ -z "$payload" ] && continue
        if curl -sf -X POST "$WEBHOOK_URL" -H "Content-Type: application/json" \
               -d "$payload" &>/dev/null; then
            continue
        fi
        echo "$payload" >> "$tmp" 2>/dev/null
    done < "$WEBHOOK_QUEUE_FILE"
    mv "$tmp" "$WEBHOOK_QUEUE_FILE" 2>/dev/null || rm -f "$tmp"
}

# --------------------
# 8.8 远端指纹校验（FINGERPRINT_PIN）
# --------------------

fingerprint_pin() {
    config_load || return 1
    [ -n "$SERVER_HOST" ] || { print_error "未配置服务器" "E006"; return 1; }

    local actual
    actual=$(ssh-keyscan -T 5 -t ed25519,rsa,ecdsa "$SERVER_HOST" 2>/dev/null \
             | ssh-keygen -lf - 2>/dev/null \
             | awk '{print $2}' | sort -u)
    if [ -z "$actual" ]; then
        print_error "无法获取服务器指纹（连接超时或无密钥）" "E003"
        return 1
    fi

    echo "当前指纹："
    echo "$actual" | sed 's/^/  /'

    if [ -n "${FINGERPRINT_PIN:-}" ]; then
        if echo "$actual" | grep -q "$FINGERPRINT_PIN"; then
            print_success "指纹匹配 FINGERPRINT_PIN"
            return 0
        else
            print_error "指纹不匹配！可能存在中间人攻击" "E011"
            send_webhook_alert "SSH fingerprint mismatch for $SERVER_HOST"
            return 1
        fi
    fi
}

